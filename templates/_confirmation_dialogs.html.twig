<dialog id="custom-confirm-dialog" class="confirmation-dialog">
    <div class="modal-dialog-content">
        <div class="confirmation-icon" id="confirm-dialog-icon">⚠️</div>
        <h3 class="confirmation-title" id="confirm-dialog-title">Confirmation</h3>
        <p class="confirmation-message" id="confirm-dialog-message"></p>
        <div class="confirmation-actions">
            <button type="button" class="btn-confirm-cancel" id="confirm-dialog-cancel">Annuler</button>
            <button type="button" class="btn-confirm-action" id="confirm-dialog-ok">Confirmer</button>
        </div>
    </div>
</dialog>

<dialog id="custom-alert-dialog" class="confirmation-dialog">
    <div class="modal-dialog-content">
        <div class="confirmation-icon" id="alert-dialog-icon">⚠️</div>
        <h3 class="confirmation-title" id="alert-dialog-title">Attention</h3>
        <p class="confirmation-message" id="alert-dialog-message"></p>
        <div class="confirmation-actions">
            <button type="button" class="btn-confirm-action" id="alert-dialog-ok">OK</button>
        </div>
    </div>
</dialog>
