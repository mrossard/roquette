<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="app-env" content="{{ app.environment }}">
        <meta name="htmx-config" content='{"historyCacheSize": 0, "globalViewTransitions": true}'>
        <script>
            window.AppTranslations = {
                "Rechercher un émoji...": "{{ 'Rechercher un émoji...'|trans|escape('js') }}",
                "Aucun émoji ne correspond": "{{ 'Aucun émoji ne correspond'|trans|escape('js') }}",
                "Visages & Personnes": "{{ 'Visages & Personnes'|trans|escape('js') }}",
                "Animaux & Nature": "{{ 'Animaux & Nature'|trans|escape('js') }}",
                "Nourriture & Boissons": "{{ 'Nourriture & Boissons'|trans|escape('js') }}",
                "Activités & Loisirs": "{{ 'Activités & Loisirs'|trans|escape('js') }}",
                "Voyages & Lieux": "{{ 'Voyages & Lieux'|trans|escape('js') }}",
                "Objets & Outils": "{{ 'Objets & Outils'|trans|escape('js') }}",
                "Symboles": "{{ 'Symboles'|trans|escape('js') }}",
                "Drapeaux": "{{ 'Drapeaux'|trans|escape('js') }}",
                "Connecté au Hub": "{{ 'Connecté au Hub'|trans|escape('js') }}",
                "Connexion au Hub...": "{{ 'Connexion au Hub...'|trans|escape('js') }}",
                "Erreur: Hub non configuré": "{{ 'Erreur: Hub non configuré'|trans|escape('js') }}",
                "Connexion interrompue": "{{ 'Connexion interrompue'|trans|escape('js') }}",
                "Erreur de connexion": "{{ 'Erreur de connexion'|trans|escape('js') }}",
                "Connexion au serveur instable. Reconnexion en cours...": "{{ 'Connexion au serveur instable. Reconnexion en cours...'|trans|escape('js') }}",
                "Connexion au serveur perdue. Tentative de reconnexion...": "{{ 'Connexion au serveur perdue. Tentative de reconnexion...'|trans|escape('js') }}"
            };
        </script>
        <script>
            (function() {
                const theme = {% if app.user %}'{{ app.user.theme }}'{% else %}localStorage.getItem('theme') || 'dark'{% endif %};
                document.documentElement.setAttribute('data-theme', theme);
                localStorage.setItem('theme', theme);

                const hljsLink = document.createElement('link');
                hljsLink.id = 'hljs-theme';
                hljsLink.rel = 'stylesheet';
                hljsLink.href = theme === 'dark'
                    ? '{{ asset('styles/highlight/atom-one-dark.min.css') }}'
                    : '{{ asset('styles/highlight/atom-one-light.min.css') }}';
                document.head.appendChild(hljsLink);
            })();
        </script>
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" type="image/svg+xml" href="{{ asset('favicon.svg') }}">
        <link rel="manifest" href="{{ asset('manifest.webmanifest') }}">
        <meta name="theme-color" content="#00e5ff">
        <meta name="apple-mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
        <link rel="apple-touch-icon" href="{{ asset('icons/apple-touch-icon.png') }}">

        {% if app.user %}
        <style>
            :root {
                --user-hue-primary: {{ app.user.hue }};
                /* Override default accents with user custom hue settings */
                --accent-cyan: hsl(var(--user-hue-primary), 100%, 45%);
                --accent-cyan-glow: hsla(var(--user-hue-primary), 100%, 50%, 0.15);
                --accent-purple: hsl(calc((var(--user-hue-primary) + 84) % 360), 91%, 65%);
                --accent-purple-glow: hsla(calc((var(--user-hue-primary) + 84) % 360), 91%, 65%, 0.15);
            }
            [data-theme="light"] {
                --accent-cyan: hsl(var(--user-hue-primary), 100%, 30%);
                --accent-cyan-glow: hsla(var(--user-hue-primary), 100%, 30%, 0.15);
                --accent-purple: hsl(calc((var(--user-hue-primary) + 84) % 360), 75%, 45%);
                --accent-purple-glow: hsla(calc((var(--user-hue-primary) + 84) % 360), 75%, 45%, 0.15);
            }

            /* Declarative visibility states based on current user session */
            .feed-item .btn-edit-subtle,
            .feed-item .btn-delete-subtle {
                display: none !important;
            }

            .feed-item[data-author-username="{{ app.user.username }}"]:not([data-poll-has-votes="1"]) .btn-edit-subtle {
                display: inline-flex !important;
            }

            .feed-item[data-author-username="{{ app.user.username }}"] .btn-delete-subtle {
                display: inline-flex !important;
            }

            #live-feed[data-is-channel-creator="true"] .btn-delete-subtle {
                display: inline-flex !important;
            }

            .feed-item[data-author-username="{{ app.user.username }}"] .feed-item-user-link {
                pointer-events: none !important;
                cursor: default !important;
            }

            .reaction-badge[data-reactors~="{{ app.user.username }}"] {
                background: rgba(0, 229, 255, 0.08) !important;
                border-color: var(--accent-cyan) !important;
                color: var(--accent-cyan) !important;
                box-shadow: 0 0 8px rgba(0, 229, 255, 0.15) !important;
            }

            .reaction-badge[data-reactors~="{{ app.user.username }}"]:hover {
                background: rgba(0, 229, 255, 0.12) !important;
                border-color: var(--accent-cyan) !important;
            }
        </style>
        {% endif %}

        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        {% endif %}
    </head>
    <body hx-ext="morph">
        {% block body %}{% endblock %}

        {% if app.user %}
            {% include '_global_search_modal.html.twig' %}
            {% include '_busy_status_modal.html.twig' %}
            {% include '_confirmation_dialogs.html.twig' %}
            <div id="modal-container" hx-target="this" hx-swap="innerHTML"></div>
            <div hx-post="{{ path('app_user_ping') }}"
                 hx-trigger="load delay:1s, every 60s"
                 hx-swap="none"
                 style="display:none"
                 id="heartbeat-ping"></div>
        {% endif %}
    </body>
</html>
