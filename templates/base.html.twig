<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="app-env" content="{{ app.environment }}">
        <meta name="htmx-config" content='{"historyCacheSize": 0, "globalViewTransitions": true}'>
        {% if app.user %}
            <meta name="csrf-token" content="{{ csrf_token('app') }}">
        {% endif %}
        <script>
            window.AppTranslations = {
                "Rechercher un émoji...": "{{ 'Rechercher un émoji...'|trans|escape('js') }}",
                "Aucun émoji ne correspond": "{{ 'Aucun émoji ne correspond'|trans|escape('js') }}",
                "Visages & Personnes": "{{ 'Visages & Personnes'|trans|escape('js') }}",
                "Animaux & Nature": "{{ 'Animaux & Nature'|trans|escape('js') }}",
                "Nourriture & Boissons": "{{ 'Nourriture & Boissons'|trans|escape('js') }}",
                "Activités & Loisirs": "{{ 'Activités & Loisirs'|trans|escape('js') }}",
                "Voyages & Lieux": "{{ 'Voyages & Lieux'|trans|escape('js') }}",
                "Objets & Outils": "{{ 'Objets & Outils'|trans|escape('js') }}",
                "Symboles": "{{ 'Symboles'|trans|escape('js') }}",
                "Drapeaux": "{{ 'Drapeaux'|trans|escape('js') }}",
                "Connecté au Hub": "{{ 'Connecté au Hub'|trans|escape('js') }}",
                "Connexion au Hub...": "{{ 'Connexion au Hub...'|trans|escape('js') }}",
                "Erreur: Hub non configuré": "{{ 'Erreur: Hub non configuré'|trans|escape('js') }}",
                "Connexion interrompue": "{{ 'Connexion interrompue'|trans|escape('js') }}",
                "Erreur de connexion": "{{ 'Erreur de connexion'|trans|escape('js') }}",
                "Connexion au serveur instable. Reconnexion en cours...": "{{ 'Connexion au serveur instable. Reconnexion en cours...'|trans|escape('js') }}",
                "Connexion au serveur perdue. Tentative de reconnexion...": "{{ 'Connexion au serveur perdue. Tentative de reconnexion...'|trans|escape('js') }}",
                "Activer les notifications": "{{ 'Activer les notifications'|trans|escape('js') }}",
                "Activer les notifications de bureau": "{{ 'Activer les notifications de bureau'|trans|escape('js') }}",
                "Notifications actives (cliquez pour désactiver)": "{{ 'Notifications actives (cliquez pour désactiver)'|trans|escape('js') }}",
                "Notifications désactivées (cliquez pour activer)": "{{ 'Notifications désactivées (cliquez pour activer)'|trans|escape('js') }}",
                "Notifications bloquées. Modifiez les autorisations de votre navigateur.": "{{ 'Notifications bloquées. Modifiez les autorisations de votre navigateur.'|trans|escape('js') }}",
                "Notifications activées ! 🚀": "{{ 'Notifications activées ! 🚀'|trans|escape('js') }}",
                "Vous recevrez désormais des alertes pour les nouveaux messages et invitations.": "{{ 'Vous recevrez désormais des alertes pour les nouveaux messages et invitations.'|trans|escape('js') }}",
                "Notifications réactivées ! 🔔": "{{ 'Notifications réactivées ! 🔔'|trans|escape('js') }}",
                "Les alertes de bureau sont à nouveau actives.": "{{ 'Les alertes de bureau sont à nouveau actives.'|trans|escape('js') }}",
                "Test de notification 🚀": "{{ 'Test de notification 🚀'|trans|escape('js') }}",
                "Ceci est une notification de test de Roquette.": "{{ 'Ceci est une notification de test de Roquette.'|trans|escape('js') }}",
                "Nouvelle invitation 🔒": "{{ 'Nouvelle invitation 🔒'|trans|escape('js') }}",
                "%sender% vous a invité à rejoindre le canal #%channelName%": "{{ '%sender% vous a invité à rejoindre le canal #%channelName%'|trans|escape('js') }}",
                "Mention dans %channelName%": "{{ 'Mention dans %channelName%'|trans|escape('js') }}",
                "Nouveau message 🚀": "{{ 'Nouveau message 🚀'|trans|escape('js') }}",
                "@%author% vous a mentionné : %content%": "{{ '@%author% vous a mentionné : %content%'|trans|escape('js') }}",
                "Nouveau message": "{{ 'Nouveau message'|trans|escape('js') }}",
                "En attente de connexion...": "{{ 'En attente de connexion...'|trans|escape('js') }}",
                "Envoi en cours...": "{{ 'Envoi en cours...'|trans|escape('js') }}",
                "Connexion perdue. Nouvel essai...": "{{ 'Connexion perdue. Nouvel essai...'|trans|escape('js') }}",
                "Votre session a expiré. Redirection vers la page de connexion dans 5 secondes...": "{{ 'Votre session a expiré. Redirection vers la page de connexion dans 5 secondes...'|trans|escape('js') }}",
                "Session expirée...": "{{ 'Session expirée...'|trans|escape('js') }}",
                "Reconnexion": "{{ 'Reconnexion'|trans|escape('js') }}",
                "Vérification...": "{{ 'Vérification...'|trans|escape('js') }}",
                "Le serveur ne répond pas. Veuillez réessayer dans quelques instants.": "{{ 'Le serveur ne répond pas. Veuillez réessayer dans quelques instants.'|trans|escape('js') }}",
                "Le fichier %fileName% dépasse la taille maximale de 10 MB.": "{{ 'Le fichier %fileName% dépasse la taille maximale de 10 MB.'|trans|escape('js') }}",
                "Terminer l'organisation": "{{ 'Terminer l\'organisation'|trans|escape('js') }}",
                "Ordonner les canaux": "{{ 'Ordonner les canaux'|trans|escape('js') }}",
                "Dernier message :": "{{ 'Dernier message :'|trans|escape('js') }}",
                "Hors ligne": "{{ 'Hors ligne'|trans|escape('js') }}",
                "En ligne": "{{ 'En ligne'|trans|escape('js') }}",
                "Ouvrir": "{{ 'Ouvrir'|trans|escape('js') }}",
                "Aperçu de l'image": "{{ 'Aperçu de l\'image'|trans|escape('js') }}",
                "Fermer l'aperçu": "{{ 'Fermer l\'aperçu'|trans|escape('js') }}",
                "Commandes disponibles": "{{ 'Commandes disponibles'|trans|escape('js') }}",
                "Aucun résultat": "{{ 'Aucun résultat'|trans|escape('js') }}",
                "Poser une question à l'Assistant Roquette": "{{ 'Poser une question à l\'Assistant Roquette'|trans|escape('js') }}",
                "Rechercher et envoyer un GIF animé": "{{ 'Rechercher et envoyer un GIF animé'|trans|escape('js') }}",
                "Envoyer le shrug ¯\\_(ツ)_/¯": "{{ 'Envoyer le shrug ¯\\_(ツ)_/¯'|trans|escape('js') }}",
                "Action": "{{ 'Action'|trans|escape('js') }}",
                "Changer la couleur de votre pseudo": "{{ 'Changer la couleur de votre pseudo'|trans|escape('js') }}",
                "Tous les canaux": "{{ 'Tous les canaux'|trans|escape('js') }}"
            };

            window.trans = function(key, placeholders = {}) {
                let translation = window.AppTranslations[key] || key;
                for (const [placeholder, value] of Object.entries(placeholders)) {
                    translation = translation.replace(placeholder, value);
                }
                return translation;
            };
        </script>
        <script>
            (function() {
                const theme = {% if app.user %}'{{ app.user.theme|escape('js') }}'{% else %}localStorage.getItem('theme') || 'dark'{% endif %};
                document.documentElement.setAttribute('data-theme', theme);
                localStorage.setItem('theme', theme);

                const hljsLink = document.createElement('link');
                hljsLink.id = 'hljs-theme';
                hljsLink.rel = 'stylesheet';
                hljsLink.href = theme === 'dark'
                    ? '{{ asset('styles/highlight/atom-one-dark.min.css') }}'
                    : '{{ asset('styles/highlight/atom-one-light.min.css') }}';
                document.head.appendChild(hljsLink);
            })();
        </script>
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" type="image/svg+xml" href="{{ asset('favicon.svg') }}?v=2">
        <link rel="manifest" href="{{ asset('manifest.webmanifest') }}">
        <meta name="theme-color" content="#00e5ff">
        <meta name="apple-mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
        <link rel="apple-touch-icon" href="{{ asset('icons/apple-touch-icon.png') }}">



        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        {% endif %}
    </head>
    <body hx-ext="morph,sse" {% if app.user %}{% set userTopics = get_user_mercure_topics(app.user) %}sse-connect="{{ mercure(userTopics, { subscribe: userTopics }) }}"{% endif %}>
        {% block body %}{% endblock %}

        {% if app.user %}
            {% include 'modals/_global_search_modal.html.twig' %}
            {% include 'modals/_busy_status_modal.html.twig' %}
            {% include 'partials/_confirmation_dialogs.html.twig' %}
            <div id="modal-container" hx-target="this" hx-swap="innerHTML"></div>
            <div hx-post="{{ path('app_user_ping') }}"
                 hx-trigger="load delay:1s, every 60s"
                 hx-swap="none"
                 style="display:none"
                 id="heartbeat-ping"></div>
        {% endif %}
    </body>
</html>
