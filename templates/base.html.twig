<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="htmx-config" content='{"historyCacheSize": 0, "globalViewTransitions": true}'>
        <script>
            (function() {
                const theme = {% if app.user %}'{{ app.user.theme }}'{% else %}localStorage.getItem('theme') || 'dark'{% endif %};
                document.documentElement.setAttribute('data-theme', theme);
                localStorage.setItem('theme', theme);

                const hljsLink = document.createElement('link');
                hljsLink.id = 'hljs-theme';
                hljsLink.rel = 'stylesheet';
                hljsLink.href = theme === 'dark' 
                    ? '{{ asset('styles/highlight/atom-one-dark.min.css') }}' 
                    : '{{ asset('styles/highlight/atom-one-light.min.css') }}';
                document.head.appendChild(hljsLink);
            })();
        </script>
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" type="image/svg+xml" href="{{ asset('favicon.svg') }}">
        
        {% if app.user %}
        <style>
            :root {
                --user-hue-primary: {{ app.user.hue }};
                /* Override default accents with user custom hue settings */
                --accent-cyan: hsl(var(--user-hue-primary), 100%, 45%);
                --accent-cyan-glow: hsla(var(--user-hue-primary), 100%, 50%, 0.15);
                --accent-purple: hsl(calc((var(--user-hue-primary) + 84) % 360), 91%, 65%);
                --accent-purple-glow: hsla(calc((var(--user-hue-primary) + 84) % 360), 91%, 65%, 0.15);
            }
            [data-theme="light"] {
                --accent-cyan: hsl(var(--user-hue-primary), 100%, 30%);
                --accent-cyan-glow: hsla(var(--user-hue-primary), 100%, 30%, 0.15);
                --accent-purple: hsl(calc((var(--user-hue-primary) + 84) % 360), 75%, 45%);
                --accent-purple-glow: hsla(calc((var(--user-hue-primary) + 84) % 360), 75%, 45%, 0.15);
            }
        </style>
        {% endif %}

        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        {% endif %}
    </head>
    <body>
        {% block body %}{% endblock %}

        {% if app.user %}
            {% include '_create_channel_modal.html.twig' %}
            {% include '_lightbox_modal.html.twig' %}
            {% include '_global_search_modal.html.twig' %}
            {% if activeChannel is defined and activeChannel and not activeChannel.isDm and activeChannel.creator == app.user %}
                {% include '_edit_channel_modal.html.twig' %}
            {% endif %}
            {% if activeChannel is defined and activeChannel and activeChannel.isPrivate and activeChannel.creator == app.user %}
                {% include '_invite_member_modal.html.twig' %}
            {% endif %}
            {% if activeChannel is defined and activeChannel %}
                {% include '_channel_members_modal.html.twig' %}
            {% endif %}

            <script>
                (function() {
                    if (!window.themeToggleInitialized) {
                        window.themeToggleInitialized = true;
                        document.addEventListener('click', function(e) {
                            const toggle = e.target.closest('#theme-toggle');
                            if (toggle) {
                                const currentTheme = document.documentElement.getAttribute('data-theme') || 'dark';
                                const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
                                document.documentElement.setAttribute('data-theme', newTheme);
                                localStorage.setItem('theme', newTheme);

                                const hljsLink = document.getElementById('hljs-theme');
                                if (hljsLink) {
                                    hljsLink.href = newTheme === 'dark' 
                                        ? '{{ asset('styles/highlight/atom-one-dark.min.css') }}' 
                                        : '{{ asset('styles/highlight/atom-one-light.min.css') }}';
                                }

                                // Update database state asynchronously
                                fetch('{{ path('app_user_update_theme') }}', {
                                    method: 'POST',
                                    headers: {
                                        'Content-Type': 'application/x-www-form-urlencoded',
                                    },
                                    body: 'theme=' + encodeURIComponent(newTheme)
                                }).catch(err => console.error('Failed to sync theme preference:', err));
                            }
                        });
                    }
                })();
            </script>
        {% endif %}
    </body>
</html>
