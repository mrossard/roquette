{% extends 'base.html.twig' %}

{% block title %}{{ 'Inscription - Roquette'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        .auth-wrapper {
            display: flex;
            justify-content: center;
            align-items: center;
            flex-grow: 1;
            padding: 2rem 1.5rem;
        }
        .auth-card {
            max-width: 420px;
            width: 100%;
        }
        .auth-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        .auth-logo {
            font-size: 3rem;
            margin-bottom: 0.5rem;
            display: inline-block;
            animation: float 4s ease-in-out infinite;
        }
        .auth-header h1 {
            font-size: 1.85rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            background: linear-gradient(135deg, var(--text-primary) 30%, var(--accent-cyan));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .auth-header p {
            color: var(--text-muted);
            font-size: 0.9rem;
        }
        .error-alert {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            color: var(--accent-red);
            border-radius: 0.75rem;
            padding: 0.85rem;
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
            animation: shake 0.5s ease;
        }
        .auth-footer {
            margin-top: 1.5rem;
            text-align: center;
            font-size: 0.9rem;
            color: var(--text-muted);
        }
        .auth-footer a {
            color: var(--accent-cyan);
            text-decoration: none;
            font-weight: 500;
            transition: var(--transition-smooth);
        }
        .auth-footer a:hover {
            color: var(--accent-purple);
            text-shadow: 0 0 8px var(--accent-purple-glow);
        }
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-6px); }
            75% { transform: translateX(6px); }
        }
    </style>
{% endblock %}

{% block body %}
<div class="auth-wrapper">
    <div class="card glass-panel auth-card fade-in">
        <div class="auth-header">
            <span class="auth-logo">🚀</span>
            <h1>{{ 'Inscription'|trans }}</h1>
            <p>{{ 'Créez un compte pour rejoindre la diffusion live'|trans }}</p>
        </div>

        {# Show flash error messages (ex. rate limit error) #}
        {% for label, messages in app.flashes('error') %}
            {% for msg in messages %}
                <div class="error-alert">
                    {{ msg|trans }}
                </div>
            {% endfor %}
        {% endfor %}

        {# Show validation/form errors #}
        {% if not registrationForm.vars.valid %}
            <div class="error-alert">
                {% for error in registrationForm.vars.errors %}
                    {{ error.message|trans }}<br>
                {% endfor %}
                {% for child in registrationForm.children %}
                    {% for error in child.vars.errors %}
                        {{ error.message|trans }}<br>
                    {% endfor %}
                {% endfor %}
            </div>
        {% endif %}

        {{ form_start(registrationForm, {'action': path('app_register'), 'method': 'post', 'attr': {'class': 'input-form'}}) }}
            <div class="input-group">
                {{ form_label(registrationForm.username, "Nom d'utilisateur"|trans) }}
                {{ form_widget(registrationForm.username, {
                    'attr': {
                        'autocomplete': 'username',
                        'autofocus': 'autofocus',
                        'placeholder': 'Ex: Jean Dupont'|trans
                    }
                }) }}
            </div>

            <div class="input-group">
                {{ form_label(registrationForm.plainPassword, "Mot de passe"|trans) }}
                {{ form_widget(registrationForm.plainPassword, {
                    'attr': {
                        'autocomplete': 'new-password',
                        'placeholder': 'Min. 6 caractères'|trans
                    }
                }) }}
            </div>

            <div class="form-actions" style="margin-top: 0.5rem;">
                <button type="submit" class="btn-publish">
                    <span>{{ 'Créer le compte'|trans }}</span>
                </button>
            </div>
            {{ form_rest(registrationForm) }}
        {{ form_end(registrationForm) }}

        <div class="auth-footer">
            {{ "Vous avez déjà un compte ?"|trans }} <a href="{{ path('app_login') }}">{{ "Se connecter"|trans }}</a>
        </div>

        <div class="language-switcher"
             style="text-align: center; margin-top: 1.5rem; font-size: 0.85rem; display: flex; justify-content: center; gap: 0.75rem;">
            <a href="?_locale=fr"
               style="color: var(--text-muted); text-decoration: none; font-weight: {% if app.request.locale == 'fr' %}600{% else %}400{% endif %};">Français</a>
            <span style="color: var(--border-glass);">|</span>
            <a href="?_locale=en"
               style="color: var(--text-muted); text-decoration: none; font-weight: {% if app.request.locale == 'en' %}600{% else %}400{% endif %};">English</a>
        </div>
    </div>
</div>
{% endblock %}
