<form hx-post="{{ path('app_message_thread_reply', {id: parentMessage.id}) }}"
      hx-swap="morph transition:false"
      enctype="multipart/form-data"
      class="input-form chat-message-form thread-message-form">
    {% for label, messages in app.flashes %}
        {% for msg in messages %}
            <div class="alert-{{ label == 'error' ? 'error' : 'success' }} fade-in" style="margin-bottom: 0.75rem; background: rgba({{ label == 'error' ? '239, 68, 68' : '16, 185, 129' }}, 0.1); border: 1px solid rgba({{ label == 'error' ? '239, 68, 68' : '16, 185, 129' }}, 0.2); color: var(--accent-{{ label == 'error' ? 'red' : 'green' }}); border-radius: 0.75rem; padding: 0.75rem 1rem; font-size: 0.9rem; font-weight: 500;">
                {{ msg }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="formatting-toolbar">
        <button type="button" class="btn-format" data-markdown="bold" title="Gras (**)">
            <span class="icon">B</span>
        </button>
        <button type="button" class="btn-format" data-markdown="italic" title="Italique (*)">
            <span class="icon">I</span>
        </button>
        <button type="button" class="btn-format" data-markdown="strikethrough" title="Barré (~~)">
            <span class="icon">S</span>
        </button>
        <button type="button" class="btn-format" data-markdown="quote" title="Citation (&gt;)">
            <span class="icon">”</span>
        </button>
        <button type="button" class="btn-format" data-markdown="code" title="Code en ligne (`)">
            <span class="icon">&lt;/&gt;</span>
        </button>
        <button type="button" class="btn-format" data-markdown="codeblock" title="Bloc de code (```)">
            <span class="icon">code</span>
        </button>
        <button type="button" class="btn-format" data-markdown="link" title="Lien [texte](url)">
            <span class="icon">🔗</span>
        </button>

        <div class="toolbar-tabs" style="margin-left: auto; display: flex; gap: 4px;">
            <button type="button" class="btn-format active" id="thread-message-btn-edit-tab"
                    hx-on:click="this.closest('.chat-message-form').classList.remove('show-preview')"
                    title="Écrire">Écrire
            </button>
            <button type="button" class="btn-format" id="thread-message-btn-preview-tab"
                    hx-post="{{ path('app_api_message_preview') }}"
                    hx-include="#thread-message"
                    hx-target="#thread-message-preview"
                    hx-swap="innerHTML transition:false"
                    hx-on:click="this.closest('.chat-message-form').classList.add('show-preview')"
                    title="Aperçu">Aperçu</button>
        </div>
    </div>

    <div class="chat-input-container">
        <div id="thread-file-preview-container" class="file-preview-container" style="display: none; flex-direction: column; align-items: stretch; gap: 0.5rem;">
            <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
                <div class="file-preview-info">
                    <span class="file-preview-icon">📎</span>
                    <span id="thread-file-preview-name" class="file-preview-name"></span>
                </div>
                <button type="button" id="thread-btn-clear-file" class="btn-clear-file" title="Supprimer le fichier">✕</button>
            </div>
            <div id="thread-file-upload-progress" class="upload-progress-wrapper" style="display: none; width: 100%;">
                <div class="upload-progress-bar-bg" style="background: rgba(255, 255, 255, 0.1); border-radius: 4px; height: 6px; overflow: hidden; width: 100%;">
                    <div id="thread-file-upload-progress-bar" class="upload-progress-bar" style="background: var(--accent-cyan); height: 100%; width: 0%; transition: width 0.15s ease;"></div>
                </div>
                <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem;">
                    <span>Envoi en cours...</span>
                    <span id="thread-file-upload-progress-percent" class="upload-progress-percent">0%</span>
                </div>
            </div>
        </div>

        <label for="thread-message" class="sr-only">Répondre...</label>
        <div class="message-input-wrapper">
            <input type="file" id="thread-file-upload" name="file" style="display: none;" />
            <textarea id="thread-message" name="message" required
                      oninput="this.style.height = 'auto'; this.style.height = this.scrollHeight + 'px';"
                      placeholder="Répondre au fil..." rows="1"></textarea>
            <div id="thread-message-preview" class="message-preview-box" style="display: none;"></div>


            <div class="input-actions-wrapper">
                <button type="button" class="btn-file-toggle" data-file-input="thread-file-upload"
                        title="Joindre un fichier" aria-label="Joindre un fichier">
                    {{ ux_icon('heroicons:paper-clip', {class: 'btn-icon', 'aria-hidden': 'true'}) }}
                </button>
                <button type="button" class="btn-emoji-toggle" data-emoji-target="#thread-message" title="Ajouter un émoji" aria-label="Ajouter un émoji">
                    {{ ux_icon('heroicons:face-smile', {'aria-hidden': 'true'}) }}
                </button>
            </div>
        </div>
        <button type="submit" class="btn-publish-compact" title="Répondre" aria-label="Répondre au message">
            {{ ux_icon('heroicons:paper-airplane', {class: 'btn-icon', 'aria-hidden': 'true'}) }}
        </button>
    </div>
</form>
