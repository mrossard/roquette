{% set user_hue = message.author ? message.author.hue : 200 %}
{% set username = message.author ? (message.author.displayName|default(message.author.username)) : 'Utilisateur' %}
<div class="feed-item fade-in editing" style="--user-hue: {{ user_hue }};" data-message-id="{{ message.id }}" data-author-username="{{ message.author ? message.author.username : '' }}">
    <div class="feed-item-header">
        <div class="feed-item-user-container">
            <span class="feed-item-avatar">{{ username|slice(0, 1)|upper }}</span>
            <span class="feed-item-user">{{ username }}</span>
        </div>
        <span class="feed-item-time">{{ message.createdAt|date('H:i:s') }}</span>
        {% if message.updatedAt %}
            <span class="feed-item-edited-indicator" title="Modifié le {{ message.updatedAt|date('d/m/Y H:i:s') }}">(modifié)</span>
        {% endif %}
    </div>
    <div class="feed-item-body" style="padding-left: 2.2rem; width: 100%;">
        <form hx-post="{{ path('app_message_edit', {id: message.id}) }}" hx-target="closest .feed-item" hx-swap="outerHTML" class="edit-message-form" style="width: 100%; display: flex; flex-direction: column; gap: 0.5rem; margin-top: 0.25rem;">
            <div class="message-input-wrapper">
                <textarea name="content" class="edit-message-textarea" required aria-label="Modifier le message" style="width: 100%; min-height: 80px; padding: 0.6rem; padding-right: 2.5rem; border-radius: 0.5rem; background: rgba(0, 0, 0, 0.4); border: 1px solid var(--border-glass); color: var(--text-primary); font-family: inherit; font-size: 0.925rem; resize: vertical; outline: none; transition: var(--transition-smooth);" onkeydown="if(event.key === 'Enter' && !event.shiftKey) { event.preventDefault(); this.form.requestSubmit(); } else if(event.key === 'Escape') { this.form.querySelector('.btn-cancel').click(); }">{{ message.content }}</textarea>
                <button type="button" class="btn-emoji-toggle" data-emoji-target="textarea" title="Ajouter un émoji" aria-label="Ajouter un émoji">
                    {{ ux_icon('heroicons:face-smile', {'aria-hidden': 'true'}) }}
                </button>
            </div>
            <div class="edit-message-actions" style="display: flex; gap: 0.5rem; align-self: flex-start;">
                <button type="submit" class="btn-publish" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; border-radius: 0.4rem; height: auto;">
                    {{ ux_icon('heroicons:check', {class: 'action-icon', style: 'width: 12px; height: 12px; margin-right: 0.25rem;'}) }}
                    <span>Enregistrer</span>
                </button>
                <button type="button" class="btn-reply-subtle btn-cancel" hx-get="{{ path('app_message_view', {id: message.id}) }}" hx-target="closest .feed-item" hx-swap="outerHTML" style="opacity: 1; padding: 0.4rem 0.8rem; border: 1px solid var(--border-glass); font-size: 0.8rem; border-radius: 0.4rem; display: inline-flex; align-items: center; justify-content: center; margin-left: 0;">
                    {{ ux_icon('heroicons:x-mark', {class: 'action-icon', style: 'width: 12px; height: 12px; margin-right: 0.25rem;'}) }}
                    <span>Annuler</span>
                </button>
            </div>
        </form>
    </div>
</div>
