{% set user_hue = message.author ? message.author.hue : 200 %}
{% set username = message.author ? (message.author.displayName|default(message.author.username)) : 'Utilisateur' %}
<div class="feed-item editing" style="--user-hue: {{ user_hue }};" data-message-id="{{ message.id }}" data-author-username="{{ message.author ? message.author.username : '' }}">
    <div class="feed-item-header">
        <div class="feed-item-user-container">
            <span class="feed-item-avatar">{{ username|slice(0, 1)|upper }}</span>
            <span class="feed-item-user">{{ username }}</span>
        </div>
        <span
            class="feed-item-time">{% if message.createdAt|date('Y-m-d') != 'now'|date('Y-m-d') %}{{ message.createdAt|date('d/m/Y') }} {% endif %}{{ message.createdAt|date('H:i:s') }}</span>
        {% if message.updatedAt %}
            <span class="feed-item-edited-indicator" title="Modifié le {{ message.updatedAt|date('d/m/Y H:i:s') }}">(modifié)</span>
        {% endif %}
    </div>
    <div class="feed-item-body" style="padding-left: 2.2rem; width: 100%;">
        <form hx-post="{{ path('app_message_edit', {id: message.id}) }}" hx-target="closest .feed-item" hx-swap="morph transition:false" class="edit-message-form" style="width: 100%; display: flex; flex-direction: column; gap: 0.75rem; margin-top: 0.25rem;">
            {% if message.poll %}
                <!-- Poll Edit Form -->
                <div>
                    <label for="edit_poll_question_{{ message.id }}" style="display: block; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.25rem;">Question</label>
                    <input type="text" id="edit_poll_question_{{ message.id }}" name="poll_question"
                           value="{{ message.poll.question }}" required autofocus class="input-sidebar"/>
                </div>

                <div style="display: flex; align-items: center; justify-content: space-between; gap: 1rem; background: rgba(0, 0, 0, 0.2); padding: 0.5rem 0.75rem; border-radius: 0.5rem; border: 1px solid var(--border-glass);">
                    <label for="edit_allow_multiple_{{ message.id }}" style="font-size: 0.85rem; color: var(--text-color); cursor: pointer; user-select: none; margin-bottom: 0; font-weight: 500;">Autoriser plusieurs réponses</label>
                    <label class="switch" style="position: relative; display: inline-block; width: 44px; height: 24px; flex-shrink: 0; margin-bottom: 0;">
                        <input type="checkbox" id="edit_allow_multiple_{{ message.id }}" name="allow_multiple" value="1"
                               style="opacity: 0; width: 0; height: 0;"
                               {% if message.poll.allowMultiple %}checked{% endif %}>
                        <span class="slider round"
                              style="position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(255, 255, 255, 0.1); transition: .3s; border-radius: 24px; border: 1px solid var(--border-glass);"></span>
                    </label>
                </div>

                <div>
                    <label style="display: block; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.25rem;">Options de réponse</label>
                    <div id="edit-poll-options-container-{{ message.id }}" class="poll-options-list"
                         style="display: flex; flex-direction: column; gap: 0.5rem;">
                        {% for option in message.poll.options %}
                            <div style="display: flex; gap: 0.5rem; align-items: center;">
                                <input type="text" name="poll_options[]" value="{{ option.text }}"
                                       placeholder="Option {{ loop.index }}" required
                                       class="edit-poll-option-input input-sidebar" style="flex: 1;"/>
                                {% if loop.index > 2 %}
                                    <button type="button"
                                            onclick="window.removePollOption(this)"
                                            style="width: 24px; height: 24px; border-radius: 50%; border: none; background: rgba(239, 68, 68, 0.2); color: var(--accent-red, #ff5b5b); cursor: pointer; display: flex; align-items: center; justify-content: center;">
                                        ✕
                                    </button>
                                {% else %}
                                    <span style="width: 24px;"></span>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                    <button type="button" class="btn-format"
                            hx-post="{{ path('app_poll_option_field') }}"
                            hx-vals="js:{count: getPollOptionCount('edit-poll-options-container-{{ message.id }}'), inputClass: 'edit-poll-option-input', isRequired: 1}"
                            hx-target="#edit-poll-options-container-{{ message.id }}"
                            hx-swap="beforeend"
                            style="margin-top: 0.5rem; font-size: 0.8rem; padding: 0.25rem 0.5rem; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 0.35rem; color: var(--text-color); cursor: pointer; display: flex; align-items: center; gap: 0.25rem;">
                        <span>+</span> Ajouter une option
                    </button>
                </div>
            {% else %}
                <!-- Standard Message Edit Form -->
                <div class="message-input-wrapper">
                    <textarea name="content" class="edit-message-textarea" required autofocus
                              aria-label="Modifier le message"
                              style="width: 100%; min-height: 80px; padding: 0.6rem; padding-right: 2.5rem; border-radius: 0.5rem; background: rgba(0, 0, 0, 0.4); border: 1px solid var(--border-glass); color: var(--text-primary); font-family: inherit; font-size: 0.925rem; resize: vertical; outline: none; transition: var(--transition-smooth);"
                              onkeydown="if(event.key === 'Enter' && !event.shiftKey && !event.altKey) { event.preventDefault(); this.form.requestSubmit(); } else if(event.key === 'Escape') { this.form.querySelector('.btn-cancel').click(); }">{{ message.content }}</textarea>
                    <button type="button" class="btn-emoji-toggle" data-emoji-target="textarea" title="Ajouter un émoji" aria-label="Ajouter un émoji">
                        {{ ux_icon('heroicons:face-smile', {'aria-hidden': 'true'}) }}
                    </button>
                </div>
            {% endif %}

            <div class="edit-message-actions" style="display: flex; gap: 0.5rem; align-self: flex-start;">
                <button type="submit" class="btn-publish" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; border-radius: 0.4rem; height: auto;">
                    {{ ux_icon('heroicons:check', {class: 'action-icon', style: 'width: 12px; height: 12px; margin-right: 0.25rem;'}) }}
                    <span>Enregistrer</span>
                </button>
                <button type="button" class="btn-reply-subtle btn-cancel" hx-get="{{ path('app_message_view', {id: message.id}) }}" hx-target="closest .feed-item" hx-swap="morph transition:false" style="opacity: 1; padding: 0.4rem 0.8rem; border: 1px solid var(--border-glass); font-size: 0.8rem; border-radius: 0.4rem; display: inline-flex; align-items: center; justify-content: center; margin-left: 0;">
                    {{ ux_icon('heroicons:x-mark', {class: 'action-icon', style: 'width: 12px; height: 12px; margin-right: 0.25rem;'}) }}
                    <span>Annuler</span>
                </button>
            </div>
        </form>
    </div>
</div>
