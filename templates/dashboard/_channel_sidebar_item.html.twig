{% set unread = unreadCounts[channel.id]|default(null) %}
{% set count = unread ? unread.count : 0 %}
{% set hasMention = unread ? unread.hasMention : false %}
{% set partner = channel.isDm ? channel.getDmPartner(app.user) : null %}
{% set channelName = partner ? partner.displayName|default(partner.username) : channel.name %}
{% set isRobotDm = channel.slug starts with 'dm-robot-roquette-' %}
<a href="{{ path('app_channel', {slug: channel.slug}) }}"
   id="sidebar-channel-{{ channel.slug }}"
   class="channel-link {% if activeChannel and channel.id == activeChannel.id %}active{% endif %} {% if count > 0 and (not activeChannel or channel.id != activeChannel.id) %}unread{% endif %} {% if hasMention and (not activeChannel or channel.id != activeChannel.id) %}has-mention{% endif %} {% if isRobotDm %}assistant-dm{% endif %}"
   data-channel-slug="{{ channel.slug }}"
   data-channel-id="{{ channel.id }}"
   draggable="false"
   title="{{ channelName }}">
    <span class="drag-handle" style="display: none; font-size: 0.85rem; margin-right: 0.2rem; opacity: 0.5;">☰</span>
    {% if channel.isDm %}
        {% if partner %}
            {% if isRobotDm %}
                <span class="robot-icon"
                      style="margin-right: 0.5rem; flex-shrink: 0; align-self: center; font-size: 1.1rem; line-height: 1;">🤖</span>
            {% else %}
                <span class="status-dot {{ partner.status }}" data-username="{{ partner.username }}"
                      data-status-override="{{ partner.statusOverride|default('auto') }}"
                      data-last-active="{{ partner.lastActiveAt ? partner.lastActiveAt.timestamp : '' }}"
                      style="display: inline-block; margin-right: 0.5rem; flex-shrink: 0; align-self: center;"
                      title="{{ partner.statusLabel }}"></span>
            {% endif %}
            <span class="channel-name"
                  style="{% if not isRobotDm %}color: hsl({{ partner.hue }}, 90%, var(--user-hue-lightness-hover));{% endif %}">{{ channelName }}</span>
        {% else %}
            <span class="channel-hash" style="color: var(--accent-purple); opacity: 1;">👤</span>
            <span class="channel-name">{{ channel.name }}</span>
        {% endif %}
    {% else %}
        {% if channel.isPrivate %}
            <span class="channel-hash" style="color: var(--accent-purple); opacity: 1;">🔒</span>
        {% else %}
            <span class="channel-hash" style="color: var(--accent-cyan); opacity: 1;">#</span>
        {% endif %}
        <span class="channel-name">{{ channel.name }}</span>
    {% endif %}
    {% set lastMessage = channel.lastMessage %}
    {% if lastMessage %}
        {% set lastMessageDate = lastMessage.createdAt %}
        {% set isToday = lastMessageDate|date('Y-m-d') == 'now'|date('Y-m-d') %}
        <span class="channel-last-message-date"
              title="{{ 'Dernier message :'|trans }} {{ lastMessageDate|date('d/m/Y H:i') }}">
            {{ isToday ? lastMessageDate|date('H:i') : lastMessageDate|date('d/m') }}
        </span>
    {% endif %}
    <button class="sidebar-favorite-toggle {% if app.user.isChannelFavorite(channel) %}is-favorite{% endif %}"
            hx-post="{{ path('app_channel_favorite_toggle', {slug: channel.slug}) }}"
            hx-swap="none"
            onclick="event.stopPropagation(); event.preventDefault();"
            title="{% if app.user.isChannelFavorite(channel) %}{{ 'Retirer des favoris'|trans }}{% else %}{{ 'Ajouter aux favoris'|trans }}{% endif %}">
        ★
    </button>
    <span class="unread-badge" {% if count == 0 or (activeChannel and channel.id == activeChannel.id) %}style="display: none;"{% endif %}>{{ count }}</span>
</a>
