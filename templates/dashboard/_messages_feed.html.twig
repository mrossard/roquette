{% if unreadFilterActive is defined and unreadFilterActive %}
    <div class="search-results-banner unread-filter-banner">
        <span class="search-banner-text">🔔 Affichage des <strong>messages non lus</strong> (et fils)</span>
        <button class="btn-clear-search btn-clear-unread" onclick="clearUnreadFilter()" title="Revenir à tous les messages">Retour au direct</button>
    </div>

    {% set lastDate = null %}
    {% for message in messages %}
        {% set currentDate = message.createdAt|date('Y-m-d') %}
        {% if lastDate is null or currentDate != lastDate %}
            <div class="day-separator">
                <span class="day-separator-line"></span>
                <span class="day-separator-label">
                    {% if currentDate == 'now'|date('Y-m-d') %}
                        Aujourd'hui
                    {% elseif currentDate == 'yesterday'|date('Y-m-d') %}
                        Hier
                    {% else %}
                        {{ message.createdAt|date('d/m/Y') }}
                    {% endif %}
                </span>
                <span class="day-separator-line"></span>
            </div>
            {% set lastDate = currentDate %}
        {% endif %}
        {% include 'dashboard/_feed_item.html.twig' with {
            'author': message.author,
            'message': message.content,
            'timestamp': message.createdAt,
            'message_id': message.id,
            'updated_at': message.updatedAt,
            'fileName': message.fileName,
            'fileSize': message.fileSize,
            'filePath': message.filePath,
            'mimeType': message.mimeType,
            'messageObject': message
        } %}
    {% else %}
        <div id="feed-empty-state" class="empty-state">
            <div class="empty-icon">✅</div>
            <h3>Tout est à jour !</h3>
            <p>Aucun message non lu dans ce canal.</p>
            <button class="btn-clear-search" onclick="clearUnreadFilter()" style="margin-top: 1rem;">Retour au direct</button>
        </div>
    {% endfor %}
{% elseif searchQuery is defined and searchQuery is not empty %}
    <div class="search-results-banner">
        <span class="search-banner-text">🔍 <strong>{{ messages|length }}</strong> résultat(s) pour "<strong>{{ searchQuery }}</strong>"</span>
        <button class="btn-clear-search" onclick="clearChannelSearch()" title="Quitter la recherche">Retour au direct</button>
    </div>

    {% set lastDate = null %}
    {% for message in messages %}
        {% set currentDate = message.createdAt|date('Y-m-d') %}
        {% if lastDate is null or currentDate != lastDate %}
            <div class="day-separator">
                <span class="day-separator-line"></span>
                <span class="day-separator-label">
                    {% if currentDate == 'now'|date('Y-m-d') %}
                        Aujourd'hui
                    {% elseif currentDate == 'yesterday'|date('Y-m-d') %}
                        Hier
                    {% else %}
                        {{ message.createdAt|date('d/m/Y') }}
                    {% endif %}
                </span>
                <span class="day-separator-line"></span>
            </div>
            {% set lastDate = currentDate %}
        {% endif %}
        {% include 'dashboard/_feed_item.html.twig' with {
            'author': message.author,
            'message': message.content,
            'timestamp': message.createdAt,
            'message_id': message.id,
            'updated_at': message.updatedAt,
            'fileName': message.fileName,
            'fileSize': message.fileSize,
            'filePath': message.filePath,
            'mimeType': message.mimeType,
            'messageObject': message
        } %}
    {% else %}
        <div id="feed-empty-state" class="empty-state">
            <div class="empty-icon">🔍</div>
            <h3>Aucun résultat</h3>
            <p>Aucun message contenant "<strong>{{ searchQuery }}</strong>" n'a été trouvé dans ce canal.</p>
        </div>
    {% endfor %}
{% else %}
    {% if messages|length >= 50 %}
        {% include 'dashboard/_load_more_trigger.html.twig' with {
            'channel': activeChannel,
            'beforeId': messages[0].id
        } %}
    {% endif %}
    {% set separatorShown = false %}
    {% set lastDate = null %}
    {% for message in messages %}
        {% set currentDate = message.createdAt|date('Y-m-d') %}
        {% if lastDate is null or currentDate != lastDate %}
            <div class="day-separator">
                <span class="day-separator-line"></span>
                <span class="day-separator-label">
                    {% if currentDate == 'now'|date('Y-m-d') %}
                        Aujourd'hui
                    {% elseif currentDate == 'yesterday'|date('Y-m-d') %}
                        Hier
                    {% else %}
                        {{ message.createdAt|date('d/m/Y') }}
                    {% endif %}
                </span>
                <span class="day-separator-line"></span>
            </div>
            {% set lastDate = currentDate %}
        {% endif %}
        {% if firstUnreadMessageId|default(null) and message.id >= firstUnreadMessageId and not separatorShown and message.author.id != app.user.id %}
            <div class="unread-separator">
                <span class="unread-separator-line"></span>
                <span class="unread-separator-label">Nouveaux messages</span>
                <span class="unread-separator-line"></span>
            </div>
            {% set separatorShown = true %}
        {% endif %}
        {% include 'dashboard/_feed_item.html.twig' with {
            'author': message.author,
            'message': message.content,
            'timestamp': message.createdAt,
            'message_id': message.id,
            'updated_at': message.updatedAt,
            'fileName': message.fileName,
            'fileSize': message.fileSize,
            'filePath': message.filePath,
            'mimeType': message.mimeType,
            'messageObject': message
        } %}
    {% else %}
        <div id="feed-empty-state" class="empty-state">
            <div class="empty-icon">📡</div>
            <h3>Aucun message reçu</h3>
            <p>Les nouveaux messages apparaîtront ici dès qu'ils seront publiés.</p>
        </div>
    {% endfor %}
{% endif %}
