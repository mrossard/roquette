<aside class="card glass-panel subchannels-sidebar-panel" id="subchannels-sidebar-panel">
    <div class="subchannels-sidebar-header">
        <h3>🌿 {{ 'Sous-canaux'|trans }}</h3>
        <button type="button" class="subchannels-sidebar-close" onclick="toggleSubChannelsSidebar()"
                title="{{ 'Fermer'|trans }}">✕
        </button>
    </div>
    <div class="subchannels-sidebar-list">
        {% if activeSubChannels is not empty %}
            {% for sub in activeSubChannels %}
                {% set subUnread = unreadCounts[sub.id]|default(null) %}
                {% set subCount = subUnread ? subUnread.count : 0 %}
                <a href="{{ path('app_channel', {slug: sub.slug}) }}" class="subchannels-sidebar-item">
                    <div class="subchannels-sidebar-item-header">
                        <span class="subchannels-sidebar-item-name">⊞ {{ sub.name }}</span>
                        {% if sub.creator == app.user %}
                            <button class="subchannel-settings-btn"
                                    hx-get="{{ path('app_channel_edit_modal', {slug: sub.slug}) }}"
                                    hx-target="#modal-container"
                                    onclick="event.stopPropagation();"
                                    title="{{ 'Paramètres'|trans }}">⚙️
                            </button>
                        {% endif %}
                        {% if subCount > 0 %}
                            <span class="unread-badge"
                                  style="position: static; margin-left: auto;">{{ subCount }}</span>
                        {% endif %}
                    </div>
                    <span class="subchannels-sidebar-item-desc">
                                    {{ sub.description|default('Aucune description.'|trans) }}
                                </span>
                </a>
            {% endfor %}
        {% else %}
            <p style="font-size: 0.85rem; color: var(--text-muted); font-style: italic; text-align: center; margin-top: 2rem;">
                {{ 'Aucun sous-canal existant.'|trans }}
            </p>
        {% endif %}
    </div>
</aside>
