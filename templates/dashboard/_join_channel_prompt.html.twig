<div class="card-body chat-body" style="align-items: center; justify-content: center; text-align: center; padding: 4rem 2rem;">
    {% for label, messages in app.flashes %}
        {% for msg in messages %}
            <div class="alert-{{ label == 'error' ? 'error' : 'success' }} fade-in" style="margin-bottom: 1rem; background: rgba({{ label == 'error' ? '239, 68, 68' : '16, 185, 129' }}, 0.1); border: 1px solid rgba({{ label == 'error' ? '239, 68, 68' : '16, 185, 129' }}, 0.2); color: var(--accent-{{ label == 'error' ? 'red' : 'green' }}); border-radius: 0.75rem; padding: 0.75rem 1rem; font-size: 0.9rem; font-weight: 500; width: 100%; max-width: 400px; text-align: left;">
                {{ msg }}
            </div>
        {% endfor %}
    {% endfor %}
    <div style="max-width: 400px; display: flex; flex-direction: column; align-items: center; gap: 1.5rem;" class="fade-in">
        <div class="empty-icon" style="font-size: 4rem; opacity: 0.8; animation: float 4s ease-in-out infinite;">📢</div>
        <div>
            <h3 style="font-size: 1.5rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.75rem;">Rejoindre #{{ activeChannel.name }}</h3>
            <p style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.5;">
                Vous n'avez pas encore rejoint ce canal public. Rejoignez-le pour voir l'historique des discussions et envoyer des messages.
            </p>
        </div>
        <form action="{{ path('app_channel_join', {slug: activeChannel.slug}) }}" method="POST" style="width: 100%;" hx-boost="false">
            <button type="submit" class="btn-publish" style="padding: 1rem; font-size: 1.05rem; cursor: pointer;">
                Rejoindre le canal
            </button>
        </form>
    </div>
</div>
