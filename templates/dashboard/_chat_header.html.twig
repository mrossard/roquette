<div class="card-header chat-header">
    <div class="chat-header-layout">
        <!-- Title area and Toggle button -->
        <div class="chat-header-main">
            <div class="title-with-pulse">
                <h2>
                    {% if activeChannel.isDm %}
                        {% set partner = activeChannel.getDmPartner(app.user) %}
                        {% if partner %}
                            <span class="status-dot {{ partner.status }}"
                                  style="width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 0.5rem;"
                                  title="{{ partner.statusLabel }}"></span>
                            <span
                                style="color: hsl({{ partner.hue }}, 90%, var(--user-hue-lightness-hover));">{{ partner.displayName|default(partner.username) }} <span
                                    style="font-size: 0.8rem; font-weight: normal; color: var(--text-muted); opacity: 0.8;">({{ partner.statusLabel }})</span></span>
                        {% else %}
                            <span
                                style="color: var(--accent-purple); margin-right: 0.25rem;">👤</span> Conversation privée
                        {% endif %}
                    {% else %}
                        {% if activeChannel.isPrivate %}
                            <span style="color: var(--accent-purple); margin-right: 0.25rem;">🔒</span>
                        {% else %}
                            <span style="color: var(--accent-cyan); margin-right: 0.25rem;">#</span>
                        {% endif %}
                        {{ activeChannel.name }}
                    {% endif %}
                    {% if isMember %}
                        <button class="btn-favorite-toggle"
                                id="btn-favorite-toggle"
                                hx-post="{{ path('app_channel_favorite_toggle', {slug: activeChannel.slug}) }}"
                                hx-swap="none"
                                title="{% if app.user.isChannelFavorite(activeChannel) %}{{ 'Retirer des favoris'|trans }}{% else %}{{ 'Ajouter aux favoris'|trans }}{% endif %}"
                                style="background: none; border: none; font-size: 1.2rem; cursor: pointer; color: {% if app.user.isChannelFavorite(activeChannel) %}#f59e0b{% else %}var(--text-muted){% endif %}; transition: color 0.2s, transform 0.2s; margin-left: 0.5rem; line-height: 1; vertical-align: middle; padding: 0;">
                            {% if app.user.isChannelFavorite(activeChannel) %}★{% else %}☆{% endif %}
                        </button>
                    {% endif %}
                </h2>
            </div>

            <!-- Toggle button (mobile only) -->
            <button type="button"
                    class="btn-channel-details-toggle"
                    id="btn-channel-details-toggle"
                    onclick="toggleMobileChannelDetails()"
                    title="{{ 'Afficher les détails du canal'|trans }}"
                    aria-label="{{ 'Afficher les détails du canal'|trans }}">
                ℹ️
            </button>
        </div>

        <!-- Details dropdown (collapsible on mobile, side-by-side on desktop) -->
        <div class="chat-header-details" id="chat-header-details">
            <div class="chat-header-info">
                <p class="card-description" style="margin: 0;">
                    {% if activeChannel.isDm %}
                        {% set partner = activeChannel.getDmPartner(app.user) %}
                        {% if partner %}
                            {{ 'Discussion directe et sécurisée avec'|trans }} {{ partner.displayName|default(partner.username) }}.
                        {% else %}
                            {{ 'Discussion directe privée.'|trans }}
                        {% endif %}
                    {% else %}
                        {{ activeChannel.description|default('Aucune description pour ce canal.'|trans) }}
                    {% endif %}
                </p>

            </div>

            <div class="chat-header-actions">
                {% if isMember %}
                    <form id="channel-filters-form"
                          hx-get="{{ path('app_channel_search', {slug: activeChannel.slug}) }}"
                          hx-target="#live-feed"
                          hx-swap="innerHTML transition:false"
                          hx-trigger="input changed delay:400ms from:#channel-search-input"
                          style="display: inline-flex; align-items: center; gap: 0.5rem; margin: 0; padding: 0;">
                        <div class="search-container">
                            <span class="search-icon">🔍</span>
                            <input type="search"
                                   id="channel-search-input"
                                   name="q"
                                   placeholder="{{ 'Rechercher...'|trans }}"
                                   class="input-search"
                                   hx-indicator="#search-indicator"
                                   aria-label="{{ 'Rechercher dans ce canal'|trans }}">
                            <span id="search-indicator" class="htmx-indicator spinner-subtle"
                                  style="display: none;"></span>
                        </div>

                        {% if activeChannel.isTodoList() %}
                            <button type="button" class="btn-hide-completed" data-channel-slug="{{ activeChannel.slug }}">
                                {{ 'Masquer les tâches terminées'|trans }}
                            </button>
                        {% endif %}
                    </form>
                {% endif %}

                {% include 'dashboard/_notification_toggle.html.twig' with {
                    'activeChannel': activeChannel,
                    'notificationsEnabled': notificationsEnabled
                } %}
                {% if isMember %}
                    <details class="user-status-dropdown-container">
                        <summary class="user-status-trigger"
                                 style="list-style: none; display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.35rem 0.75rem; border-radius: 0.5rem; height: 32px;">
                            ⚙️ <span>{{ 'Actions'|trans }}</span>
                            <span class="dropdown-chevron">▼</span>
                        </summary>
                        <div class="user-status-dropdown-menu" role="menu" style="right: 0; min-width: 190px;">
                            {# 0. Membres #}
                            {% if not activeChannel.isDm %}
                                <button type="button" class="user-status-option"
                                        hx-get="{{ path('app_channel_members_modal', {slug: activeChannel.slug}) }}"
                                        hx-target="#modal-container"
                                        hx-trigger="click"
                                        role="menuitem"
                                        style="cursor: pointer;">
                                    <span class="option-icon">👥</span>
                                    <span class="option-label">{{ 'Membres'|trans }} ({{ activeChannel.members|length }})</span>
                                </button>
                            {% endif %}

                            {# 1. Discussions #}
                            {% if not activeChannel.isSubChannel %}
                                <button type="button" class="user-status-option"
                                        id="btn-subchannels-toggle"
                                        onclick="toggleSubChannelsSidebar()"
                                        role="menuitem"
                                        style="cursor: pointer;">
                                    <span class="option-icon">🌿</span>
                                    <span class="option-label">{{ 'Discussions'|trans }} ({{ activeSubChannels|length }})</span>
                                </button>
                            {% endif %}

                            {# 1b. Médiathèque #}
                            <button type="button" class="user-status-option"
                                    id="btn-files-toggle"
                                    onclick="toggleFilesSidebar()"
                                    role="menuitem"
                                    style="cursor: pointer;">
                                <span class="option-icon">📂</span>
                                <span class="option-label">{{ 'Médiathèque'|trans }}</span>
                            </button>

                            {# 2. Inviter #}
                            {% if not activeChannel.isDm and activeChannel.isPrivate and activeChannel.creator == app.user and not activeChannel.isSubChannel %}
                                <button type="button" class="user-status-option"
                                        hx-get="{{ path('app_channel_invite_modal', {slug: activeChannel.slug}) }}"
                                        hx-target="#modal-container"
                                        hx-trigger="click"
                                        role="menuitem"
                                        style="cursor: pointer;">
                                    <span class="option-icon">✉️</span>
                                    <span class="option-label">{{ 'Inviter'|trans }}</span>
                                </button>
                            {% endif %}

                            {# 3. Paramètres #}
                            {% if not activeChannel.isDm and activeChannel.isAdministrator(app.user) %}
                                <button type="button" class="user-status-option"
                                        hx-get="{{ path('app_channel_edit_modal', {slug: activeChannel.slug}) }}"
                                        hx-target="#modal-container"
                                        hx-trigger="click"
                                        role="menuitem"
                                        style="cursor: pointer;">
                                    <span class="option-icon">⚙️</span>
                                    <span class="option-label">{{ 'Paramètres'|trans }}</span>
                                </button>
                            {% endif %}

                            {# 3b. Exporter #}
                            {% if not activeChannel.isDm and (activeChannel.isAdministrator(app.user) or is_granted('ROLE_ADMIN')) %}
                                <a href="{{ path('app_channel_export', {slug: activeChannel.slug}) }}"
                                   class="user-status-option"
                                   hx-boost="false"
                                   target="_blank"
                                   role="menuitem"
                                   style="cursor: pointer; text-decoration: none; color: inherit; display: flex; align-items: center; width: 100%;">
                                    <span class="option-icon">📤</span>
                                    <span class="option-label">{{ 'Exporter l\'historique'|trans }}</span>
                                </a>
                            {% endif %}

                            {# Divider if there is leave or delete #}
                            {% if not activeChannel.isDm and (is_granted('ROLE_ADMIN') and not (activeChannel.creator and activeChannel.creator == app.user) or (not activeChannel.isPrivate and activeChannel.slug != 'general')) %}
                                <div class="user-menu-divider"></div>
                            {% endif %}

                            {# 4. Quitter #}
                            {% if not activeChannel.isDm and not activeChannel.isPrivate and activeChannel.slug != 'general' %}
                                <form action="{{ path('app_channel_leave', {slug: activeChannel.slug}) }}"
                                      method="POST"
                                      data-confirm="{{ 'Êtes-vous sûr de vouloir quitter ce canal ?'|trans }}"
                                      hx-boost="false"
                                      style="margin: 0; padding: 0; display: block; width: 100%;">
                                    <button type="submit" class="user-status-option"
                                            style="width: 100%; text-align: left; background: none; border: none; cursor: pointer;"
                                            role="menuitem">
                                        <span class="option-icon">🚪</span>
                                        <span class="option-label">{{ 'Quitter'|trans }}</span>
                                    </button>
                                </form>
                            {% endif %}

                            {# 5. Supprimer #}
                            {% if not activeChannel.isDm and is_granted('ROLE_ADMIN') and not (activeChannel.creator and activeChannel.creator == app.user) %}
                                <form action="{{ path('app_channel_delete', {slug: activeChannel.slug}) }}"
                                      method="POST"
                                      data-confirm="{{ 'Êtes-vous sûr de vouloir supprimer ce canal ? Tout l\'historique des messages sera perdu définitivement.'|trans }}"
                                      hx-boost="false"
                                      style="margin: 0; padding: 0; display: block; width: 100%;">
                                    <button type="submit" class="user-status-option"
                                            style="width: 100%; text-align: left; background: none; border: none; cursor: pointer; color: var(--accent-red);"
                                            role="menuitem">
                                        <span class="option-icon">🗑️</span>
                                        <span class="option-label"
                                              style="color: var(--accent-red);">{{ 'Supprimer'|trans }}</span>
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    </details>
                {% endif %}
            </div>
        </div>
    </div>
</div>
