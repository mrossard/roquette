{% set unreadCounts = unreadCounts|default({}) %}
{% set activeChannel = activeChannel|default(null) %}
{% set pendingInvitations = pendingInvitations|default([]) %}
{% set showReorder = showReorder|default(true) %}
{% set subChannelsByParent = subChannelsByParent|default({}) %}

<section class="card glass-panel sidebar-panel" id="sidebar-panel">
    {# Hidden elements to subscribe HTMX to global SSE events without triggering DOM swaps #}
    <div style="display:none;" hx-trigger="sse:personal_notification"></div>
    <div style="display:none;" hx-trigger="sse:user_typing"></div>
    <div style="display:none;" hx-trigger="sse:user_status_changed"></div>
    <div style="display:none;" hx-trigger="sse:help_stream_update"></div>
    <div style="display:none;" hx-trigger="sse:invitation_received"></div>
    <div style="display:none;" hx-trigger="sse:channel_deleted"></div>
    <div class="card-header" style="display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.25rem;">
        <div class="sidebar-actions"
             style="display: flex; gap: 0.5rem; align-items: center; justify-content: flex-end;">
            <button id="btn-reorder-done" class="reorder-done-btn"
                    style="display: none; background: var(--accent-cyan); color: #0f172a; border: 1px solid var(--accent-cyan); border-radius: 0.5rem; padding: 0.35rem 0.75rem; font-size: 0.8rem; font-weight: bold; cursor: pointer; align-items: center; justify-content: center; gap: 0.25rem; height: 32px; width: auto;"
                    onclick="document.getElementById('btn-edit-order-trigger').dispatchEvent(new MouseEvent('click', { bubbles: true }));">
                ✔️ {{ 'Terminer'|trans }}
            </button>
            <details class="user-status-dropdown-container">
                <summary class="user-status-trigger"
                         style="list-style: none; display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.35rem 0.75rem; border-radius: 0.5rem; height: 32px; cursor: pointer;">
                    ⚙️ <span>{{ 'Options'|trans }}</span>
                    <span class="dropdown-chevron">▼</span>
                </summary>
                <div class="user-status-dropdown-menu" role="menu" style="right: 0; min-width: 210px;">
                    {# Create channel #}
                    <button type="button" class="user-status-option"
                            hx-get="{{ path('app_channel_create_modal') }}"
                            hx-target="#modal-container"
                            hx-trigger="click"
                            style="width: 100%; text-align: left; background: none; border: none; cursor: pointer;"
                            role="menuitem">
                        <span class="option-icon">＋</span>
                        <span class="option-label">{{ 'Créer un canal'|trans }}</span>
                    </button>

                    <div class="user-menu-divider"></div>

                    {# Filter unread #}
                    <button id="btn-filter-unread" class="user-status-option"
                            style="width: 100%; text-align: left; background: none; border: none; cursor: pointer;"
                            role="menuitem">
                        <span class="option-icon">✉️</span>
                        <span class="option-label">{{ 'Filtrer par non lus'|trans }}</span>
                    </button>

                    {# Reorder #}
                    {% if showReorder %}
                        <button id="btn-edit-order-trigger" class="user-status-option"
                                style="width: 100%; text-align: left; background: none; border: none; cursor: pointer;"
                                role="menuitem">
                            <span class="option-icon">⇅</span>
                            <span class="option-label">{{ 'Ordonner les canaux'|trans }}</span>
                        </button>
                    {% endif %}

                    {# Directory #}
                    <a href="{{ path('app_channels_directory') }}" class="user-status-option"
                       style="text-decoration: none;" role="menuitem">
                        <span class="option-icon">🔍</span>
                        <span class="option-label">{{ 'Parcourir les canaux'|trans }}</span>
                    </a>
                </div>
            </details>
        </div>
    </div>

    <div class="card-body" style="display: flex; flex-direction: column; gap: 1.5rem; overflow-y: auto;">
        <div>
            {% set robotChannel = null %}
            {% for channel in channels %}
                {% if channel.slug starts with 'dm-robot-roquette-' %}
                    {% set robotChannel = channel %}
                {% endif %}
            {% endfor %}

            <details class="sidebar-section-details" data-section="shortcuts" open
                     style="margin-bottom: 1.5rem; display: block;">
                <summary class="sidebar-section-header">
                    <span>
                        <span class="sidebar-section-toggle-icon">▼</span>
                        {{ 'Raccourcis'|trans }}
                    </span>
                </summary>
                <div class="channel-list" id="section-shortcuts">
                    <div style="margin-bottom: 0.125rem;">
                        <a href="{{ path('app_saved_messages') }}"
                           class="btn-sidebar-item {% if app.request.attributes.get('_route') == 'app_saved_messages' %}active{% endif %}">
                            <span style="font-size: 1.1rem; line-height: 1; margin-right: 0.5rem;">⭐</span>
                            <span>{{ 'Messages enregistrés'|trans }}</span>
                        </a>
                    </div>

                    <div style="margin-bottom: 0.125rem;">
                        <a href="{{ path('app_my_reactions') }}"
                           class="btn-sidebar-item {% if app.request.attributes.get('_route') == 'app_my_reactions' or app.request.attributes.get('_route') == 'app_my_reactions_filtered' %}active{% endif %}">
                            <span style="font-size: 1.1rem; line-height: 1; margin-right: 0.5rem;">💬</span>
                            <span>{{ 'Mes réactions'|trans }}</span>
                        </a>
                    </div>

                    {% if robotChannel %}
                        <div class="channel-group">
                            {% include 'dashboard/_channel_sidebar_item.html.twig' with {
                                'channel': robotChannel,
                                'unreadCounts': unreadCounts,
                                'activeChannel': activeChannel
                            } %}
                        </div>
                    {% endif %}
                </div>
            </details>

            {% set hasFavorites = false %}
            {% for channel in channels %}
                {% if app.user.isChannelFavorite(channel) and not (channel.slug starts with 'dm-robot-roquette-') %}
                    {% set hasFavorites = true %}
                {% endif %}
            {% endfor %}

            {% if hasFavorites %}
                <details class="sidebar-section-details" data-section="favorites" open
                         style="margin-bottom: 1.5rem; display: block;">
                    <summary class="sidebar-section-header">
                    <span>
                        <span class="sidebar-section-toggle-icon">▼</span>
                        {{ 'Favoris'|trans }}
                    </span>
                    </summary>
                <div class="channel-list" id="section-favorites" data-list-type="favorites">
                    {% for channel in channels %}
                        {% if app.user.isChannelFavorite(channel) and not (channel.slug starts with 'dm-robot-roquette-') %}
                            {% if channel.isSubChannel %}
                                {% if (activeChannel and channel.id == activeChannel.id) or (unreadCounts[channel.id] is defined and unreadCounts[channel.id].count > 0) %}
                                    {% include 'dashboard/_subchannel_sidebar_item.html.twig' with {
                                        'channel': channel,
                                        'unreadCounts': unreadCounts,
                                        'activeChannel': activeChannel
                                    } %}
                                {% endif %}
                            {% else %}
                                {% include 'dashboard/_channel_sidebar_item.html.twig' with {
                                    'channel': channel,
                                    'unreadCounts': unreadCounts,
                                    'activeChannel': activeChannel
                                } %}
                            {% endif %}
                        {% endif %}
                    {% endfor %}
                </div>
                </details>
            {% endif %}

            {# Todos section — includes both top-level todo channels and todo sub-channels #}
            {% set hasTodos = false %}
            {% for channel in channels %}
                {% if not channel.isDm and channel.isTodoList() and not app.user.isChannelFavorite(channel) %}
                    {% set hasTodos = true %}
                {% endif %}
            {% endfor %}

            <details class="sidebar-section-details sidebar-section-todos" data-section="todos" open
                     style="margin-bottom: 1.5rem; display: block;">
                <summary class="sidebar-section-header sidebar-section-header-todos">
                    <span>
                        <span class="sidebar-section-toggle-icon">▼</span>
                        {{ 'Todos'|trans }}
                    </span>
                    <button type="button" class="btn-sidebar-section-add btn-sidebar-section-add-todo"
                            hx-get="{{ path('app_channel_create_modal', {defaultTodo: 1}) }}"
                            hx-target="#modal-container"
                            hx-trigger="click"
                            onclick="event.preventDefault(); event.stopPropagation();"
                            title="{{ 'Créer un canal todo'|trans }}"
                            aria-label="{{ 'Créer un canal todo'|trans }}">
                        +
                    </button>
                </summary>
                <div class="channel-list" id="section-todos" data-list-type="todos">
                    {% if hasTodos %}
                        {% for channel in channels %}
                            {% if not channel.isDm and channel.isTodoList() and not app.user.isChannelFavorite(channel) %}
                                {% if channel.isSubChannel %}
                                    {# Todo sub-channel: show with parent channel context #}
                                    {% set parentChan = channel.parentMessage ? channel.parentMessage.channel : null %}
                                    <div class="channel-group">
                                        <a href="{{ path('app_channel', {slug: channel.slug}) }}"
                                           id="sidebar-channel-{{ channel.slug }}"
                                           class="channel-link is-todo-channel {% if activeChannel and channel.id == activeChannel.id %}active{% endif %} {% set unread = unreadCounts[channel.id]|default(null) %}{% set cnt = unread ? unread.count : 0 %}{% if cnt > 0 and (not activeChannel or channel.id != activeChannel.id) %}unread{% endif %}"
                                           data-channel-slug="{{ channel.slug }}"
                                           data-channel-id="{{ channel.id }}"
                                           title="{{ channel.name }}">
                                            <span class="channel-hash todo-channel-icon" title="{{ 'Discussion todo'|trans }}">✅</span>
                                            <span class="channel-name">{{ channel.name }}</span>
                                            {% if parentChan %}
                                                <span class="todo-subchannel-parent-badge" title="{{ 'Depuis #' ~ parentChan.name }}">
                                                    ↳ #{{ parentChan.name }}
                                                </span>
                                            {% endif %}
                                            {% set unreadSub = unreadCounts[channel.id]|default(null) %}
                                            {% set cntSub = unreadSub ? unreadSub.count : 0 %}
                                            <span class="unread-badge" {% if cntSub == 0 or (activeChannel and channel.id == activeChannel.id) %}style="display: none;"{% endif %}>{{ cntSub }}</span>
                                        </a>
                                    </div>
                                {% else %}
                                    {# Top-level todo channel #}
                                    <div class="channel-group">
                                        {% include 'dashboard/_channel_sidebar_item.html.twig' with {
                                            'channel': channel,
                                            'unreadCounts': unreadCounts,
                                            'activeChannel': activeChannel
                                        } %}
                                        <div class="channel-subchannels">
                                            {% for sub in subChannelsByParent[channel.id]|default([]) %}
                                                {% if not app.user.isChannelFavorite(sub) and ((activeChannel and sub.id == activeChannel.id) or (unreadCounts[sub.id] is defined and unreadCounts[sub.id].count > 0)) %}
                                                {% include 'dashboard/_subchannel_sidebar_item.html.twig' with {
                                                    'channel': sub,
                                                    'unreadCounts': unreadCounts,
                                                    'activeChannel': activeChannel
                                                } %}
                                            {% endif %}
                                            {% endfor %}
                                        </div>
                                    </div>
                                {% endif %}
                            {% endif %}
                        {% endfor %}
                    {% else %}
                        <p class="sidebar-empty-section-hint">{{ 'Aucun canal todo. Créez-en un !'|trans }}</p>
                    {% endif %}
                </div>
            </details>

            <details class="sidebar-section-details" data-section="channels" open
                     style="margin-bottom: 1.5rem; display: block;">
                <summary class="sidebar-section-header">
                    <span>
                        <span class="sidebar-section-toggle-icon">▼</span>
                        {{ 'Canaux'|trans }}
                    </span>
                </summary>
                <div class="channel-list" id="section-channels" data-list-type="channels">
                    {% set hasChannels = false %}
                    {% for channel in channels %}
                        {% if not channel.isDm and not channel.isSubChannel and not channel.isTodoList() and not app.user.isChannelFavorite(channel) %}
                            {% set hasChannels = true %}
                            <div class="channel-group">
                                {% include 'dashboard/_channel_sidebar_item.html.twig' with {
                                    'channel': channel,
                                    'unreadCounts': unreadCounts,
                                    'activeChannel': activeChannel
                                } %}
                                <div class="channel-subchannels">
                                    {% for sub in subChannelsByParent[channel.id]|default([]) %}
                                        {% if not app.user.isChannelFavorite(sub) and ((activeChannel and sub.id == activeChannel.id) or (unreadCounts[sub.id] is defined and unreadCounts[sub.id].count > 0)) %}
                                        {% include 'dashboard/_subchannel_sidebar_item.html.twig' with {
                                            'channel': sub,
                                            'unreadCounts': unreadCounts,
                                            'activeChannel': activeChannel
                                        } %}
                                    {% endif %}
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                    {% if not hasChannels %}
                        <p style="font-size: 0.85rem; color: var(--text-muted); font-style: italic; padding: 0.25rem 0.5rem;">{{ 'Aucun canal'|trans }}</p>
                    {% endif %}
                </div>
            </details>
        </div>

        <details class="sidebar-section-details" data-section="dms" open style="display: block;">
            <summary class="sidebar-section-header">
                <span>
                    <span class="sidebar-section-toggle-icon">▼</span>
                    {{ 'Messages Directs'|trans }}
                </span>
            </summary>
            <div class="channel-list" id="section-dms" data-list-type="dms">
                {% set hasDms = false %}
                {% for channel in channels %}
                    {% if channel.isDm and not app.user.isChannelFavorite(channel) and not (channel.slug starts with 'dm-robot-roquette-') %}
                        {% set hasDms = true %}
                        <div class="channel-group">
                            {% include 'dashboard/_channel_sidebar_item.html.twig' with {
                                'channel': channel,
                                'unreadCounts': unreadCounts,
                                'activeChannel': activeChannel
                            } %}
                            <div class="channel-subchannels">
                                {% for sub in subChannelsByParent[channel.id]|default([]) %}
                                    {% if not app.user.isChannelFavorite(sub) and ((activeChannel and sub.id == activeChannel.id) or (unreadCounts[sub.id] is defined and unreadCounts[sub.id].count > 0)) %}
                                    {% include 'dashboard/_subchannel_sidebar_item.html.twig' with {
                                        'channel': sub,
                                        'unreadCounts': unreadCounts,
                                        'activeChannel': activeChannel
                                    } %}
                                {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
                {% if not hasDms %}
                    <p style="font-size: 0.85rem; color: var(--text-muted); font-style: italic; padding: 0.25rem 0.5rem;">{{ 'Aucun message direct'|trans }}</p>
                {% endif %}
            </div>
        </details>

        <div class="invitations-section" id="invitations-section" {% if pendingInvitations is empty %}style="display: none; margin-top: 1.5rem; border-top: 1px solid var(--border-glass); padding-top: 1.25rem;"{% else %}style="margin-top: 1.5rem; border-top: 1px solid var(--border-glass); padding-top: 1.25rem;"{% endif %}>
            <h3 style="font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); margin-bottom: 0.75rem;">{{ 'Invitations'|trans }}</h3>
            <div class="invitations-list" style="display: flex; flex-direction: column; gap: 0.75rem;">
                {% for invite in pendingInvitations %}
                    {% include 'dashboard/_invite_sidebar_item.html.twig' with {'invite': invite} %}
                {% endfor %}
            </div>
        </div>
    </div>
</section>
<div id="mobile-sidebar-backdrop" class="mobile-sidebar-backdrop"></div>

