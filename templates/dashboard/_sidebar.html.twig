{% set unreadCounts = unreadCounts|default({}) %}
{% set activeChannel = activeChannel|default(null) %}
{% set pendingInvitations = pendingInvitations|default([]) %}
{% set showReorder = showReorder|default(true) %}
{% set subChannelsByParent = subChannelsByParent|default({}) %}

<section class="card glass-panel sidebar-panel" id="sidebar-panel">
    {# Hidden elements to subscribe HTMX to global SSE events without triggering DOM swaps #}
    <div style="display:none;" hx-trigger="sse:personal_notification"></div>
    <div style="display:none;" hx-trigger="sse:user_typing"></div>
    <div style="display:none;" hx-trigger="sse:user_status_changed"></div>
    <div style="display:none;" hx-trigger="sse:help_stream_update"></div>
    <div style="display:none;" hx-trigger="sse:invitation_received"></div>
    <div style="display:none;" hx-trigger="sse:channel_deleted"></div>
    <div class="card-header" style="display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.25rem;">
        <div class="sidebar-actions" style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; justify-content: flex-end;">
            <button id="btn-filter-unread" class="btn-directory-trigger"
                    title="{{ 'Filtrer par nouveaux messages'|trans }}"
                    aria-label="{{ 'Filtrer par nouveaux messages'|trans }}">✉️
            </button>
            {% if showReorder %}
                <button id="btn-edit-order-trigger" class="btn-directory-trigger"
                        title="{{ 'Ordonner les canaux'|trans }}" aria-label="{{ 'Ordonner les canaux'|trans }}">⇅
                </button>
            {% endif %}
            <a href="{{ path('app_channels_directory') }}" class="btn-directory-trigger" style="text-decoration: none;"
               title="{{ 'Parcourir les canaux'|trans }}" aria-label="{{ 'Parcourir les canaux'|trans }}">🔍</a>
            <button hx-get="{{ path('app_channel_create_modal') }}"
                    hx-target="#modal-container"
                    hx-trigger="click"
                    class="btn-add-channel-trigger"
                    title="{{ 'Créer un canal'|trans }}" aria-label="{{ 'Créer un canal'|trans }}">＋
            </button>
        </div>
    </div>

    <div class="card-body" style="display: flex; flex-direction: column; gap: 1.5rem; overflow-y: auto;">
        <div>
            {% set robotChannel = null %}
            {% for channel in channels %}
                {% if channel.slug starts with 'dm-robot-roquette-' %}
                    {% set robotChannel = channel %}
                {% endif %}
            {% endfor %}

            <div class="sidebar-saved-messages-link-wrapper" style="margin-bottom: 0.75rem;">
                <a href="{{ path('app_saved_messages') }}" class="btn-sidebar-item {% if app.request.attributes.get('_route') == 'app_saved_messages' %}active{% endif %}" style="display: flex; align-items: center; gap: 0.75rem; padding: 0.6rem 0.8rem; border-radius: 0.5rem; text-decoration: none; color: var(--text-primary); transition: var(--transition-smooth); font-size: 0.9rem; font-weight: 500; background: rgba(255, 255, 255, 0.02); border: 1px solid var(--border-glass);">
                    <span style="font-size: 1.1rem; line-height: 1;">⭐</span>
                    <span>{{ 'Messages enregistrés'|trans }}</span>
                </a>
            </div>

            <div class="sidebar-reactions-link-wrapper" style="margin-bottom: 0.75rem;">
                <a href="{{ path('app_my_reactions') }}"
                   class="btn-sidebar-item {% if app.request.attributes.get('_route') == 'app_my_reactions' or app.request.attributes.get('_route') == 'app_my_reactions_filtered' %}active{% endif %}"
                   style="display: flex; align-items: center; gap: 0.75rem; padding: 0.6rem 0.8rem; border-radius: 0.5rem; text-decoration: none; color: var(--text-primary); transition: var(--transition-smooth); font-size: 0.9rem; font-weight: 500; background: rgba(255, 255, 255, 0.02); border: 1px solid var(--border-glass);">
                    <span style="font-size: 1.1rem; line-height: 1;">💬</span>
                    <span>{{ 'Mes réactions'|trans }}</span>
                </a>
            </div>

            {% if robotChannel %}
                <div class="sidebar-robot-link-wrapper" style="margin-bottom: 1.5rem;">
                    {% include 'dashboard/_channel_sidebar_item.html.twig' with {
                        'channel': robotChannel,
                        'unreadCounts': unreadCounts,
                        'activeChannel': activeChannel
                    } %}
                </div>
            {% endif %}

            {% set hasFavorites = false %}
            {% for channel in channels %}
                {% if app.user.isChannelFavorite(channel) and not (channel.slug starts with 'dm-robot-roquette-') %}
                    {% set hasFavorites = true %}
                {% endif %}
            {% endfor %}

            {% if hasFavorites %}
                <details class="sidebar-section-details" data-section="favorites" open
                         style="margin-bottom: 1.5rem; display: block;">
                    <summary class="sidebar-section-header">
                    <span>
                        <span class="sidebar-section-toggle-icon">▼</span>
                        {{ 'Favoris'|trans }}
                    </span>
                    </summary>
                <div class="channel-list" id="section-favorites" data-list-type="favorites">
                    {% for channel in channels %}
                        {% if app.user.isChannelFavorite(channel) and not (channel.slug starts with 'dm-robot-roquette-') %}
                            {% if channel.isSubChannel %}
                                {% if (activeChannel and channel.id == activeChannel.id) or (unreadCounts[channel.id] is defined and unreadCounts[channel.id].count > 0) %}
                                    {% include 'dashboard/_subchannel_sidebar_item.html.twig' with {
                                        'channel': channel,
                                        'unreadCounts': unreadCounts,
                                        'activeChannel': activeChannel
                                    } %}
                                {% endif %}
                            {% else %}
                                {% include 'dashboard/_channel_sidebar_item.html.twig' with {
                                    'channel': channel,
                                    'unreadCounts': unreadCounts,
                                    'activeChannel': activeChannel
                                } %}
                            {% endif %}
                        {% endif %}
                    {% endfor %}
                </div>
                </details>
            {% endif %}

            <details class="sidebar-section-details" data-section="channels" open
                     style="margin-bottom: 1.5rem; display: block;">
                <summary class="sidebar-section-header">
                    <span>
                        <span class="sidebar-section-toggle-icon">▼</span>
                        {{ 'Canaux'|trans }}
                    </span>
                </summary>
                <div class="channel-list" id="section-channels" data-list-type="channels">
                    {% set hasChannels = false %}
                    {% for channel in channels %}
                        {% if not channel.isDm and not channel.isSubChannel and not app.user.isChannelFavorite(channel) %}
                            {% set hasChannels = true %}
                            <div class="channel-group">
                                {% include 'dashboard/_channel_sidebar_item.html.twig' with {
                                    'channel': channel,
                                    'unreadCounts': unreadCounts,
                                    'activeChannel': activeChannel
                                } %}
                                <div class="channel-subchannels">
                                    {% for sub in subChannelsByParent[channel.id]|default([]) %}
                                        {% if not app.user.isChannelFavorite(sub) and ((activeChannel and sub.id == activeChannel.id) or (unreadCounts[sub.id] is defined and unreadCounts[sub.id].count > 0)) %}
                                        {% include 'dashboard/_subchannel_sidebar_item.html.twig' with {
                                            'channel': sub,
                                            'unreadCounts': unreadCounts,
                                            'activeChannel': activeChannel
                                        } %}
                                    {% endif %}
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                    {% if not hasChannels %}
                        <p style="font-size: 0.85rem; color: var(--text-muted); font-style: italic; padding: 0.25rem 0.5rem;">{{ 'Aucun canal'|trans }}</p>
                    {% endif %}
                </div>
            </details>
        </div>

        <details class="sidebar-section-details" data-section="dms" open style="display: block;">
            <summary class="sidebar-section-header">
                <span>
                    <span class="sidebar-section-toggle-icon">▼</span>
                    {{ 'Messages Directs'|trans }}
                </span>
            </summary>
            <div class="channel-list" id="section-dms" data-list-type="dms">
                {% set hasDms = false %}
                {% for channel in channels %}
                    {% if channel.isDm and not app.user.isChannelFavorite(channel) and not (channel.slug starts with 'dm-robot-roquette-') %}
                        {% set hasDms = true %}
                        <div class="channel-group">
                            {% include 'dashboard/_channel_sidebar_item.html.twig' with {
                                'channel': channel,
                                'unreadCounts': unreadCounts,
                                'activeChannel': activeChannel
                            } %}
                            <div class="channel-subchannels">
                                {% for sub in subChannelsByParent[channel.id]|default([]) %}
                                    {% if not app.user.isChannelFavorite(sub) and ((activeChannel and sub.id == activeChannel.id) or (unreadCounts[sub.id] is defined and unreadCounts[sub.id].count > 0)) %}
                                    {% include 'dashboard/_subchannel_sidebar_item.html.twig' with {
                                        'channel': sub,
                                        'unreadCounts': unreadCounts,
                                        'activeChannel': activeChannel
                                    } %}
                                {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
                {% if not hasDms %}
                    <p style="font-size: 0.85rem; color: var(--text-muted); font-style: italic; padding: 0.25rem 0.5rem;">{{ 'Aucun message direct'|trans }}</p>
                {% endif %}
            </div>
        </details>

        <div class="invitations-section" id="invitations-section" {% if pendingInvitations is empty %}style="display: none; margin-top: 1.5rem; border-top: 1px solid var(--border-glass); padding-top: 1.25rem;"{% else %}style="margin-top: 1.5rem; border-top: 1px solid var(--border-glass); padding-top: 1.25rem;"{% endif %}>
            <h3 style="font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); margin-bottom: 0.75rem;">{{ 'Invitations'|trans }}</h3>
            <div class="invitations-list" style="display: flex; flex-direction: column; gap: 0.75rem;">
                {% for invite in pendingInvitations %}
                    {% include 'dashboard/_invite_sidebar_item.html.twig' with {'invite': invite} %}
                {% endfor %}
            </div>
        </div>
    </div>
</section>
<div id="mobile-sidebar-backdrop" class="mobile-sidebar-backdrop"></div>

