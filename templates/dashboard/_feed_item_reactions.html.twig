{% set message_reactions = messageObject is defined and messageObject ? messageObject.getGroupedReactions(app.user) : {} %}
{% if message_reactions is not empty %}
    <div class="message-reactions-container" {% if isMeMessage|default(false) %}style="margin-top: 0.25rem;"{% endif %}>
        {% for emoji, info in message_reactions %}
            <button class="reaction-badge {% if info.hasReacted %}active{% endif %}"
                    hx-post="{{ path('app_message_react', {id: message_id, emoji: emoji}) }}"
                    hx-target="closest .feed-item"
                    hx-swap="morph transition:false"
                    data-reactors="{{ info.reactorUsernames|join(' ') }}"
                    title="{{ info.usernames|reaction_tooltip(emoji) }}">
                <span class="reaction-emoji">{{ emoji }}</span>
                <span class="reaction-count">{{ info.count }}</span>
            </button>
        {% endfor %}
    </div>
{% endif %}
