{% extends 'base.html.twig' %}

{% block title %}Roquette - {{ 'Mes réactions'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
    <div class="app-container" hx-boost="true">
        <header class="app-header">
            <div class="logo-area">
                <button id="mobile-sidebar-toggle" class="btn-mobile-toggle" aria-label="Afficher le menu">
                    <span class="hamburger-bar"></span>
                    <span class="hamburger-bar"></span>
                    <span class="hamburger-bar"></span>
                </button>
                <span class="logo-rocket">🚀</span>
                <div class="logo-text">
                    <h1>Roquette</h1>
                    <p class="subtitle">Symfony + HTMX + Mercure + AssetMapper</p>
                </div>
            </div>

            {% include 'dashboard/_header_controls.html.twig' %}
        </header>

        <main class="dashboard-grid">
            {% include 'dashboard/_sidebar.html.twig' with {
                'channels': channels,
                'activeChannel': null
            } %}

            <section class="card glass-panel chat-panel" id="reactions-panel">
                <div class="card-header chat-header">
                    <div>
                        <h2>💬 {{ 'Mes réactions'|trans }}</h2>
                        <p class="card-description" style="margin-top: 0.25rem;">
                            Retrouvez ici tous les messages auxquels vous avez réagi.
                        </p>
                    </div>
                </div>

                <div class="card-body chat-body" style="padding: 1rem 1.5rem; overflow-y: auto;">
                    <div class="reaction-filter-bar"
                         style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; padding-bottom: 1rem; border-bottom: 1px solid rgba(255,255,255,0.05);">
                        <a href="{{ path('app_my_reactions') }}"
                           hx-target="#reactions-panel"
                           hx-select="#reactions-panel"
                           hx-swap="outerHTML"
                           style="text-decoration: none; padding: 0.4rem 0.8rem; border-radius: 0.5rem; font-size: 0.85rem; color: var(--text-muted); background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08); {% if activeEmoji is null %}background: var(--accent-primary); color: #fff; border-color: var(--accent-primary);{% endif %}">
                            {{ 'Tout'|trans }}
                        </a>
                        {% for emoji in userEmojis %}
                            <a href="{{ path(activeEmoji == emoji ? 'app_my_reactions' : 'app_my_reactions_filtered', activeEmoji == emoji ? {} : {emoji: emoji}) }}"
                               hx-target="#reactions-panel"
                               hx-select="#reactions-panel"
                               hx-swap="outerHTML"
                               style="text-decoration: none; padding: 0.3rem 0.6rem; border-radius: 0.5rem; font-size: 1.2rem; line-height: 1; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08); {% if activeEmoji == emoji %}background: var(--accent-primary); border-color: var(--accent-primary);{% endif %}">
                                {{ emoji }}
                            </a>
                        {% endfor %}
                    </div>

                    <div class="messages-feed" id="live-feed">
                        {% include 'dashboard/_my_reactions_list.html.twig' %}
                    </div>
                </div>
            </section>
        </main>
    </div>
{% endblock %}