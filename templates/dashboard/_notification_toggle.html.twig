<button type="button" 
        class="btn-notifications {% if not notificationsEnabled %}muted{% endif %}"
        hx-post="{{ path('app_channel_toggle_notifications', {slug: activeChannel.slug}) }}"
        hx-swap="outerHTML"
        title="{% if notificationsEnabled %}{{ 'Notifications de bureau activées pour ce canal (cliquez pour désactiver)'|trans }}{% else %}{{ 'Notifications de bureau désactivées pour ce canal (cliquez pour activer)'|trans }}{% endif %}">
    {% if notificationsEnabled %}
        🔔 {{ 'Notifications actives'|trans }}
    {% else %}
        🔕 {{ 'Sourdine'|trans }}
    {% endif %}
</button>
