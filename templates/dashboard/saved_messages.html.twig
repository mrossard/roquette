{% extends 'base.html.twig' %}

{% block title %}Roquette - {{ 'Messages enregistrés'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
    <div class="app-container" hx-boost="true">
    <header class="app-header">
        <div class="logo-area">
            <button id="mobile-sidebar-toggle" class="btn-mobile-toggle" aria-label="Afficher le menu">
                <span class="hamburger-bar"></span>
                <span class="hamburger-bar"></span>
                <span class="hamburger-bar"></span>
            </button>
            <span class="logo-rocket">🚀</span>
            <div class="logo-text">
                <h1>Roquette</h1>
                <p class="subtitle">Symfony + HTMX + Mercure + AssetMapper</p>
            </div>
        </div>

        {% include 'dashboard/_header_controls.html.twig' %}
    </header>

    <main class="dashboard-grid">
        <!-- Channels Sidebar Panel -->
        {% include 'dashboard/_sidebar.html.twig' with {
            'channels': channels,
            'activeChannel': null
        } %}

        <!-- Main Chat Area Panel -->
        <section class="card glass-panel chat-panel">
            <div class="card-header chat-header">
                <div>
                    <h2>⭐ Messages enregistrés</h2>
                    <p class="card-description" style="margin-top: 0.25rem;">
                        Retrouvez ici tous les messages que vous avez marqués comme favoris.
                    </p>
                </div>
            </div>

            <div class="card-body chat-body" style="padding: 1rem 1.5rem; overflow-y: auto;">
                <div class="messages-feed" id="live-feed">
                    {% include 'dashboard/_saved_messages_list.html.twig' %}
                </div>
            </div>
        </section>
    </main>
</div>
{% endblock %}