{% extends 'base.html.twig' %}

{% block title %}Roquette - {{ 'Messages enregistrés'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
    {% set mercureTopics = [
        mercure_topic_prefix ~ '/users/' ~ app.user.username,
        mercure_topic_prefix ~ '/users/status'
    ] %}
    {% for ch in channels %}
        {% set mercureTopics = mercureTopics|merge([mercure_topic_prefix ~ '/channels/' ~ ch.slug]) %}
    {% endfor %}
    {% set hubUrl = mercure(mercureTopics, { subscribe: mercureTopics }) %}
    <div class="app-container" hx-boost="true" hx-ext="sse" sse-connect="{{ hubUrl }}">
    <header class="app-header">
        <div class="logo-area">
            <button id="mobile-sidebar-toggle" class="btn-mobile-toggle" aria-label="Afficher le menu">
                <span class="hamburger-bar"></span>
                <span class="hamburger-bar"></span>
                <span class="hamburger-bar"></span>
            </button>
            <span class="logo-rocket">🚀</span>
            <div class="logo-text">
                <h1>Roquette</h1>
                <p class="subtitle">Symfony + HTMX + Mercure + AssetMapper</p>
            </div>
        </div>

        <div class="header-controls">
            <div class="status-badge" id="mercure-status"
                 data-active-channel-slug=""
                 data-current-username="{{ app.user.username }}"
                 data-hub="{{ hubUrl }}">
                <span class="status-dot disconnected"></span>
                <span class="status-text">Connexion au Hub...</span>
            </div>

            <button id="theme-toggle" class="btn-theme-toggle" aria-label="Changer de thème">🌓</button>

            {% include 'dashboard/_user_menu_dropdown.html.twig' %}
        </div>
    </header>

    <main class="dashboard-grid">
        <!-- Channels Sidebar Panel -->
        {% include 'dashboard/_sidebar.html.twig' with {
            'channels': channels,
            'activeChannel': null
        } %}

        <!-- Main Chat Area Panel -->
        <section class="card glass-panel chat-panel">
            <div class="card-header chat-header">
                <div>
                    <h2>⭐ Messages enregistrés</h2>
                    <p class="card-description" style="margin-top: 0.25rem;">
                        Retrouvez ici tous les messages que vous avez marqués comme favoris.
                    </p>
                </div>
            </div>

            <div class="card-body chat-body" style="padding: 1rem 1.5rem; overflow-y: auto;">
                <div class="messages-feed" id="live-feed">
                    {% if savedMessages is empty %}
                        <div class="empty-state" id="feed-empty-state" style="text-align: center; padding: 4rem 2rem;">
                            <span style="font-size: 3rem; display: block; margin-bottom: 1rem;">⭐</span>
                            <h3>Aucun message enregistré</h3>
                            <p style="color: var(--text-muted); font-size: 0.9rem; margin-top: 0.5rem; max-width: 400px; margin-left: auto; margin-right: auto;">
                                Cliquez sur le bouton "Enregistrer" sur n'importe quel message dans vos canaux pour le conserver ici.
                            </p>
                        </div>
                    {% else %}
                        {% for msg in savedMessages %}
                            <div style="margin-bottom: 1.5rem; border-bottom: 1px solid rgba(255, 255, 255, 0.05); padding-bottom: 1.5rem;">
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; background: rgba(255,255,255,0.02); padding: 0.4rem 0.8rem; border-radius: 0.5rem; border: 1px solid rgba(255,255,255,0.03);">
                                    <span style="font-size: 0.8rem; color: var(--text-muted);">
                                        Provenance :
                                        {% if msg.channel.isDm %}
                                            {% set partner = msg.channel.getDmPartner(app.user) %}
                                            <strong>💬 Conversation privée avec {{ partner ? partner.displayName|default(partner.username) : 'un utilisateur' }}</strong>
                                        {% else %}
                                            <strong>#{{ msg.channel.name }}</strong>
                                        {% endif %}
                                    </span>
                                    <a href="{{ path('app_channel', {slug: msg.channel.slug}) }}" class="btn-reply-subtle" style="font-size: 0.75rem; text-decoration: none;">
                                        Y aller →
                                    </a>
                                </div>
                                {% include 'dashboard/_feed_item.html.twig' with {
                                    'messageObject': msg
                                } %}
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
        </section>
    </main>
</div>
{% endblock %}
