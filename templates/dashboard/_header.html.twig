<header class="app-header">
    <div class="logo-area">
        <button id="mobile-sidebar-toggle" class="btn-mobile-toggle" aria-label="{{ 'Afficher le menu'|trans }}">
            <span class="hamburger-bar"></span>
            <span class="hamburger-bar"></span>
            <span class="hamburger-bar"></span>
        </button>
        <span class="logo-rocket">🚀</span>
        <div class="logo-text">
            <h1>Roquette</h1>
            <p class="subtitle">Chat avec Mercure !</p>
        </div>
    </div>

    <div class="global-search-trigger-container">
        <button id="global-search-trigger-btn" class="global-search-trigger" onclick="openGlobalSearch()"
                title="{{ 'Recherche globale (Ctrl+K)'|trans }}">
            <span class="search-trigger-icon">🔍</span>
            <span class="search-trigger-placeholder">{{ 'Rechercher...'|trans }}</span>
            <kbd class="search-trigger-shortcut">Ctrl+K</kbd>
        </button>
    </div>

    {% include 'dashboard/_header_controls.html.twig' with {'activeChannel': activeChannel} %}
</header>
