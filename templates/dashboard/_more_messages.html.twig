{% if hasMore %}
    {% include 'dashboard/_load_more_trigger.html.twig' with {
        'channel': channel,
        'beforeId': nextBeforeId
    } %}
{% endif %}

{% set lastDate = null %}
{% for message in messages %}
    {% set currentDate = message.createdAt|date('Y-m-d') %}
    {% if lastDate is null or currentDate != lastDate %}
        {% include 'dashboard/_day_separator.html.twig' with {label: currentDate == 'now'|date('Y-m-d') ? 'Aujourd\'hui' : (currentDate == 'yesterday'|date('Y-m-d') ? 'Hier' : message.createdAt|date('d/m/Y'))} %}
        {% set lastDate = currentDate %}
    {% endif %}
    {% include 'dashboard/_feed_item.html.twig' with {
        'messageObject': message,
        'replyCounts': replyCounts|default({})
    } %}
{% endfor %}
