{% extends 'base.html.twig' %}

{% block title %}Roquette - {{ 'Répertoire des canaux'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
    {% set mercureTopics = [
        mercure_topic_prefix ~ '/users/' ~ app.user.username,
        mercure_topic_prefix ~ '/users/status'
    ] %}
    {% for ch in channels %}
        {% set mercureTopics = mercureTopics|merge([mercure_topic_prefix ~ '/channels/' ~ ch.slug]) %}
    {% endfor %}
    {% set hubUrl = mercure(mercureTopics, { subscribe: mercureTopics }) %}
    <div class="app-container" hx-boost="true" hx-ext="sse" sse-connect="{{ hubUrl }}">
    <header class="app-header">
        <div class="logo-area">
            <button id="mobile-sidebar-toggle" class="btn-mobile-toggle" aria-label="Afficher le menu">
                <span class="hamburger-bar"></span>
                <span class="hamburger-bar"></span>
                <span class="hamburger-bar"></span>
            </button>
            <span class="logo-rocket">🚀</span>
            <div class="logo-text">
                <h1>Roquette</h1>
                <p class="subtitle">Symfony + HTMX + Mercure + AssetMapper</p>
            </div>
        </div>

        {% include 'dashboard/_header_controls.html.twig' %}
    </header>

    <main class="dashboard-grid">
        <!-- Channels Sidebar Panel -->
        {% include 'dashboard/_sidebar.html.twig' with {
            'channels': channels,
            'unreadCounts': unreadCounts,
            'activeChannel': null,
            'pendingInvitations': pendingInvitations
        } %}

        <!-- Directory Panel -->
        <section class="card glass-panel chat-panel">
            {% include 'dashboard/_chat_skeleton.html.twig' %}
            <div class="card-header chat-header" style="border-bottom: 1px solid var(--border-glass); padding-bottom: 1.25rem; margin-bottom: 0;">
                <div class="chat-header-layout" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; width: 100%;">
                    <div>
                        <div class="title-with-pulse">
                            <h2>
                                <span style="color: var(--accent-cyan); margin-right: 0.25rem;">📁</span> Répertoire & Annuaire
                            </h2>
                        </div>
                        <p class="card-description" style="margin-top: 0.25rem;">Parcourez les canaux ou trouvez des membres pour leur écrire en privé.</p>
                    </div>
                    <div>
                        <input type="text" id="directory-search" placeholder="Rechercher un canal..." class="input-sidebar" style="max-width: 250px; background: rgba(0,0,0,0.3) !important;">
                    </div>

                    <div role="tablist" aria-label="Sections du répertoire" style="display: flex; gap: 1rem; margin-top: 1rem; width: 100%; border-top: 1px solid var(--border-glass); padding-top: 1rem;">
                        <button class="tab-btn active" role="tab" aria-selected="true" aria-controls="panel-channels" onclick="switchTab('channels')" id="tab-btn-channels" style="background: none; border: none; border-bottom: 2px solid var(--accent-cyan); color: var(--text-primary); font-size: 0.95rem; font-weight: 600; padding: 0.5rem 1rem; cursor: pointer; transition: var(--transition-smooth);">📁 Canaux Publics</button>
                        <button class="tab-btn" role="tab" aria-selected="false" aria-controls="panel-members" onclick="switchTab('members')" id="tab-btn-members" style="background: none; border: none; border-bottom: 2px solid transparent; color: var(--text-muted); font-size: 0.95rem; font-weight: 600; padding: 0.5rem 1rem; cursor: pointer; transition: var(--transition-smooth);">👥 Membres de l'application</button>
                    </div>
                </div>
            </div>

            <div class="card-body chat-body" style="overflow-y: auto; padding-top: 1.5rem;">
                {% for label, messages in app.flashes %}
                    {% for msg in messages %}
                        <div class="alert-{{ label == 'error' ? 'error' : 'success' }} fade-in" style="margin-bottom: 1.5rem; background: rgba({{ label == 'error' ? '239, 68, 68' : '16, 185, 129' }}, 0.1); border: 1px solid rgba({{ label == 'error' ? '239, 68, 68' : '16, 185, 129' }}, 0.2); color: var(--accent-{{ label == 'error' ? 'red' : 'green' }}); border-radius: 0.75rem; padding: 0.75rem 1rem; font-size: 0.9rem; font-weight: 500;">
                            {{ msg }}
                        </div>
                    {% endfor %}
                {% endfor %}

                <div id="directory-panels">
                    {% include 'dashboard/_directory_panel.html.twig' with {type: 'channels', allPublicChannels: allPublicChannels} %}
                </div>
            </div>
        </section>
    </main>

        {% include 'partials/_footer.html.twig' %}
</div>

<script>
    (function() {
        function initSearch() {
            const searchInput = document.getElementById('directory-search');
            if (searchInput) {
                searchInput.addEventListener('input', (e) => {
                    const query = e.target.value.toLowerCase().trim();
                    document.querySelectorAll('.directory-card').forEach(card => {
                        const name = card.querySelector('h3').textContent.toLowerCase();
                        const desc = card.querySelector('p') ? card.querySelector('p').textContent.toLowerCase() : '';
                        if (name.includes(query) || desc.includes(query)) {
                            card.style.display = 'flex';
                        } else {
                            card.style.display = 'none';
                        }
                    });
                    document.querySelectorAll('.member-card').forEach(card => {
                        const name = card.querySelector('h3').textContent.toLowerCase();
                        const username = card.querySelector('.member-username') ? card.querySelector('.member-username').textContent.toLowerCase() : '';
                        if (name.includes(query) || username.includes(query)) {
                            card.style.display = 'flex';
                        } else {
                            card.style.display = 'none';
                        }
                    });
                });
            }
        }

        document.addEventListener('DOMContentLoaded', initSearch);
        document.body.addEventListener('htmx:afterSettle', initSearch);
    })();

    function switchTab(tab) {
        const channelsBtn = document.getElementById('tab-btn-channels');
        const membersBtn = document.getElementById('tab-btn-members');
        const searchInput = document.getElementById('directory-search');

        if (tab === 'channels') {
            channelsBtn.style.borderBottomColor = 'var(--accent-cyan)';
            channelsBtn.style.color = 'var(--text-primary)';
            channelsBtn.setAttribute('aria-selected', 'true');
            membersBtn.style.borderBottomColor = 'transparent';
            membersBtn.style.color = 'var(--text-muted)';
            membersBtn.setAttribute('aria-selected', 'false');
            if (searchInput) searchInput.placeholder = 'Rechercher un canal...';
        } else {
            membersBtn.style.borderBottomColor = 'var(--accent-cyan)';
            membersBtn.style.color = 'var(--text-primary)';
            membersBtn.setAttribute('aria-selected', 'true');
            channelsBtn.style.borderBottomColor = 'transparent';
            channelsBtn.style.color = 'var(--text-muted)';
            channelsBtn.setAttribute('aria-selected', 'false');
            if (searchInput) searchInput.placeholder = 'Rechercher un membre...';
        }

        htmx.ajax('GET', '{{ path('app_directory_panel', {type: 'TYPE'}) }}'.replace('TYPE', tab), {
            target: '#directory-panels',
            swap: 'innerHTML',
        });

        if (searchInput) {
            searchInput.value = '';
            searchInput.dispatchEvent(new Event('input'));
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        const tabList = document.querySelector('[role="tablist"]');
        if (tabList) {
            tabList.addEventListener('keydown', (e) => {
                const tabs = Array.from(tabList.querySelectorAll('[role="tab"]'));
                const activeIndex = tabs.indexOf(document.activeElement);
                if (activeIndex === -1) return;

                if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
                    const nextIndex = (activeIndex + 1) % tabs.length;
                    tabs[nextIndex].focus();
                    tabs[nextIndex].click();
                    e.preventDefault();
                } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
                    const prevIndex = (activeIndex - 1 + tabs.length) % tabs.length;
                    tabs[prevIndex].focus();
                    tabs[prevIndex].click();
                    e.preventDefault();
                }
            });
        }
    });
</script>
{% endblock %}
