{% extends 'base.html.twig' %}

{% block title %}{{ 'Export en cours - Roquette'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/pages/auth.css') }}">
{% endblock %}

{% block body %}
<div class="auth-wrapper" id="main-content">
    <div class="card glass-panel auth-card fade-in" style="max-width: 500px; text-align: center;">
        <div class="auth-header">
            <span class="auth-logo" style="font-size: 3rem; display: block; margin-bottom: 1rem;">📤</span>
            <h1>{{ 'Export demandé'|trans }}</h1>
            <p style="margin-top: 1rem; line-height: 1.6;">
                {{ "L'exportation du canal"|trans }} <strong>#{{ channel.name }}</strong> {{ "a commencé en arrière-plan."|trans }}
            </p>
            <p style="margin-top: 1rem; line-height: 1.6; color: var(--text-muted);">
                {{ "Cette opération peut prendre quelques instants selon le volume de messages et de fichiers joints. Vous pouvez fermer cet onglet en toute sécurité. Le Robot Roquette vous enverra un message privé contenant le lien de téléchargement dès que l'archive sera prête."|trans }}
            </p>
        </div>

        <div class="form-actions" style="margin-top: 2rem; display: flex; justify-content: center;">
            <button onclick="window.close();" class="btn-publish" style="padding: 0.75rem 2rem;">
                <span>{{ 'Fermer la page'|trans }}</span>
            </button>
        </div>
    </div>
</div>
{% endblock %}
