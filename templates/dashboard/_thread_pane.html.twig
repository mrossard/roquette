<div class="thread-header">
    <div class="thread-header-title">
        <h3>Fil de discussion</h3>
        <span class="thread-header-subtitle">dans #{{ parentMessage.channel.name }}</span>
    </div>
    <button type="button" class="btn-close-thread"
            hx-post="{{ path('app_thread_mark_read', {id: parentMessage.id}) }}"
            hx-target="#thread-panel"
            hx-swap="innerHTML"
            title="Fermer le fil">✕
    </button>
</div>

<div class="thread-content" data-parent-id="{{ parentMessage.id }}">
    <!-- Parent Message -->
    <div class="thread-parent-container">
        {% include 'dashboard/_feed_item.html.twig' with {
            'messageObject': parentMessage
        } %}
    </div>

    <div class="thread-divider">
        <span class="thread-divider-text">Réponses</span>
    </div>

    <!-- Replies -->
    <div class="thread-replies-container" id="thread-replies-feed">
        <div class="thread-replies-list" id="thread-replies-list">
            {% set lastDate = null %}
            {% for reply in replies %}
                {% set currentDate = reply.createdAt|date('Y-m-d') %}
                {% if lastDate is null or currentDate != lastDate %}
                    <div class="day-separator">
                        <span class="day-separator-line"></span>
                        <span class="day-separator-label">
                            {% if currentDate == 'now'|date('Y-m-d') %}
                                Aujourd'hui
                            {% elseif currentDate == 'yesterday'|date('Y-m-d') %}
                                Hier
                            {% else %}
                                {{ reply.createdAt|date('d/m/Y') }}
                            {% endif %}
                        </span>
                        <span class="day-separator-line"></span>
                    </div>
                    {% set lastDate = currentDate %}
                {% endif %}
                {% include 'dashboard/_feed_item.html.twig' with {
                    'messageObject': reply
                } %}
            {% else %}
                <div class="thread-empty-state">
                    Aucune réponse pour le moment. Soyez le premier à répondre !
                </div>
            {% endfor %}
        </div>
    </div>
</div>

<div class="thread-input-area">
    {% include 'dashboard/_thread_input_form.html.twig' with {'parentMessage': parentMessage} %}
</div>

