{# Remplacement OOB de la liste complète des réponses (gère l'état vide automatiquement) #}
<div hx-swap-oob="innerHTML:#thread-replies-list">
    {% set lastDate = null %}
    {% for existingReply in replies %}
        {% set currentDate = existingReply.createdAt|date('Y-m-d') %}
        {% if lastDate is null or currentDate != lastDate %}
            <div class="day-separator">
                <span class="day-separator-line"></span>
                <span class="day-separator-label">
                    {% if currentDate == 'now'|date('Y-m-d') %}
                        Aujourd'hui
                    {% elseif currentDate == 'yesterday'|date('Y-m-d') %}
                        Hier
                    {% else %}
                        {{ existingReply.createdAt|date('d/m/Y') }}
                    {% endif %}
                </span>
                <span class="day-separator-line"></span>
            </div>
            {% set lastDate = currentDate %}
        {% endif %}
        {% include 'dashboard/_feed_item.html.twig' with {
            'messageObject': existingReply
        } %}
    {% endfor %}
</div>

