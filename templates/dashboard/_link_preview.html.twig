<div class="link-preview-card" data-preview-url="{{ url }}">
    <a href="{{ url }}" target="_blank" rel="noopener noreferrer" class="link-preview-wrapper">
        {% if image %}
            <div class="link-preview-image-container">
                <img src="{{ image }}" class="link-preview-image" alt="Aperçu de l'image">
            </div>
        {% endif %}
        <div class="link-preview-content">
            <div class="link-preview-site">{{ siteName }}</div>
            <div class="link-preview-title">{{ title }}</div>
            {% if description %}
                <div class="link-preview-description">{{ description }}</div>
            {% endif %}
        </div>
    </a>
</div>
