{% set channelCount = channels|filter(c => not c.isDm and not c.isSubChannel and not c.isTodoList() and not app.user.isChannelFavorite(c))|length %}

<details class="sidebar-section-details" data-section="channels"
         {% if channelCount <= 5 %}open{% endif %}
         style="display: block;">
    <summary class="sidebar-section-header sidebar-section-header-channels">
        <span>
            <span class="sidebar-section-toggle-icon">▼</span>
            <span class="sidebar-section-icon">#</span>
            {{ 'Canaux'|trans }}
        </span>
        <button type="button" class="btn-sidebar-section-add btn-sidebar-section-add-channel"
                hx-get="{{ path('app_channel_create_modal') }}"
                hx-target="#modal-container"
                hx-trigger="click"
                onclick="event.preventDefault(); event.stopPropagation();"
                title="{{ 'Créer un canal'|trans }}"
                aria-label="{{ 'Créer un canal'|trans }}">
            +
        </button>
    </summary>
    {% include 'dashboard/_sidebar_channels_list.html.twig' %}
</details>
