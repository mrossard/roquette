{% extends 'base.html.twig' %}

{% block title %}Roquette - #{{ activeChannel.name }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
    {% set activeSubChannels = [] %}
    {% for sub in channels %}
        {% if sub.isSubChannel and sub.parentMessage and sub.parentMessage.channel.id == activeChannel.id %}
            {% set activeSubChannels = activeSubChannels|merge([sub]) %}
        {% endif %}
    {% endfor %}
    <div class="app-container" hx-boost="true">
        <div sse-swap="channel_deleted" hx-swap="none" style="display: none;"></div>
    {% include 'dashboard/_header.html.twig' with {
        'channels': channels,
        'activeChannel': activeChannel
    } %}

        <main class="dashboard-grid" id="main-content">
        <!-- Channels Sidebar Panel -->
        {% include 'dashboard/_sidebar.html.twig' with {
            'channels': channels,
            'unreadCounts': unreadCounts,
            'activeChannel': activeChannel,
            'pendingInvitations': pendingInvitations
        } %}

        <!-- Main Chat Area Panel -->
        <section class="card glass-panel chat-panel">
            {% include 'dashboard/_chat_skeleton.html.twig' %}
            {% if isMember %}
                <!-- Drag and drop overlay -->
                <div id="drag-drop-overlay" class="drag-drop-overlay">
                    <div class="drag-drop-container">
                        <div class="drag-drop-icon-wrapper">
                            <span class="drag-drop-icon">📤</span>
                        </div>
                        <h3 class="drag-drop-title">Déposer votre fichier</h3>
                        <p class="drag-drop-text">
                            {%- if activeChannel.isDm -%}
                                {%- set partner = activeChannel.getDmPartner(app.user) -%}
                                Relâchez le fichier pour l'envoyer à {{ partner ? (partner.displayName|default(partner.username)) : 'votre destinataire' }}
                            {%- else -%}
                                Relâchez le fichier pour l'ajouter à votre message dans #{{ activeChannel.name }}
                            {%- endif -%}
                        </p>
                    </div>
                </div>
            {% endif %}

            {% include 'dashboard/_chat_header.html.twig' %}

            {% if isMember %}
                <div class="card-body chat-body">
                    {% for label, messages in app.flashes %}
                        {% for msg in messages %}
                            <div class="alert-{{ label == 'error' ? 'error' : 'success' }} fade-in" style="margin-bottom: 1rem; background: rgba({{ label == 'error' ? '239, 68, 68' : '16, 185, 129' }}, 0.1); border: 1px solid rgba({{ label == 'error' ? '239, 68, 68' : '16, 185, 129' }}, 0.2); color: var(--accent-{{ label == 'error' ? 'red' : 'green' }}); border-radius: 0.75rem; padding: 0.75rem 1rem; font-size: 0.9rem; font-weight: 500;">
                                {{ msg|trans }}
                            </div>
                        {% endfor %}
                    {% endfor %}
                    <div id="pinned-banner-container" class="pinned-banner-container">
                        {% if activeChannel.pinnedMessage %}
                            {% include 'dashboard/_pinned_banner.html.twig' with {'pinnedMessage': activeChannel.pinnedMessage, 'activeChannel': activeChannel} %}
                        {% endif %}
                    </div>
                    {% if activeChannel.isSubChannel and activeChannel.parentMessage %}
                        {% include 'dashboard/_subchannel_header.html.twig' with {
                            'parentMessage': activeChannel.parentMessage
                        } %}
                    {% endif %}
                    <div id="live-feed" class="feed-container" role="log" aria-live="polite"
                         sse-swap="message_{{ activeChannel.slug }}" hx-swap="beforeend transition:false"
                         {% if activeChannel.creator == app.user or is_granted('ROLE_ADMIN') %}data-is-channel-creator="true"{% endif %}>
                        {% include 'dashboard/_messages_feed.html.twig' with {
                            'messages': messages,
                            'activeChannel': activeChannel,
                            'firstUnreadMessageId': firstUnreadMessageId,
                            'replyCounts': replyCounts|default({})
                        } %}
                    </div>

                    {% include 'dashboard/_typing_indicator.html.twig' with {'typingUsers': typingUsers|default([]), 'activeChannel': activeChannel} %}

                    <div class="chat-input-area">
                        {% include 'dashboard/_input_form.html.twig' with {'activeChannel': activeChannel} %}
                    </div>
                </div>
            {% else %}
                {% include 'dashboard/_join_channel_prompt.html.twig' with {'activeChannel': activeChannel} %}
            {% endif %}
        </section>

            {% if not activeChannel.isSubChannel %}
                {% include 'dashboard/_subchannels_sidebar_panel.html.twig' with {
                    'activeSubChannels': activeSubChannels,
                    'unreadCounts': unreadCounts,
                    'activeChannel': activeChannel,
                } %}
            {% endif %}

            {% include 'dashboard/_files_sidebar_panel.html.twig' with {
                'activeChannel': activeChannel,
            } %}

    </main>

        {% include 'partials/_footer.html.twig' %}
</div>
{% endblock %}
