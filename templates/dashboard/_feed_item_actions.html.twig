<div class="feed-item-actions">
    <button type="button" class="btn-actions-toggle"
            title="{{ 'Actions'|trans }}" aria-label="{{ 'Actions du message'|trans }}">•••
    </button>
    <div class="feed-item-actions-list">
        {% if messageObject is not defined or not messageObject or not messageObject.poll %}
            <button class="btn-reply-subtle btn-quote-reply"
                    data-reply-username="{{ username|escape('html_attr') }}"
                    data-reply-content="{{ message|escape('html_attr') }}"
                    title="{{ 'Répondre'|trans }}">
                {{ ux_icon('heroicons:arrow-uturn-left', {class: 'action-icon', style: 'width: 11px; height: 11px;'}) }}
                <span>{{ 'Répondre'|trans }}</span>
            </button>
        {% endif %}
        {% if message_id|default(0) > 0 %}
            <button class="btn-reply-subtle btn-subchannel-subtle"
                    hx-post="{{ path('app_message_create_subchannel', {id: message_id}) }}"
                    title="{{ 'Créer un sous-canal'|trans }}">
                {{ ux_icon('heroicons:rectangle-stack', {class: 'action-icon', style: 'width: 11px; height: 11px;'}) }}
                <span>{{ 'Sous-canal'|trans }}</span>
            </button>
        {% endif %}
        {% if message_id|default(0) > 0 %}
            <div class="add-reaction-trigger-container"
                 style="position: relative; display: inline-flex; align-items: center;">
                <button class="btn-reply-subtle btn-add-reaction"
                        title="{{ 'Réagir'|trans }}">
                    {{ ux_icon('heroicons:face-smile', {class: 'action-icon', style: 'width: 11px; height: 11px;'}) }}
                    <span>{{ 'Réagir'|trans }}</span>
                </button>
                <div class="reaction-picker" id="reaction-picker-{{ message_id }}">
                    <div class="reaction-picker-standards">
                        {% for picker_emoji in ['👍', '❤️', '😂', '😮', '😢', '🎉'] %}
                            <button class="reaction-picker-btn"
                                    hx-post="{{ path('app_message_react', {id: message_id, emoji: picker_emoji}) }}"
                                    hx-target="closest .feed-item"
                                    hx-swap="morph transition:false">
                                {{ picker_emoji }}
                            </button>
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% endif %}
        {% if message_id|default(0) > 0 %}
            <button class="btn-reply-subtle btn-edit-subtle"
                    hx-get="{{ path('app_message_edit_form', {id: message_id}) }}"
                    hx-target="closest .feed-item" hx-swap="morph transition:false" title="{{ 'Modifier'|trans }}">
                {{ ux_icon('heroicons:pencil-square', {class: 'action-icon', style: 'width: 11px; height: 11px;'}) }}
                <span>{{ 'Modifier'|trans }}</span>
            </button>
            <button class="btn-reply-subtle btn-delete-subtle"
                    hx-post="{{ path('app_message_delete', {id: message_id}) }}"
                    hx-confirm="{{ 'Voulez-vous vraiment supprimer ce message ?'|trans }}"
                    hx-swap="none"
                    title="{{ 'Supprimer'|trans }}">
                {{ ux_icon('heroicons:trash', {class: 'action-icon', style: 'width: 11px; height: 11px; color: var(--accent-red, #ff5b5b);'}) }}
                <span style="color: var(--accent-red, #ff5b5b);">{{ 'Supprimer'|trans }}</span>
            </button>
        {% endif %}
        {% if message_id|default(0) > 0 and messageChannel and messageChannel.creator == app.user %}
            <button class="btn-reply-subtle btn-pin-subtle"
                    hx-post="{{ isThisMessagePinned ? path('app_message_unpin', {id: message_id}) : path('app_message_pin', {id: message_id}) }}"
                    hx-target="#pinned-banner-container"
                    hx-swap="innerHTML transition:false"
                    title="{{ isThisMessagePinned ? 'Désépingler'|trans : 'Épingler'|trans }}">
                <span class="action-icon"
                      style="font-size: 11px; line-height: 1; display: inline-flex; align-items: center; justify-content: center; width: 11px; height: 11px;">📌</span>
                <span>{{ isThisMessagePinned ? 'Désépingler'|trans : 'Épingler'|trans }}</span>
            </button>
        {% endif %}
        {% if message_id|default(0) > 0 and app.user %}
            {% set isSaved = messageObject is defined and messageObject and app.user.savedMessages.contains(messageObject) %}
            <button class="btn-reply-subtle btn-save-subtle {{ isSaved ? 'is-saved' : '' }}"
                    hx-post="{{ path('app_message_save_toggle', {id: message_id}) }}"
                    hx-target="closest .feed-item"
                    hx-swap="morph transition:false"
                    title="{{ isSaved ? 'Retirer des favoris'|trans : 'Enregistrer dans les favoris'|trans }}">
                <span class="action-icon"
                      style="font-size: 11px; line-height: 1; display: inline-flex; align-items: center; justify-content: center; width: 11px; height: 11px;">⭐</span>
                <span>{{ isSaved ? 'Enregistré'|trans : 'Enregistrer'|trans }}</span>
            </button>
        {% endif %}
    </div>
</div>
