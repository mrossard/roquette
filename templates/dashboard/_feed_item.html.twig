{% set messageObject = messageObject|default(null) %}
{% if messageObject is null and message is defined and message is not empty %}
    {% if message.content is defined %}
        {% set messageObject = message %}
    {% endif %}
{% endif %}

{% if message is defined and message is same as(messageObject) %}
    {% set message = messageObject.content %}
{% else %}
    {% set message = message|default(messageObject ? messageObject.content : '') %}
{% endif %}

{% set author = author|default(messageObject ? messageObject.author : null) %}
{% set timestamp = timestamp|default(messageObject ? messageObject.createdAt : null) %}
{% set message_id = message_id|default(messageObject ? messageObject.id : 0) %}
{% set updated_at = updated_at|default(messageObject ? messageObject.updatedAt : null) %}
{% set fileName = fileName|default(messageObject ? messageObject.fileName : null) %}
{% set fileSize = fileSize|default(messageObject ? messageObject.fileSize : null) %}
{% set filePath = filePath|default(messageObject ? messageObject.filePath : null) %}
{% set mimeType = mimeType|default(messageObject ? messageObject.mimeType : null) %}
{% set user_hue = author ? author.hue : 200 %}
{% set username = (messageObject and messageObject.customAuthorName) ? messageObject.customAuthorName : (author ? (author.displayName|default(author.username)) : (user|default('Utilisateur'))) %}
{% set messageChannel = messageObject ? messageObject.getChannel() : null %}
{% set isThisMessagePinned = messageChannel and messageChannel.pinnedMessage == messageObject %}
{% set isMeMessage = message is not null and (message starts with '/me ' or message == '/me') %}
{% set pollHasVotes = messageObject and messageObject.poll and messageObject.poll.totalVotes > 0 %}
<div
    class="feed-item {{ (oob|default(false) or no_fade|default(false)) ? '' : 'fade-in' }} {{ isThisMessagePinned ? 'is-pinned' : '' }} {{ isMeMessage ? 'is-me-message' : '' }}"
     id="feed-item-{{ message_id|default('') }}" {% if oob|default(false) %}hx-swap-oob="morph"{% endif %}
     style="--user-hue: {{ user_hue }};" data-message-id="{{ message_id|default('') }}"
     data-author-username="{{ author ? author.username : '' }}" data-raw-content="{{ message|default('') }}"
     data-file-name="{{ fileName|default('') }}" data-file-size="{{ fileSize|default('') }}"
    data-poll-has-votes="{{ pollHasVotes ? '1' : '0' }}"
    {% if isLast|default(false) %}data-last-message="true"{% endif %}>
    {% if isMeMessage %}
        <div class="feed-item-header">
            <div class="feed-item-me-content">
                <span
                    class="feed-item-time">{% if timestamp|date('Y-m-d') != 'now'|date('Y-m-d') %}{{ timestamp|date('d/m/Y') }} {% endif %}{{ timestamp|date('H:i') }}</span>
                {% if author and author.username != constant('App\\\\Entity\\\\User::ROBOT_USERNAME') %}
                    <a href="{{ path('app_dm_open', {username: author.username}) }}" class="feed-item-user-link"
                       title="{{ 'Discuter en privé avec %username% (%status%)'|trans({'%username%': username, '%status%': author.statusLabel}) }}">
                        <span class="feed-item-user">{{ username|wrap_emojis }}</span>
                    </a>
                {% else %}
                    <span class="feed-item-user">{{ username|wrap_emojis }}</span>
                {% endif %}
                <span class="feed-item-me-text">
                    {% set me_content = message|slice(4) %}
                    {{ me_content|format_message }}
                </span>
                {% if updated_at is defined and updated_at %}
                    <span class="feed-item-edited-indicator"
                          title="{{ 'Modifié le'|trans }} {{ updated_at|date('d/m/Y H:i') }}">(modifié)</span>
                {% endif %}
            </div>
            {% include 'dashboard/_feed_item_actions.html.twig' %}
        </div>
        {% set message_reactions = messageObject is defined and messageObject ? messageObject.getGroupedReactions(app.user) : {} %}
        {% if message_reactions is not empty %}
            <div class="feed-item-body" style="padding: 0; border: none; background: none; box-shadow: none;">
                {% include 'dashboard/_feed_item_reactions.html.twig' %}
            </div>
        {% endif %}
    {% else %}
        <div class="feed-item-header">
            <div class="feed-item-user-container">
                {% if author and author.username != 'robot-roquette' %}
                    <a href="{{ path('app_dm_open', {username: author.username}) }}" class="feed-item-user-link"
                       title="{{ 'Discuter en privé avec %username% (%status%)'|trans({'%username%': username, '%status%': author.statusLabel}) }}">
                        <div class="avatar-container">
                            {% if messageObject and messageObject.customAuthorAvatar %}
                                {% if messageObject.customAuthorAvatar starts with 'http' or messageObject.customAuthorAvatar starts with '/' %}
                                    <img src="{{ messageObject.customAuthorAvatar }}" class="feed-item-avatar-img"
                                         style="width: 24px; height: 24px; object-fit: cover; border-radius: 50%;">
                                {% else %}
                                    <span class="feed-item-avatar">{{ messageObject.customAuthorAvatar }}</span>
                                {% endif %}
                            {% else %}
                                <span class="feed-item-avatar">{{ username|slice(0, 1)|upper }}</span>
                            {% endif %}
                            <span class="status-dot-overlay {{ author.status }}" data-username="{{ author.username }}" data-status-override="{{ author.statusOverride|default('auto') }}" data-last-active="{{ author.lastActiveAt ? author.lastActiveAt.timestamp : '' }}" title="{{ author.statusLabel }}"></span>
                        </div>
                        <span class="feed-item-user">{{ username|wrap_emojis }}</span>
                    </a>
                {% else %}
                    <div class="avatar-container">
                        {% if messageObject and messageObject.customAuthorAvatar %}
                            {% if messageObject.customAuthorAvatar starts with 'http' or messageObject.customAuthorAvatar starts with '/' %}
                                <img src="{{ messageObject.customAuthorAvatar }}" class="feed-item-avatar-img"
                                     style="width: 24px; height: 24px; object-fit: cover; border-radius: 50%;">
                            {% else %}
                                <span class="feed-item-avatar">{{ messageObject.customAuthorAvatar }}</span>
                            {% endif %}
                        {% else %}
                            <span class="feed-item-avatar">{{ username|slice(0, 1)|upper }}</span>
                        {% endif %}
                        {% if author %}
                            <span class="status-dot-overlay {{ author.status }}" data-username="{{ author.username }}"
                                  data-status-override="{{ author.statusOverride|default('auto') }}"
                                  data-last-active="{{ author.lastActiveAt ? author.lastActiveAt.timestamp : '' }}"
                                  title="{{ author.statusLabel }}"></span>
                        {% endif %}
                    </div>
                    <span class="feed-item-user">{{ username|wrap_emojis }}</span>
                {% endif %}
            </div>
            <span
                class="feed-item-time">{% if timestamp|date('Y-m-d') != 'now'|date('Y-m-d') %}{{ timestamp|date('d/m/Y') }} {% endif %}{{ timestamp|date('H:i') }}</span>
            {% if updated_at is defined and updated_at %}
                <span class="feed-item-edited-indicator"
                      title="{{ 'Modifié le'|trans }} {{ updated_at|date('d/m/Y H:i') }}">(modifié)</span>
            {% endif %}
            {% if isThisMessagePinned %}
                <span class="feed-item-pinned-indicator"
                      title="{{ 'Message épinglé dans ce canal'|trans }}">📌 {{ 'Épinglé'|trans }}</span>
            {% endif %}
            {% include 'dashboard/_feed_item_actions.html.twig' %}
        </div>
        <div class="feed-item-body">
            {% if messageObject is defined and messageObject and messageObject.poll %}
                {% include 'dashboard/_poll.html.twig' with { poll: messageObject.poll } %}
            {% elseif message is defined and message is not empty and message != '' %}
                {% if is_html|default(false) %}
                    {{ message|raw }}
                {% else %}
                    <p>{{ message|format_message }}</p>
                {% endif %}
                {% set links = message|extract_external_links %}
                {% for link in links %}
                    {% set cachedResult = get_cached_link_preview(link) %}
                    {% if cachedResult is not null %}
                        {% if cachedResult.status == 'success' %}
                            {% include 'dashboard/_link_preview.html.twig' with {
                                url: cachedResult.preview.url,
                                title: cachedResult.preview.title,
                                description: cachedResult.preview.description,
                                image: cachedResult.preview.image,
                                siteName: cachedResult.preview.siteName
                            } %}
                        {% endif %}
                    {% else %}
                        <div hx-get="{{ path('app_api_link_preview', {url: link}) }}"
                             hx-trigger="intersect once"
                             hx-swap="outerHTML transition:false"
                             class="link-preview-placeholder">
                        </div>
                    {% endif %}
                {% endfor %}
            {% endif %}

            {% if fileName is defined and fileName %}
                <div class="message-attachment">
                    <span class="attachment-icon">📎</span>
                    <div class="attachment-details">
                        <a href="{{ path('app_file_download', {id: message_id}) }}" class="attachment-link" hx-boost="false" target="_blank" download>
                            {{ fileName }}
                        </a>
                        <span class="attachment-size">{{ fileSize|format_bytes }}</span>
                    </div>
                </div>
                {% set fileExt = fileName|split('.')|last|lower %}
                {% set isImage = (mimeType is defined and mimeType and mimeType starts with 'image/') or fileExt in ['jpg', 'jpeg', 'png', 'gif', 'webp', 'svg'] %}
                {% set isAudio = (mimeType is defined and mimeType and mimeType starts with 'audio/') or fileExt in ['mp3', 'wav', 'ogg', 'm4a', 'aac'] %}
                {% set isVideo = (mimeType is defined and mimeType and mimeType starts with 'video/') or fileExt in ['mp4', 'webm', 'ogg', 'mov', 'avi'] %}
                {% set isPdf = (mimeType is defined and mimeType and mimeType == 'application/pdf') or fileExt == 'pdf' %}
                {% set isText = (mimeType is defined and mimeType and mimeType starts with 'text/') or fileExt in ['txt', 'log', 'md', 'html', 'css', 'js', 'json', 'php', 'yml', 'yaml', 'xml'] %}
                {% if isImage %}
                    <div class="attachment-preview image-preview-container">
                        <img src="{{ path('app_file_preview', {id: message_id}) }}" alt="{{ fileName }}"
                             class="preview-image" hx-get="{{ path('app_lightbox', {id: message_id}) }}"
                             hx-target="#modal-container" hx-trigger="click" style="cursor:pointer">
                    </div>
                {% elseif isAudio %}
                    <div class="attachment-preview audio-preview-container">
                        <audio controls preload="none" class="preview-audio">
                            <source src="{{ path('app_file_preview', {id: message_id}) }}" {% if mimeType is defined and mimeType %}type="{{ mimeType }}"{% endif %}>
                            {{ 'Votre navigateur ne supporte pas la lecture audio.'|trans }}
                        </audio>
                    </div>
                {% elseif isVideo %}
                    <div class="attachment-preview video-preview-container">
                        <video controls preload="metadata" class="preview-video">
                            <source src="{{ path('app_file_preview', {id: message_id}) }}" {% if mimeType is defined and mimeType %}type="{{ mimeType }}"{% endif %}>
                            {{ 'Votre navigateur ne supporte pas la lecture vidéo.'|trans }}
                        </video>
                    </div>
                {% elseif isPdf %}
                    <div class="attachment-preview pdf-preview-container">
                        <a href="{{ path('app_file_preview', {id: message_id}) }}" target="_blank" class="btn-preview-link">
                            <span class="btn-preview-icon">👁️</span> {{ 'Ouvrir le PDF'|trans }}
                        </a>
                    </div>
                {% elseif isText %}
                    <div class="attachment-preview text-preview-container" id="text-preview-wrapper-{{ message_id }}">
                        <button type="button" class="btn-preview-link text-preview-toggle"
                                hx-get="{{ path('app_file_text_preview', {id: message_id}) }}"
                                hx-target="#text-preview-wrapper-{{ message_id }}"
                                hx-swap="outerHTML">
                            <span class="btn-preview-icon">👁️</span> {{ 'Prévisualiser le texte'|trans }}
                        </button>
                    </div>
                {% endif %}
            {% endif %}
            {% if messageObject %}
                {% set subChannel = get_subchannel(messageObject) %}
                {% if subChannel and (channel is not defined or channel is null or subChannel.id != channel.id) and (activeChannel is not defined or activeChannel is null or subChannel.id != activeChannel.id) %}
                    <div class="subchannel-indicator"
                         style="margin-top: 0.75rem; display: flex; align-items: center; gap: 0.5rem; background: var(--accent-cyan-glow); border: 1px solid var(--accent-cyan); padding: 0.5rem 0.75rem; border-radius: 0.375rem; width: fit-content; font-size: 0.85rem;">
                        <span style="font-size: 1.1rem; line-height: 1; color: var(--accent-cyan);">⊞</span>
                        <span>{{ 'Sous-canal existant :'|trans }} <strong>{{ subChannel.name }}</strong></span>
                        <a href="{{ path('app_channel', {slug: subChannel.slug}) }}" class="btn-subchannel-join"
                           hx-boost="false"
                           style="margin-left: 0.5rem; background: var(--accent-cyan); color: var(--text-primary); text-decoration: none; padding: 0.25rem 0.6rem; border-radius: 0.25rem; font-weight: 600; font-size: 0.8rem; transition: background 0.2s;">
                            {{ 'Rejoindre'|trans }}
                        </a>
                    </div>
                {% endif %}
            {% endif %}
            {% include 'dashboard/_feed_item_reactions.html.twig' %}
        </div>
    {% endif %}
</div>
