<div class="poll-composer glass-panel"
     style="{% if not pollComposerOpen|default(false) %}display: none;{% endif %} padding: 1rem; margin-bottom: 0.75rem; border-radius: 0.75rem; border: 1px solid rgba(255, 255, 255, 0.1); background: rgba(255, 255, 255, 0.03);">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
        <span style="font-weight: 600; font-size: 0.95rem; color: var(--accent-cyan);">📊 Créer un sondage</span>
        <button type="button"
                hx-get="{{ path('app_composer_toggle', {slug: activeChannel.slug, open: 0}) }}"
                hx-include="closest form"
                hx-target="closest form"
                hx-swap="morph transition:false"
                title="Fermer"
                style="background: none; border: none; cursor: pointer; color: var(--text-muted); font-size: 1.1rem; display: flex; align-items: center; justify-content: center;">
            ✕
        </button>
    </div>

    <div style="display: flex; flex-direction: column; gap: 0.75rem;">
        <div>
            <label for="poll_question" style="display: block; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.25rem;">Question</label>
            <input type="text" id="poll_question" name="poll_question" placeholder="Posez votre question..."
                   class="input-sidebar"
                   value="{{ pollQuestion|default('') }}"
                   {% if pollComposerOpen|default(false) %}required{% endif %} />
        </div>

        <div
            style="display: flex; align-items: center; justify-content: space-between; gap: 1rem; background: var(--bg-input); padding: 0.5rem 0.75rem; border-radius: 0.5rem; border: 1px solid var(--border-input);">
            <label for="allow_multiple" style="font-size: 0.85rem; color: var(--text-color); cursor: pointer; user-select: none; margin-bottom: 0; font-weight: 500;">Autoriser plusieurs réponses</label>
            <label class="switch" style="position: relative; display: inline-block; width: 44px; height: 24px; flex-shrink: 0; margin-bottom: 0;">
                <input type="checkbox" id="allow_multiple" name="allow_multiple" value="1" style="opacity: 0; width: 0; height: 0;"
                       {% if allowMultiple|default(false) %}checked{% endif %}>
                <span class="slider round"
                      style="position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: var(--bg-input); transition: .3s; border-radius: 24px; border: 1px solid var(--border-input);"></span>
            </label>
        </div>

        <div>
            <label style="display: block; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.25rem;">Options de réponse</label>
            <div id="poll-options-container" class="poll-options-list"
                 style="display: flex; flex-direction: column; gap: 0.5rem;">
                {% set optionsToRender = pollOptions|default(['', '']) %}
                {% if optionsToRender|length == 0 %}
                    {% set optionsToRender = ['', ''] %}
                {% elseif optionsToRender|length == 1 %}
                    {% set optionsToRender = [optionsToRender[0], ''] %}
                {% endif %}
                {% for index, optionVal in optionsToRender %}
                    <div style="display: flex; gap: 0.5rem; align-items: center;">
                        <input type="text" name="poll_options[]" placeholder="Option {{ index + 1 }}"
                               class="poll-option-input input-sidebar" style="flex: 1;"
                               {% if pollComposerOpen|default(false) and index < 2 %}required{% endif %}
                               value="{{ optionVal }}"/>
                        <span style="width: 24px;"></span>
                    </div>
                {% endfor %}
            </div>
            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 1rem;">
                <button type="button" class="btn-format"
                        hx-post="{{ path('app_poll_option_field') }}"
                        hx-vals="js:{count: getPollOptionCount('poll-options-container'), inputClass: 'poll-option-input', isRequired: 0}"
                        hx-target="#poll-options-container"
                        hx-swap="beforeend"
                        style="font-size: 0.8rem; padding: 0.4rem 0.8rem; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 0.5rem; color: var(--text-color); cursor: pointer; display: flex; align-items: center; gap: 0.25rem;">
                    <span>+</span> Ajouter une option
                </button>

                <button type="submit" class="btn-submit" style="padding: 0.4rem 1.2rem; font-size: 0.85rem; border-radius: 0.5rem; margin-top: 0;">
                    Publier
                </button>
            </div>
        </div>
    </div>
</div>
