<form hx-post="{{ path('app_publish', {slug: activeChannel.slug}) }}"
      hx-swap="morph transition:false"
      enctype="multipart/form-data"
      class="input-form chat-message-form">
    {% for label, messages in app.flashes %}
        {% for msg in messages %}
            <div class="alert-{{ label == 'error' ? 'error' : 'success' }} fade-in" style="margin-bottom: 0.75rem; background: rgba({{ label == 'error' ? '239, 68, 68' : '16, 185, 129' }}, 0.1); border: 1px solid rgba({{ label == 'error' ? '239, 68, 68' : '16, 185, 129' }}, 0.2); color: var(--accent-{{ label == 'error' ? 'red' : 'green' }}); border-radius: 0.75rem; padding: 0.75rem 1rem; font-size: 0.9rem; font-weight: 500;">
                {{ msg }}
            </div>
        {% endfor %}
    {% endfor %}
    {% if giphyPreviews is defined and giphyPreviews is not empty %}
        <div class="giphy-preview-panel glass-panel">
            <div class="giphy-preview-header">
                <span class="giphy-preview-title">👾 Choisir un GIF pour "{{ giphyQuery }}" :</span>
                <button type="button" class="btn-giphy-cancel"
                        hx-post="{{ path('app_publish', {slug: activeChannel.slug}) }}"
                        hx-vals='{"message": ""}'
                        hx-target="closest form"
                        hx-swap="morph transition:false"
                        title="Annuler">
                    Annuler
                </button>
            </div>
            <div class="giphy-preview-grid">
                {% for gif in giphyPreviews %}
                    <div class="giphy-preview-item"
                         hx-post="{{ path('app_publish', {slug: activeChannel.slug}) }}"
                         hx-vals='{"message": "![giphy {{ giphyQuery|escape('js') }}]({{ gif.url }})"}'
                         hx-target="closest form"
                         hx-swap="morph transition:false">
                        <img src="{{ gif.preview }}" alt="GIF Preview" class="giphy-preview-img">
                        <div class="giphy-preview-overlay">
                            <span class="giphy-send-icon">📤</span>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% elseif giphyPreviews is defined %}
        <div class="giphy-preview-panel glass-panel" style="padding: 0.5rem; text-align: center; font-size: 0.85rem; color: var(--accent-red, #ff5b5b); display: flex; justify-content: space-between; align-items: center; gap: 1rem;">
            <span>❌ Aucun GIF trouvé pour "{{ giphyQuery }}".</span>
            <button type="button" class="btn-giphy-cancel"
                    hx-post="{{ path('app_publish', {slug: activeChannel.slug}) }}"
                    hx-vals='{"message": ""}'
                    hx-target="closest form"
                    hx-swap="morph transition:false"
                    title="Fermer">
                Fermer
            </button>
        </div>
    {% endif %}

    <!-- Poll Composer Panel -->
    <div class="poll-composer glass-panel" style="display: none; padding: 1rem; margin-bottom: 0.75rem; border-radius: 0.75rem; border: 1px solid rgba(255, 255, 255, 0.1); background: rgba(255, 255, 255, 0.03);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
            <span style="font-weight: 600; font-size: 0.95rem; color: var(--accent-cyan);">📊 Créer un sondage</span>
            <button type="button" onclick="togglePollComposer()" title="Fermer" style="background: none; border: none; cursor: pointer; color: var(--text-muted); font-size: 1.1rem; display: flex; align-items: center; justify-content: center;">✕</button>
        </div>

        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
            <div>
                <label for="poll_question" style="display: block; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.25rem;">Question</label>
                <input type="text" id="poll_question" name="poll_question" placeholder="Posez votre question..." class="input-sidebar" />
            </div>

            <div style="display: flex; align-items: center; justify-content: space-between; gap: 1rem; background: rgba(0, 0, 0, 0.2); padding: 0.5rem 0.75rem; border-radius: 0.5rem; border: 1px solid var(--border-glass);">
                <label for="allow_multiple" style="font-size: 0.85rem; color: var(--text-color); cursor: pointer; user-select: none; margin-bottom: 0; font-weight: 500;">Autoriser plusieurs réponses</label>
                <label class="switch" style="position: relative; display: inline-block; width: 44px; height: 24px; flex-shrink: 0; margin-bottom: 0;">
                    <input type="checkbox" id="allow_multiple" name="allow_multiple" value="1" style="opacity: 0; width: 0; height: 0;"
                           onchange="this.nextElementSibling.style.backgroundColor = this.checked ? 'var(--accent-cyan)' : 'rgba(255, 255, 255, 0.1)';">
                    <span class="slider round" style="position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(255, 255, 255, 0.1); transition: .3s; border-radius: 24px; border: 1px solid var(--border-glass);"></span>
                </label>
            </div>

            <div>
                <label style="display: block; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.25rem;">Options de réponse</label>
                <div id="poll-options-container" class="poll-options-list"
                     style="display: flex; flex-direction: column; gap: 0.5rem;">
                    <div style="display: flex; gap: 0.5rem; align-items: center;">
                        <input type="text" name="poll_options[]" placeholder="Option 1" class="poll-option-input input-sidebar" style="flex: 1;" />
                        <span style="width: 24px;"></span>
                    </div>
                    <div style="display: flex; gap: 0.5rem; align-items: center;">
                        <input type="text" name="poll_options[]" placeholder="Option 2" class="poll-option-input input-sidebar" style="flex: 1;" />
                        <span style="width: 24px;"></span>
                    </div>
                </div>
                <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 1rem;">
                    <button type="button" class="btn-format"
                            hx-post="{{ path('app_poll_option_field') }}"
                            hx-vals="js:{count: document.getElementById('poll-options-container').querySelectorAll('input').length, inputClass: 'poll-option-input', isRequired: 0}"
                            hx-target="#poll-options-container"
                            hx-swap="beforeend"
                            style="font-size: 0.8rem; padding: 0.4rem 0.8rem; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 0.5rem; color: var(--text-color); cursor: pointer; display: flex; align-items: center; gap: 0.25rem;">
                        <span>+</span> Ajouter une option
                    </button>

                    <button type="submit" class="btn-submit" style="padding: 0.4rem 1.2rem; font-size: 0.85rem; border-radius: 0.5rem; margin-top: 0;">
                        Publier
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Formatting Toolbar -->
    <div class="formatting-toolbar">
        <button type="button" class="btn-format" data-markdown="bold" title="{{ 'Gras (**)'|trans }}">
            <span class="icon">B</span>
        </button>
        <button type="button" class="btn-format" data-markdown="italic" title="{{ 'Italique (*)'|trans }}">
            <span class="icon">I</span>
        </button>
        <button type="button" class="btn-format" data-markdown="strikethrough"
                title="{{ 'Barré (~~)'|trans }}">
            <span class="icon">S</span>
        </button>
        <button type="button" class="btn-format" data-markdown="quote"
                title="{{ 'Citation (&gt;)'|trans }}">
            <span class="icon">”</span>
        </button>
        <button type="button" class="btn-format" data-markdown="code"
                title="{{ 'Code en ligne (`)'|trans }}">
            <span class="icon">&lt;/&gt;</span>
        </button>
        <button type="button" class="btn-format" data-markdown="codeblock"
                title="{{ 'Bloc de code (```)'|trans }}">
            <span class="icon">code</span>
        </button>
        <button type="button" class="btn-format" data-markdown="link"
                title="{{ 'Lien [texte](url)'|trans }}">
            <span class="icon">🔗</span>
        </button>
        <button type="button" class="btn-format btn-poll-toggle" onclick="togglePollComposer()"
                title="{{ 'Créer un sondage'|trans }}">
            <span class="icon">📊</span>
        </button>

        <div class="toolbar-tabs" style="margin-left: auto; display: flex; gap: 4px;">
            <button type="button" class="btn-format active" id="message-btn-edit-tab"
                    hx-on:click="this.closest('.chat-message-form').classList.remove('show-preview')"
                    title="{{ 'Écrire'|trans }}">{{ 'Écrire'|trans }}</button>
            <button type="button" class="btn-format" id="message-btn-preview-tab"
                    hx-post="{{ path('app_api_message_preview') }}"
                    hx-include="#message"
                    hx-target="#message-preview"
                    hx-swap="innerHTML transition:false"
                    hx-on:click="this.closest('.chat-message-form').classList.add('show-preview')"
                    title="{{ 'Aperçu'|trans }}">{{ 'Aperçu'|trans }}</button>
        </div>
    </div>

    <div class="chat-input-container">
        <!-- File upload preview -->
        <div id="file-preview-container" class="file-preview-container" style="display: none; flex-direction: column; align-items: stretch; gap: 0.5rem;">
            <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
                <div class="file-preview-info">
                    <span class="file-preview-icon">📎</span>
                    <span id="file-preview-name" class="file-preview-name"></span>
                </div>
                <button type="button" id="btn-clear-file" class="btn-clear-file"
                        title="{{ 'Supprimer le fichier'|trans }}">✕
                </button>
            </div>
            <div id="file-upload-progress" class="upload-progress-wrapper" style="display: none; width: 100%;">
                <div class="upload-progress-bar-bg" style="background: rgba(255, 255, 255, 0.1); border-radius: 4px; height: 6px; overflow: hidden; width: 100%;">
                    <div id="file-upload-progress-bar" class="upload-progress-bar" style="background: var(--accent-cyan); height: 100%; width: 0%; transition: width 0.15s ease;"></div>
                </div>
                <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem;">
                    <span>{{ 'Envoi en cours...'|trans }}</span>
                    <span id="file-upload-progress-percent" class="upload-progress-percent">0%</span>
                </div>
            </div>
        </div>

        <label for="message" class="sr-only">{{ 'Message'|trans }}</label>
        <div class="message-input-wrapper">
            <input type="file" id="file-upload" name="file" style="display: none;" />
            <textarea id="message" name="message" required
                      placeholder="{{ 'Saisissez votre message dans #%name%...'|trans({'%name%': activeChannel.name}) }}"
                      rows="1"></textarea>
            <div id="message-preview" class="message-preview-box" style="display: none;"></div>


            <div class="input-actions-wrapper">
                <button type="button" class="btn-file-toggle" onclick="document.getElementById('file-upload').click()"
                        title="{{ 'Joindre un fichier'|trans }}" aria-label="{{ 'Joindre un fichier'|trans }}">
                    {{ ux_icon('heroicons:paper-clip', {class: 'btn-icon', 'aria-hidden': 'true'}) }}
                </button>
                <button type="button" class="btn-emoji-toggle" data-emoji-target="#message"
                        title="{{ 'Ajouter un émoji'|trans }}" aria-label="{{ 'Ajouter un émoji'|trans }}">
                    {{ ux_icon('heroicons:face-smile', {'aria-hidden': 'true'}) }}
                </button>
            </div>
        </div>
        <button type="submit" class="btn-publish-compact" title="{{ 'Diffuser'|trans }}"
                aria-label="{{ 'Diffuser le message'|trans }}">
            {{ ux_icon('heroicons:paper-airplane', {class: 'btn-icon', 'aria-hidden': 'true'}) }}
        </button>
    </div>
</form>
