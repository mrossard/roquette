<dialog id="global-search-modal" class="modal-backdrop-dialog"
        style="align-items: flex-start; padding-top: 10vh; z-index: 1100;">
    <div class="modal-container global-search-modal-container"
         style="max-width: 700px; width: 90%; border-radius: 1rem; overflow: hidden; display: flex; flex-direction: column; max-height: 75vh;">
        <form hx-get="{{ path('app_global_search') }}"
              hx-target="#global-search-results"
              hx-swap="innerHTML transition:false"
              style="display: flex; gap: 0.75rem; align-items: center; padding: 1rem; border-bottom: 1px solid var(--border-glass); width: 100%; margin: 0;">
            <button type="submit" style="background: transparent; border: none; font-size: 1.25rem; opacity: 0.8; cursor: pointer; padding: 0; display: flex; align-items: center;">🔍</button>
            <input type="text"
                   id="global-search-input"
                   name="q"
                   placeholder="Rechercher des messages, canaux ou pseudos... (ex: in:general from:jean)"
                   style="flex-grow: 1; background: transparent; border: none; outline: none; color: var(--text-primary); font-size: 1.05rem;"
                   autocomplete="off">
            <button type="button" class="btn-close-global-search" onclick="closeGlobalSearch()" style="background: transparent; border: none; color: var(--text-muted); cursor: pointer; font-size: 1.25rem; line-height: 1; padding: 0.25rem 0.5rem; transition: color 0.2s;">✕</button>
        </form>

        <div class="search-builder-trigger-container"
             style="padding: 0.5rem 1rem; border-bottom: 1px solid var(--border-glass); display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;">
            <button type="button" id="btn-toggle-search-builder" onclick="toggleSearchBuilder()" style="background: none; border: none; color: var(--accent-cyan); font-size: 0.85rem; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 0.25rem; outline: none;">
                <span class="builder-toggle-icon">▶</span> Assistant de filtres
            </button>
        </div>

        <div id="search-builder-panel" data-users-url="{{ path('app_api_users_options') }}"
             style="display: none; padding: 1rem; border-bottom: 1px solid var(--border-glass); background: var(--bg-card); flex-direction: column; gap: 0.75rem; width: 100%; flex-shrink: 0; box-sizing: border-box;">
            <div style="display: flex; gap: 1rem; flex-wrap: wrap; width: 100%;">
                <!-- Filter by Author -->
                <div style="flex: 1; min-width: 180px;">
                    <label for="builder-from" style="display: block; font-size: 0.75rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; margin-bottom: 0.35rem;">Auteur (from:)</label>
                    <select id="builder-from" class="builder-select" onchange="updateSearchQueryFromBuilder()">
                        <option value="">Tous les utilisateurs</option>
                    </select>
                </div>
                <!-- Filter by Channel -->
                <div style="flex: 1; min-width: 180px;">
                    <label for="builder-in" style="display: block; font-size: 0.75rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; margin-bottom: 0.35rem;">Canal (in:)</label>
                    <select id="builder-in" class="builder-select" onchange="updateSearchQueryFromBuilder()">
                        <option value="">Tous les canaux</option>
                    </select>
                </div>
                <!-- Filter by attachment type -->
                <div style="flex: 1; min-width: 180px;">
                    <label for="builder-has" style="display: block; font-size: 0.75rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; margin-bottom: 0.35rem;">Pièce jointe (has:)</label>
                    <select id="builder-has" class="builder-select" onchange="updateSearchQueryFromBuilder()">
                        <option value="">Peu importe</option>
                        <option value="file">Tout fichier</option>
                        <option value="image">Image</option>
                        <option value="video">Vidéo</option>
                        <option value="audio">Audio</option>
                        <option value="pdf">PDF</option>
                    </select>
                </div>
            </div>
            <!-- Simple Text Query -->
            <div style="width: 100%;">
                <label for="builder-text" style="display: block; font-size: 0.75rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; margin-bottom: 0.35rem;">Mots-clés recherchés</label>
                <input type="text" id="builder-text" oninput="updateSearchQueryFromBuilder()"
                       placeholder="Tapez votre recherche de texte ici..."
                       style="width: 100%; padding: 0.4rem 0.6rem; background: var(--bg-card); border: 1px solid var(--border-glass); border-radius: 0.375rem; color: var(--text-primary); outline: none; box-sizing: border-box;"
                       autocomplete="off">
            </div>
        </div>

        <div id="global-search-results" class="global-search-modal-body" style="overflow-y: auto; padding: 1rem; flex-grow: 1; min-height: 200px;">
            {# Initial state / tips #}
            <div class="global-search-tips">
                <h4 class="tips-title" style="font-size: 0.9rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.75rem;">💡 Astuces pour affiner votre recherche :</h4>
                <ul class="tips-list" style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.85rem; color: var(--text-secondary);">
                    <li style="display: flex; align-items: center; gap: 8px;">
                        <kbd
                            style="background: var(--bg-card); padding: 2px 6px; border-radius: 4px; border: 1px solid var(--border-glass); font-family: monospace; font-size: 0.8rem; color: var(--accent-cyan);">from:@pseudo</kbd>
                        <span>Filtrer par auteur</span>
                    </li>
                    <li style="display: flex; align-items: center; gap: 8px;">
                        <kbd
                            style="background: var(--bg-card); padding: 2px 6px; border-radius: 4px; border: 1px solid var(--border-glass); font-family: monospace; font-size: 0.8rem; color: var(--accent-cyan);">in:#canal</kbd>
                        <span>Filtrer par canal ou message direct</span>
                    </li>
                    <li style="display: flex; align-items: center; gap: 8px;">
                        <kbd
                            style="background: var(--bg-card); padding: 2px 6px; border-radius: 4px; border: 1px solid var(--border-glass); font-family: monospace; font-size: 0.8rem; color: var(--accent-cyan);">has:file</kbd>
                        <span>Messages contenant un fichier joint</span>
                    </li>
                    <li style="display: flex; align-items: center; gap: 8px;">
                        <kbd
                            style="background: var(--bg-card); padding: 2px 6px; border-radius: 4px; border: 1px solid var(--border-glass); font-family: monospace; font-size: 0.8rem; color: var(--accent-cyan);">has:image</kbd>
                        <span>Filtrer par type de fichier (image, video, pdf, etc.)</span>
                    </li>
                </ul>
            </div>
        </div>

        <div class="global-search-modal-footer"
             style="padding: 0.75rem 1rem; border-top: 1px solid var(--border-glass); font-size: 0.8rem; color: var(--text-muted); display: flex; justify-content: space-between; align-items: center; flex-shrink: 0;">
            <span>Saisissez des filtres ou recherchez du texte</span>
            <div>
                <kbd
                    style="background: var(--bg-card); padding: 2px 6px; border-radius: 4px; border: 1px solid var(--border-glass);">Echap</kbd>
                pour fermer
            </div>
        </div>
    </div>
</dialog>


