<dialog id="create-channel-modal" class="modal-backdrop-dialog" role="dialog" aria-modal="true"
        aria-labelledby="modal-title">
    <div class="modal-content glass-panel">
        <div class="modal-header">
            <h3 id="modal-title">Créer un nouveau canal</h3>
            <button type="button" onclick="closeChannelModal()" class="btn-close-modal" aria-label="Fermer la boîte de dialogue">&times;</button>
        </div>
        <form action="{{ path('app_channel_create') }}" method="POST" class="add-channel-form" hx-boost="false">
            <div class="input-group">
                <label for="modal-name">Nom du canal</label>
                <input type="text" id="modal-name" name="name" required placeholder="Nom du canal..." maxlength="20" class="input-sidebar" style="background: rgba(0, 0, 0, 0.3) !important;">
            </div>
            <div class="input-group" style="margin-top: 0.5rem;">
                <label for="modal-description">Description</label>
                <input type="text" id="modal-description" name="description" placeholder="Description (optionnelle)..." maxlength="50" class="input-sidebar" style="background: rgba(0, 0, 0, 0.3) !important;">
            </div>
            <div class="input-group" style="margin-top: 0.5rem;">
                <label for="modal-retention">Rétention des messages</label>
                <select id="modal-retention" name="messageRetentionMonths" class="input-sidebar"
                        style="width: 100%; cursor: pointer;">
                    <option value="1">1 mois</option>
                    <option value="3">3 mois</option>
                    <option value="6" selected>6 mois (par défaut)</option>
                    <option value="12">12 mois</option>
                    <option value="0">Sans limite</option>
                </select>
            </div>
            <div class="input-group-checkbox" style="margin-top: 0.75rem; display: flex; align-items: center; gap: 0.5rem;">
                <input type="checkbox" name="isPrivate" id="modal-isPrivate" class="input-checkbox" style="width: auto; cursor: pointer;">
                <label for="modal-isPrivate" style="font-size: 0.85rem; color: var(--text-muted); cursor: pointer; text-transform: none; font-weight: normal; letter-spacing: normal;">Canal privé</label>
            </div>
            <button type="submit" class="btn-publish" style="margin-top: 1.25rem;">Créer le canal</button>
        </form>
    </div>
</dialog>

<script>
    (function() {
        let lastFocusedElement = null;

        window.openChannelModal = function(trigger) {
            lastFocusedElement = trigger;
            const modal = document.getElementById('create-channel-modal');
            if (modal) {
                modal.showModal();
                const firstInput = document.getElementById('modal-name');
                if (firstInput) {
                    setTimeout(() => firstInput.focus(), 50);
                }
            }
        };

        window.closeChannelModal = function() {
            const modal = document.getElementById('create-channel-modal');
            if (modal) {
                modal.close();
                if (lastFocusedElement) {
                    lastFocusedElement.focus();
                }
            }
        };

        document.getElementById('create-channel-modal')?.addEventListener('click', (e) => {
            if (e.target.id === 'create-channel-modal') {
                closeChannelModal();
            }
        });
    })();
</script>
