{% embed '_modal_layout.html.twig' with {
    id: 'invite-member-modal',
    title: 'Inviter un membre dans #' ~ activeChannel.name,
    content_style: 'max-width: 480px !important;'
} %}
    {% block modal_body %}
        <div id="invite-modal-body">
            {% include 'dashboard/_invite_modal_list.html.twig' with {'activeChannel': activeChannel, 'usersToInvite': usersToInvite} %}
        </div>
    {% endblock %}
{% endembed %}

<script>
    (function() {
        const searchInput = document.getElementById('invite-member-search-input');
        if (searchInput) {
            searchInput.value = '';
            const listContainer = document.getElementById('modal-invite-members-list');
            if (listContainer) {
                listContainer.innerHTML = '<span style="font-size: 0.85rem; color: var(--text-muted); text-align: center; display: block; padding: 1rem 0;">Saisissez un nom pour rechercher un membre.</span>';
            }
        }
        openModal('invite-member-modal');
    })();
</script>
