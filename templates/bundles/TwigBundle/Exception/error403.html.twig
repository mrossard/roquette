<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ 'Accès refusé - Roquette'|trans }}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-base: hsl(222, 47%, 9%);
            --bg-card: hsla(223, 47%, 14%, 0.6);
            --border-glass: rgba(255, 255, 255, 0.06);
            --text-primary: hsl(210, 40%, 98%);
            --text-muted: hsl(215, 20%, 65%);
            --accent-cyan: hsl(187, 100%, 45%);
            --accent-cyan-glow: rgba(0, 229, 255, 0.2);
            --accent-purple: hsl(271, 91%, 65%);
            --accent-purple-glow: rgba(168, 85, 247, 0.2);
            --font-sans: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;
            --accent-red: hsl(0, 84%, 60%);
            --accent-red-glow: rgba(239, 68, 68, 0.2);
        }

        [data-theme="light"] {
            --bg-base: hsl(210, 15%, 90%);
            --bg-card: hsla(210, 20%, 100%, 0.85);
            --border-glass: rgba(0, 0, 0, 0.15);
            --text-primary: hsl(222, 47%, 10%);
            --text-muted: hsl(215, 20%, 35%);
            --accent-cyan: hsl(195, 100%, 28%);
            --accent-cyan-glow: rgba(0, 120, 160, 0.2);
            --accent-purple: hsl(271, 75%, 45%);
            --accent-purple-glow: rgba(110, 30, 180, 0.2);
            --accent-red: hsl(0, 75%, 40%);
            --accent-red-glow: rgba(180, 30, 30, 0.2);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--bg-base);
            background-image: radial-gradient(at 20% 80%, rgba(239, 68, 68, 0.12) 0px, transparent 50%),
            radial-gradient(at 100% 0%, rgba(0, 229, 255, 0.12) 0px, transparent 50%);
            background-attachment: fixed;
            color: var(--text-primary);
            font-family: var(--font-sans);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
        }

        .stars {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
        }

        .star {
            position: absolute;
            background: currentColor;
            color: var(--text-primary);
            border-radius: 50%;
            opacity: 0.15;
            animation: float-around var(--speed, 20s) infinite linear;
        }

        @keyframes float-around {
            0% {
                transform: translateY(0) translateX(0) scale(1);
            }
            50% {
                transform: translateY(-50px) translateX(30px) scale(1.2);
            }
            100% {
                transform: translateY(0) translateX(0) scale(1);
            }
        }

        .container {
            position: relative;
            z-index: 1;
            text-align: center;
            padding: 2.5rem;
            background: var(--bg-card);
            border: 1px solid var(--border-glass);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-radius: 24px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
            max-width: 500px;
            width: 90%;
            animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @keyframes slide-up {
            0% {
                opacity: 0;
                transform: translateY(30px);
            }
            100% {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .icon-container {
            position: relative;
            margin-bottom: 2rem;
            display: inline-block;
            animation: pulse-shield 3s ease-in-out infinite;
        }

        @keyframes pulse-shield {
            0%, 100% {
                transform: scale(1);
            }
            50% {
                transform: scale(1.08);
            }
        }

        .icon-svg {
            width: 100px;
            height: 100px;
            filter: drop-shadow(0 0 15px var(--accent-red-glow));
        }

        .lock-ring {
            position: absolute;
            inset: -8px;
            border: 2px solid var(--accent-red-glow);
            border-radius: 50%;
            animation: ring-pulse 2s infinite ease-out;
        }

        @keyframes ring-pulse {
            0% {
                transform: scale(1);
                opacity: 0.6;
            }
            100% {
                transform: scale(1.3);
                opacity: 0;
            }
        }

        h1 {
            font-size: 5rem;
            font-weight: 800;
            line-height: 1;
            margin-bottom: 0.5rem;
            background: linear-gradient(135deg, var(--accent-red), var(--accent-purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -2px;
        }

        h2 {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 1rem;
            color: var(--text-primary);
        }

        p {
            color: var(--text-muted);
            font-size: 1rem;
            line-height: 1.6;
            margin-bottom: 2rem;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            padding: 0.8rem 1.8rem;
            border-radius: 12px;
            font-weight: 600;
            font-size: 1rem;
            text-decoration: none;
            transition: all 0.3s ease;
            background: linear-gradient(135deg, var(--accent-cyan), var(--accent-purple));
            color: white;
            box-shadow: 0 4px 15px var(--accent-cyan-glow);
            border: none;
            cursor: pointer;
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px var(--accent-purple-glow);
            opacity: 0.95;
        }

        .btn:active {
            transform: translateY(0);
        }
    </style>
</head>
<body>
<div class="stars" id="stars-container"></div>
<div class="container">
    <div class="icon-container">
        <svg class="icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
             stroke-linecap="round" stroke-linejoin="round">
            <defs>
                <linearGradient id="shield-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="var(--accent-red)"/>
                    <stop offset="100%" stop-color="var(--accent-purple)"/>
                </linearGradient>
            </defs>
            <path d="M12 2L3 7v5c0 5.25 3.83 10.15 9 11 5.17-.85 9-5.75 9-11V7l-9-5z"
                  stroke="url(#shield-gradient)" stroke-width="1.8"/>
            <path d="M9 12l2 2 4-4" stroke="url(#shield-gradient)" stroke-width="2.5"/>
            <circle cx="12" cy="12" r="1.5" fill="var(--bg-card)" stroke="none"/>
        </svg>
        <div class="lock-ring"></div>
    </div>
    <h1>403</h1>
    <h2>{{ 'Accès refusé.'|trans }}</h2>
    <p>{{ "Vous n'avez pas les autorisations nécessaires pour accéder à cette zone. Si vous pensez qu'il s'agit d'une erreur, contactez un administrateur."|trans }}</p>
    <a href="/" class="btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
             stroke-linecap="round" stroke-linejoin="round">
            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        {{ "Retourner à l'accueil"|trans }}
    </a>
</div>

<script>
    const savedTheme = localStorage.getItem('theme') || 'dark';
    document.documentElement.setAttribute('data-theme', savedTheme);
    const container = document.getElementById('stars-container');
    const starCount = 30;
    for (let i = 0; i < starCount; i++) {
        const star = document.createElement('div');
        star.className = 'star';
        const size = Math.random() * 3 + 1;
        star.style.width = `${size}px`;
        star.style.height = `${size}px`;
        star.style.left = `${Math.random() * 100}%`;
        star.style.top = `${Math.random() * 100}%`;
        star.style.setProperty('--speed', `${Math.random() * 15 + 10}s`);
        container.appendChild(star);
    }
</script>
</body>
</html>
