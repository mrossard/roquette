{% extends 'base.html.twig' %}

{% block title %}{{ 'Roquette - Administration - Exports'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
    <div class="app-container admin-layout" hx-boost="true">
        <header class="app-header">
            <div class="logo-area">
                <button id="mobile-sidebar-toggle" class="btn-mobile-toggle" aria-label="{{ 'Afficher le menu'|trans }}">
                    <span class="hamburger-bar"></span>
                    <span class="hamburger-bar"></span>
                    <span class="hamburger-bar"></span>
                </button>
                <span class="logo-rocket">🚀</span>
                <div class="logo-text">
                    <h1>Roquette</h1>
                    <p class="subtitle">Administration</p>
                </div>
            </div>

            {% include 'dashboard/_header_controls.html.twig' with {'show_back_button': true} %}
        </header>

        <main class="dashboard-grid" id="main-content">
            <section class="card glass-panel settings-panel">
                <div class="card-header">
                    <div>
                        <h2>{{ 'Gestion des exports de canaux'|trans }}</h2>
                        <p class="card-description">{{ "Liste des exports d'historiques archivés, téléchargement et suppression."|trans }}</p>
                    </div>
                    {% include 'admin/_nav.html.twig' %}
                </div>

                <div class="card-body">
                    {% for label, messages in app.flashes %}
                        {% for msg in messages %}
                            <div class="alert-{{ label == 'error' ? 'error' : 'success' }} fade-in">
                                {{ msg }}
                            </div>
                        {% endfor %}
                    {% endfor %}

                    <div class="admin-table-wrapper">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>{{ 'Canal'|trans }}</th>
                                    <th>{{ "Date d'export"|trans }}</th>
                                    <th>{{ 'Exporté par'|trans }}</th>
                                    <th>{{ 'Nom du fichier / Taille'|trans }}</th>
                                    <th class="th--right">{{ 'Actions'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for e in exports %}
                                <tr>
                                    <td>
                                        {% if e.channel %}
                                            <strong style="color: var(--accent-cyan);">#{{ e.channel.name }}</strong>
                                            <span class="text-muted-block">slug: {{ e.channel.slug }}</span>
                                        {% else %}
                                            <strong style="color: var(--text-muted);">{{ e.channelName }}</strong>
                                            <span class="status-pill status-pill--deleted-channel">{{ 'Supprimé'|trans }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <span>{{ e.createdAt|date('d/m/Y H:i:s') }}</span>
                                    </td>
                                    <td>
                                        {% if e.exportedBy %}
                                            <span>{{ e.exportedBy.displayName|default(e.exportedBy.username) }}</span>
                                            <span class="text-muted-block">@{{ e.exportedBy.username }}</span>
                                        {% else %}
                                            <span style="color: var(--text-muted); font-style: italic;">{{ 'Inconnu'|trans }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <code class="file-name">{{ e.fileName }}</code>
                                        <span class="file-size">{{ e.fileSize|format_bytes }}</span>
                                    </td>
                                    <td class="td--right">
                                        <div class="action-row">
                                            <a href="{{ path('app_admin_export_download', {id: e.id}) }}" 
                                               class="btn-download" hx-boost="false">
                                                📥 {{ 'Télécharger'|trans }}
                                            </a>
                                            <form action="{{ path('app_admin_export_delete', {id: e.id}) }}" 
                                                  method="POST" class="action-inline" hx-boost="false"
                                                  data-confirm="{{ 'Êtes-vous sûr de vouloir supprimer cet export ? Le fichier physique sera également détruit.'|trans }}">
                                                <button type="submit" class="btn-delete-channel btn-action">
                                                    🗑️ {{ 'Supprimer'|trans }}
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5" class="empty-state">
                                        {{ 'Aucun export archivé pour le moment.'|trans }}
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    {% include 'admin/_pagination.html.twig' with {
                        routeName: 'app_admin_exports',
                        currentPage: page,
                        totalPages: totalPages,
                        totalItems: total,
                    } %}
                </div>
            </section>
        </main>

        {% include 'partials/_footer.html.twig' %}
    </div>
{% endblock %}
