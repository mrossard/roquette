{% extends 'base.html.twig' %}

{% block title %}Roquette - Administration - Audit Log{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
    <div class="app-container" hx-boost="true">
        <header class="app-header">
            <div class="logo-area">
                <button id="mobile-sidebar-toggle" class="btn-mobile-toggle" aria-label="Afficher le menu">
                    <span class="hamburger-bar"></span>
                    <span class="hamburger-bar"></span>
                    <span class="hamburger-bar"></span>
                </button>
                <span class="logo-rocket">🚀</span>
                <div class="logo-text">
                    <h1>Roquette</h1>
                    <p class="subtitle">Administration</p>
                </div>
            </div>

            {% include 'dashboard/_header_controls.html.twig' with {'show_back_button': true} %}
        </header>

        <main class="dashboard-grid" style="grid-template-columns: 1fr;">
            <section class="card glass-panel settings-panel" style="flex-grow: 1;">
                <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; border-bottom: 1px solid var(--border-glass); padding-bottom: 1rem; margin-bottom: 1rem;">
                    <div>
                        <h2>Logs d'audit de sécurité</h2>
                        <p class="card-description">Historique des actions administratives critiques effectuées sur la plateforme.</p>
                    </div>
                    {% include 'admin/_nav.html.twig' %}
                </div>

                <div class="card-body" style="gap: 1rem;">
                    <div class="admin-users-table-wrapper" style="overflow-x: auto;">
                        <table class="admin-users-table" style="width: 100%; border-collapse: collapse; font-size: 0.9rem;">
                            <thead>
                                <tr style="border-bottom: 1px solid var(--border-glass); text-align: left;">
                                    <th style="padding: 0.75rem 0.5rem; color: var(--text-muted); font-weight: 600;">Date</th>
                                    <th style="padding: 0.75rem 0.5rem; color: var(--text-muted); font-weight: 600;">Administrateur</th>
                                    <th style="padding: 0.75rem 0.5rem; color: var(--text-muted); font-weight: 600;">Action</th>
                                    <th style="padding: 0.75rem 0.5rem; color: var(--text-muted); font-weight: 600;">Détails</th>
                                    <th style="padding: 0.75rem 0.5rem; color: var(--text-muted); font-weight: 600; text-align: right;">Adresse IP</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for log in logs %}
                                <tr style="border-bottom: 1px solid rgba(255, 255, 255, 0.05);">
                                    <td style="padding: 0.75rem 0.5rem;">
                                        <span>{{ log.createdAt|date('d/m/Y H:i:s') }}</span>
                                    </td>
                                    <td style="padding: 0.75rem 0.5rem;">
                                        {% if log.performedBy %}
                                            <strong>{{ log.performedBy.displayName|default(log.performedBy.username) }}</strong>
                                            <span style="display: block; font-size: 0.8rem; color: var(--text-muted);">@{{ log.performedBy.username }}</span>
                                        {% else %}
                                            <span style="color: var(--text-muted); font-style: italic;">Système</span>
                                        {% endif %}
                                    </td>
                                    <td style="padding: 0.75rem 0.5rem;">
                                        {% if log.action.value == 'user_ban' %}
                                            <span class="status-pill" style="background: rgba(239, 68, 68, 0.15); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2);">
                                                Bannissement
                                            </span>
                                        {% elseif log.action.value == 'user_unban' %}
                                            <span class="status-pill" style="background: rgba(34, 197, 94, 0.15); color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.2);">
                                                Réhabilitation
                                            </span>
                                        {% elseif log.action.value == 'channel_export' %}
                                            <span class="status-pill" style="background: rgba(59, 130, 246, 0.15); color: #3b82f6; border: 1px solid rgba(59, 130, 246, 0.2);">
                                                Export Canal
                                            </span>
                                        {% elseif log.action.value == 'export_download' %}
                                            <span class="status-pill" style="background: rgba(99, 102, 241, 0.15); color: #818cf8; border: 1px solid rgba(99, 102, 241, 0.2);">
                                                Téléchargement
                                            </span>
                                        {% elseif log.action.value == 'export_delete' %}
                                            <span class="status-pill" style="background: rgba(239, 68, 68, 0.15); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2);">
                                                Suppr. Export
                                            </span>
                                        {% elseif log.action.value == 'channel_create' %}
                                            <span class="status-pill" style="background: rgba(34, 197, 94, 0.15); color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.2);">
                                                Création Canal
                                            </span>
                                        {% elseif log.action.value == 'channel_delete' %}
                                            <span class="status-pill" style="background: rgba(239, 68, 68, 0.15); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2);">
                                                Suppr. Canal
                                            </span>
                                        {% elseif log.action.value == 'group_create' %}
                                            <span class="status-pill" style="background: rgba(34, 197, 94, 0.15); color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.2);">
                                                Création Groupe
                                            </span>
                                        {% elseif log.action.value == 'group_delete' %}
                                            <span class="status-pill" style="background: rgba(239, 68, 68, 0.15); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2);">
                                                Suppr. Groupe
                                            </span>
                                        {% else %}
                                            <span class="status-pill" style="background: rgba(255, 255, 255, 0.05); color: var(--text-normal); border: 1px solid var(--border-glass);">
                                                {{ log.action.value }}
                                            </span>
                                        {% endif %}
                                    </td>
                                    <td style="padding: 0.75rem 0.5rem; max-width: 350px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        {% if log.action.value == 'user_ban' %}
                                            Bannissement de l'utilisateur <strong style="color: var(--text-normal);">{{ log.details.username|default('Inconnu') }}</strong>
                                        {% elseif log.action.value == 'user_unban' %}
                                            Réhabilitation de l'utilisateur <strong style="color: var(--text-normal);">{{ log.details.username|default('Inconnu') }}</strong>
                                        {% elseif log.action.value == 'channel_export' %}
                                            Export du canal <strong style="color: var(--accent-cyan);">#{{ log.details.channel_name|default('Inconnu') }}</strong> (Fichier: <code>{{ log.details.file_name|default('—') }}</code>)
                                        {% elseif log.action.value == 'export_download' %}
                                            Téléchargement d'export pour <strong style="color: var(--accent-cyan);">#{{ log.details.channel_name|default('Inconnu') }}</strong> (Fichier: <code>{{ log.details.file_name|default('—') }}</code>)
                                        {% elseif log.action.value == 'export_delete' %}
                                            Suppression d'export pour <strong style="color: var(--accent-cyan);">#{{ log.details.channel_name|default('Inconnu') }}</strong> (Fichier: <code>{{ log.details.file_name|default('—') }}</code>)
                                        {% elseif log.action.value == 'channel_create' %}
                                            Création du canal <strong style="color: var(--accent-cyan);">#{{ log.details.channel_name|default('Inconnu') }}</strong> (Privé : {{ log.details.is_private ? 'Oui' : 'Non' }}{% if log.details.parent_channel_id is defined %}, sous-canal{% endif %})
                                        {% elseif log.action.value == 'channel_delete' %}
                                            Suppression du canal <strong style="color: var(--text-normal);">#{{ log.details.channel_name|default('Inconnu') }}</strong> (slug: <code>{{ log.details.slug|default('—') }}</code>)
                                        {% elseif log.action.value == 'group_create' %}
                                            Création du groupe <strong style="color: var(--accent-cyan);">{{ log.details.group_name|default('Inconnu') }}</strong> (Identifier : <code>{{ log.details.group_identifier|default('—') }}</code>{% if log.details.imported is defined and log.details.imported %}, importé{% endif %})
                                        {% elseif log.action.value == 'group_delete' %}
                                            Suppression du groupe <strong style="color: var(--text-normal);">{{ log.details.group_name|default('Inconnu') }}</strong> (Identifier : <code>{{ log.details.group_identifier|default('—') }}</code>)
                                        {% else %}
                                            <span style="font-family: monospace; font-size: 0.8rem; color: var(--text-muted);">{{ log.details|json_encode }}</span>
                                        {% endif %}
                                    </td>
                                    <td style="padding: 0.75rem 0.5rem; text-align: right; font-family: monospace; color: var(--text-muted);">
                                        {{ log.ipAddress|default('—') }}
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5" style="text-align: center; padding: 2rem; color: var(--text-muted);">
                                        Aucun événement d'audit enregistré.
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </main>

        {% include 'partials/_footer.html.twig' %}
    </div>
{% endblock %}
