{% extends 'base.html.twig' %}

{% block title %}{{ 'Roquette - Administration - Audit Log'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
    <div class="app-container admin-layout" hx-boost="true">
        <header class="app-header">
            <div class="logo-area">
                <button id="mobile-sidebar-toggle" class="btn-mobile-toggle" aria-label="{{ 'Afficher le menu'|trans }}">
                    <span class="hamburger-bar"></span>
                    <span class="hamburger-bar"></span>
                    <span class="hamburger-bar"></span>
                </button>
                <span class="logo-rocket">🚀</span>
                <div class="logo-text">
                    <h1>Roquette</h1>
                    <p class="subtitle">Administration</p>
                </div>
            </div>

            {% include 'dashboard/_header_controls.html.twig' with {'show_back_button': true} %}
        </header>

        <main class="dashboard-grid" id="main-content">
            <section class="card glass-panel settings-panel">
                <div class="card-header">
                    <div>
                        <h2>{{ "Logs d'audit de sécurité"|trans }}</h2>
                        <p class="card-description">{{ 'Historique des actions administratives critiques effectuées sur la plateforme.'|trans }}</p>
                    </div>
                    {% include 'admin/_nav.html.twig' %}
                </div>

                <div class="card-body">
                    <div class="admin-table-wrapper">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>{{ 'Date'|trans }}</th>
                                    <th>{{ 'Administrateur'|trans }}</th>
                                    <th>{{ 'Action'|trans }}</th>
                                    <th>{{ 'Détails'|trans }}</th>
                                    <th class="th--right">{{ 'Adresse IP'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for log in logs %}
                                <tr>
                                    <td>
                                        <span>{{ log.createdAt|date('d/m/Y H:i:s') }}</span>
                                    </td>
                                    <td>
                                        {% if log.performedBy %}
                                            <strong>{{ log.performedBy.displayName|default(log.performedBy.username) }}</strong>
                                            <span class="text-muted-block">@{{ log.performedBy.username }}</span>
                                        {% else %}
                                            <span style="color: var(--text-muted); font-style: italic;">{{ 'Système'|trans }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if log.action.value == 'user_ban' %}
                                            <span class="status-pill status-pill--banned">{{ 'Bannissement'|trans }}</span>
                                        {% elseif log.action.value == 'user_unban' %}
                                            <span class="status-pill status-pill--active">{{ 'Réhabilitation'|trans }}</span>
                                        {% elseif log.action.value == 'channel_export' %}
                                            <span class="status-pill status-pill--export">{{ 'Export Canal'|trans }}</span>
                                        {% elseif log.action.value == 'export_download' %}
                                            <span class="status-pill status-pill--download">{{ 'Téléchargement'|trans }}</span>
                                        {% elseif log.action.value == 'export_delete' %}
                                            <span class="status-pill status-pill--delete">{{ 'Suppr. Export'|trans }}</span>
                                        {% elseif log.action.value == 'channel_create' %}
                                            <span class="status-pill status-pill--create">{{ 'Création Canal'|trans }}</span>
                                        {% elseif log.action.value == 'channel_delete' %}
                                            <span class="status-pill status-pill--delete">{{ 'Suppr. Canal'|trans }}</span>
                                        {% elseif log.action.value == 'group_create' %}
                                            <span class="status-pill status-pill--create">{{ 'Création Groupe'|trans }}</span>
                                        {% elseif log.action.value == 'group_delete' %}
                                            <span class="status-pill status-pill--delete">{{ 'Suppr. Groupe'|trans }}</span>
                                        {% else %}
                                            <span class="status-pill status-pill--default">{{ log.action.value }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="detail-cell">
                                        {% if log.action.value == 'user_ban' %}
                                            {{ "Bannissement de l'utilisateur"|trans }} <strong style="color: var(--text-normal);">{{ log.details.username|default('Inconnu'|trans) }}</strong>
                                        {% elseif log.action.value == 'user_unban' %}
                                            {{ "Réhabilitation de l'utilisateur"|trans }} <strong style="color: var(--text-normal);">{{ log.details.username|default('Inconnu'|trans) }}</strong>
                                        {% elseif log.action.value == 'channel_export' %}
                                            {{ "Export du canal"|trans }} <strong style="color: var(--accent-cyan);">#{{ log.details.channel_name|default('Inconnu'|trans) }}</strong> (Fichier: <code>{{ log.details.file_name|default('—') }}</code>)
                                        {% elseif log.action.value == 'export_download' %}
                                            {{ "Téléchargement d'export pour"|trans }} <strong style="color: var(--accent-cyan);">#{{ log.details.channel_name|default('Inconnu'|trans) }}</strong> (Fichier: <code>{{ log.details.file_name|default('—') }}</code>)
                                        {% elseif log.action.value == 'export_delete' %}
                                            {{ "Suppression d'export pour"|trans }} <strong style="color: var(--accent-cyan);">#{{ log.details.channel_name|default('Inconnu'|trans) }}</strong> (Fichier: <code>{{ log.details.file_name|default('—') }}</code>)
                                        {% elseif log.action.value == 'channel_create' %}
                                            {{ "Création du canal"|trans }} <strong style="color: var(--accent-cyan);">#{{ log.details.channel_name|default('Inconnu'|trans) }}</strong> (Privé : {{ log.details.is_private ? 'Oui'|trans : 'Non'|trans }}{% if log.details.parent_channel_id is defined %}, {{ 'sous-canal'|trans }}{% endif %})
                                        {% elseif log.action.value == 'channel_delete' %}
                                            {{ "Suppression du canal"|trans }} <strong style="color: var(--text-normal);">#{{ log.details.channel_name|default('Inconnu'|trans) }}</strong> (slug: <code>{{ log.details.slug|default('—') }}</code>)
                                        {% elseif log.action.value == 'group_create' %}
                                            {{ "Création du groupe"|trans }} <strong style="color: var(--accent-cyan);">{{ log.details.group_name|default('Inconnu'|trans) }}</strong> (Identifier : <code>{{ log.details.group_identifier|default('—') }}</code>{% if log.details.imported is defined and log.details.imported %}, {{ 'importé'|trans }}{% endif %})
                                        {% elseif log.action.value == 'group_delete' %}
                                            {{ "Suppression du groupe"|trans }} <strong style="color: var(--text-normal);">{{ log.details.group_name|default('Inconnu'|trans) }}</strong> (Identifier : <code>{{ log.details.group_identifier|default('—') }}</code>)
                                        {% else %}
                                            <span class="json-fallback">{{ log.details|json_encode }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="td--right json-fallback">
                                        {{ log.ipAddress|default('—') }}
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5" class="empty-state">
                                        {{ "Aucun événement d'audit enregistré."|trans }}
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    {% include 'admin/_pagination.html.twig' with {
                        routeName: 'app_admin_audit_logs',
                        currentPage: page,
                        totalPages: totalPages,
                        totalItems: total,
                    } %}
                </div>
            </section>
        </main>

        {% include 'partials/_footer.html.twig' %}
    </div>
{% endblock %}
