{# templates/admin/_nav.html.twig #}
{% set current_route = app.request.attributes.get('_route') %}

<div class="admin-nav-tabs">
    {% if is_granted('ROLE_ADMIN') %}
        {% set is_active = current_route starts with 'app_admin_users' %}
        <a href="{{ path('app_admin_users') }}"
           class="{{ is_active ? 'admin-nav-tab--active' : 'admin-nav-tab--inactive' }}">
            Utilisateurs
        </a>
    {% endif %}

    {% set is_active = current_route starts with 'app_admin_group' %}
    <a href="{{ path('app_admin_groups') }}"
       class="{{ is_active ? 'admin-nav-tab--active' : 'admin-nav-tab--inactive' }}">
        Groupes
    </a>

    {% if is_granted('ROLE_ADMIN') %}
        {% set is_active = current_route starts with 'app_admin_export' %}
        <a href="{{ path('app_admin_exports') }}"
           class="{{ is_active ? 'admin-nav-tab--active' : 'admin-nav-tab--inactive' }}">
            Exports
        </a>

        {% set is_active = current_route starts with 'app_admin_audit_logs' %}
        <a href="{{ path('app_admin_audit_logs') }}"
           class="{{ is_active ? 'admin-nav-tab--active' : 'admin-nav-tab--inactive' }}">
            Audit Log
        </a>
    {% endif %}
</div>
