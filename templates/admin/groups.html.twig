{% extends 'base.html.twig' %}

{% block title %}Roquette - Gestion des groupes{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
    <div class="app-container admin-layout" hx-boost="true">
        <header class="app-header">
            <div class="logo-area">
                <button id="mobile-sidebar-toggle" class="btn-mobile-toggle" aria-label="Afficher le menu">
                    <span class="hamburger-bar"></span>
                    <span class="hamburger-bar"></span>
                    <span class="hamburger-bar"></span>
                </button>
                <span class="logo-rocket">🚀</span>
                <div class="logo-text">
                    <h1>Roquette</h1>
                    <p class="subtitle">Administration</p>
                </div>
            </div>

            {% include 'dashboard/_header_controls.html.twig' with {'show_back_button': true} %}
        </header>

        <main class="dashboard-grid">
            <!-- Group Tabs & Actions Panel -->
            <section class="card glass-panel settings-panel">
                <div class="card-header" style="border-bottom: 1px solid var(--border-glass); padding-bottom: 1rem;">
                    <div>
                        <h2>Gestion des groupes</h2>
                        <p class="card-description">Créer des groupes locaux ou importer des groupes depuis l'annuaire.</p>
                    </div>
                    {% include 'admin/_nav.html.twig' %}
                </div>

                <div class="card-body card-body--padded-top">
                    {% for label, messages in app.flashes %}
                        {% for msg in messages %}
                            <div class="alert-{{ label == 'error' ? 'error' : 'success' }} fade-in alert-wrapper">
                                {{ msg }}
                            </div>
                        {% endfor %}
                    {% endfor %}

                    {% if is_granted('ROLE_ADMIN') %}
                    <!-- Search and Creation Row -->
                    <div class="search-row">
                        <!-- Local Group Creation -->
                        <div class="glass-panel">
                            <h3>🆕 Créer un groupe local</h3>
                            <form action="{{ path('app_admin_group_create') }}" method="POST" class="inline-form">
                                <div style="flex-grow: 1;">
                                    <label for="group-name-input" class="form-label">Nom du groupe</label>
                                    <input type="text" id="group-name-input" name="name" required placeholder="Ex: Équipe Support" class="input-sidebar form-input-full">
                                </div>
                                <button type="submit" class="btn-publish btn-panel">Créer</button>
                            </form>
                        </div>

                        <!-- Provider Search -->
                        <div class="glass-panel">
                            <h3>🔍 Rechercher un groupe (Annuaire)</h3>
                            <form action="{{ path('app_admin_groups') }}" method="GET" class="inline-form">
                                <div style="flex-grow: 1;">
                                    <label for="provider-search-input" class="form-label">Nom du groupe ou identifiant</label>
                                    <input type="text" id="provider-search-input" name="search" value="{{ searchQuery }}" placeholder="Ex: devs" class="input-sidebar form-input-full">
                                </div>
                                <button type="submit" class="btn-publish btn-panel btn-panel--search">Rechercher</button>
                            </form>
                        </div>
                    </div>
                    {% endif %}

                    {% if searchQuery is not empty %}
                        <div class="provider-results">
                            <h3>Résultats de la recherche dans l'annuaire</h3>
                            {% if providerResults|length > 0 %}
                                <div class="result-list">
                                    {% for group in providerResults %}
                                        <div class="result-item">
                                            <div>
                                                <div class="item-name">👥 {{ group.name }}</div>
                                                <div class="item-identifier">{{ group.identifier }}</div>
                                                {% if group.description %}
                                                    <div class="item-description">{{ group.description }}</div>
                                                {% endif %}
                                            </div>
                                            <div>
                                                {% if group.isImported %}
                                                    <span class="badge-imported">Importé</span>
                                                {% else %}
                                                    <form action="{{ path('app_admin_group_import') }}" method="POST" style="margin: 0;">
                                                        <input type="hidden" name="identifier" value="{{ group.identifier }}">
                                                        <input type="hidden" name="name" value="{{ group.name }}">
                                                        <button type="submit" class="btn-publish" style="margin: 0; padding: 0.35rem 0.75rem; font-size: 0.8rem; border-radius: 0.35rem; cursor: pointer; height: auto;">Importer</button>
                                                    </form>
                                                {% endif %}
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <div class="no-results">Aucun groupe trouvé pour "{{ searchQuery }}".</div>
                            {% endif %}
                        </div>
                    {% endif %}

                    <!-- Local Groups Table -->
                    <h3 class="section-title">Groupes enregistrés</h3>
                    {% if localGroups|length > 0 %}
                        <div class="admin-table-wrapper">
                            <table class="admin-table">
                                <thead>
                                    <tr>
                                        <th>Nom du groupe</th>
                                        <th>Identifiant / DN</th>
                                        <th>Canal officiel</th>
                                        <th>Administrateurs</th>
                                        <th class="th--center">Membres locaux</th>
                                        <th class="th--right">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for group in localGroups %}
                                        <tr>
                                            <td style="font-weight: 500; color: var(--text-primary);">
                                                👥 {{ group.name }}
                                            </td>
                                            <td style="font-family: monospace; font-size: 0.8rem; max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" class="text-muted" title="{{ group.groupIdentifier }}">
                                                {{ group.groupIdentifier }}
                                            </td>
                                            <td>
                                                <a href="{{ path('app_channel', {slug: group.channel.slug}) }}" class="table-link" hx-boost="false">
                                                    #{{ group.channel.name }}
                                                </a>
                                            </td>
                                            <td style="font-size: 0.85rem;">
                                                {% for admin in group.administrators %}
                                                    <span class="admin-badge" title="@{{ admin.username }}">
                                                        {{ admin.displayName|default(admin.username) }}
                                                    </span>
                                                {% else %}
                                                    <span style="font-style: italic; color: var(--text-muted); font-size: 0.8rem;">Aucun</span>
                                                {% endfor %}
                                            </td>
                                            <td class="member-count">
                                                {{ group.members|length }}
                                            </td>
                                            <td class="td--right">
                                                <div class="action-row action-row--flex">
                                                    <a href="{{ path('app_admin_group_members', {id: group.id}) }}" class="btn-members-link" hx-boost="false">
                                                        👤 Membres
                                                    </a>
                                                    {% if is_granted('ROLE_ADMIN') %}
                                                    <form action="{{ path('app_admin_group_delete', {id: group.id}) }}" method="POST" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce groupe ? Son canal officiel sera supprimé définitivement.');" style="margin: 0;">
                                                        <button type="submit" class="btn-member-action btn-member-action--remove">
                                                            Supprimer
                                                        </button>
                                                    </form>
                                                    {% endif %}
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>

                        {% include 'admin/_pagination.html.twig' with {
                            routeName: 'app_admin_groups',
                            currentPage: page,
                            totalPages: totalPages,
                            totalItems: total,
                        } %}
                    {% else %}
                        <div class="empty-state-block">Aucun groupe enregistré localement.</div>
                    {% endif %}
                </div>
            </section>
        </main>
    </div>
{% endblock %}
