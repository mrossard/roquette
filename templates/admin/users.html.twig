{% extends 'base.html.twig' %}

{% block title %}{{ 'Roquette - Administration'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
    <div class="app-container admin-layout" hx-boost="true">
        <header class="app-header">
            <div class="logo-area">
                <button id="mobile-sidebar-toggle" class="btn-mobile-toggle" aria-label="{{ 'Afficher le menu'|trans }}">
                    <span class="hamburger-bar"></span>
                    <span class="hamburger-bar"></span>
                    <span class="hamburger-bar"></span>
                </button>
                <span class="logo-rocket">🚀</span>
                <div class="logo-text">
                    <h1>Roquette</h1>
                    <p class="subtitle">Administration</p>
                </div>
            </div>

            {% include 'dashboard/_header_controls.html.twig' with {'show_back_button': true} %}
        </header>

        <main class="dashboard-grid" id="main-content">
            <section class="card glass-panel settings-panel">
                <div class="card-header">
                    <div>
                        <h2>{{ 'Gestion des utilisateurs'|trans }}</h2>
                        <p class="card-description">{{ 'Bannir ou réhabiliter des utilisateurs.'|trans }}</p>
                    </div>
                    {% include 'admin/_nav.html.twig' %}
                </div>

                <div class="card-body">
                    {% for label, messages in app.flashes %}
                        {% for msg in messages %}
                            <div class="alert-{{ label == 'error' ? 'error' : 'success' }} fade-in">
                                {{ msg }}
                            </div>
                        {% endfor %}
                    {% endfor %}

                    <div class="admin-table-wrapper">
                        <table class="admin-table">
                            <thead>
                            <tr>
                                <th>{{ 'Utilisateur'|trans }}</th>
                                <th>{{ 'Rôle'|trans }}</th>
                                <th>{{ 'Statut'|trans }}</th>
                                <th>{{ 'Actions'|trans }}</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for u in users %}
                                <tr>
                                    <td class="user-cell">
                                    <span class="feed-item-avatar"
                                          style="--user-hue: {{ u.hue }};">
                                        {{ u.username|slice(0, 1)|upper }}
                                    </span>
                                        <div>
                                            <strong class="user-name"
                                                    style="--user-hue: {{ u.hue }};">{{ u.displayName|default(u.username) }}</strong>
                                            <span class="user-username">@{{ u.username }}</span>
                                        </div>
                                    </td>
                                    <td>
                                        {% if u.admin %}
                                            <span class="status-pill status-pill--admin">{{ 'Admin'|trans }}</span>
                                        {% else %}
                                            <span class="status-pill status-pill--user">{{ 'Utilisateur'|trans }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if u.bannedAt %}
                                            <span class="status-pill status-pill--banned">
                                            {{ 'Banni'|trans }}
                                        </span>
                                            {% if u.bannedReason %}
                                                <span class="text-muted-small" style="margin-top: 0.25rem;">{{ u.bannedReason }}</span>
                                            {% endif %}
                                        {% else %}
                                            <span class="status-pill status-pill--active">{{ 'Actif'|trans }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if u.bannedAt %}
                                            <form action="{{ path('app_admin_user_unban', {id: u.id}) }}" method="POST"
                                                  class="action-inline" hx-boost="false">
                                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('app') }}">
                                                <button type="submit" class="btn-submit btn-action btn-action--rehab">
                                                    {{ 'Réhabiliter'|trans }}
                                                </button>
                                            </form>
                                        {% elseif u.admin or u.id == app.user.id %}
                                            <span class="action-placeholder">—</span>
                                        {% else %}
                                            <form action="{{ path('app_admin_user_ban', {id: u.id}) }}" method="POST"
                                                  class="action-inline" hx-boost="false"
                                                  data-confirm="{{ 'Êtes-vous sûr de vouloir bannir %username% ?'|trans({ '%username%': u.username }) }}">
                                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('app') }}">
                                                <button type="submit" class="btn-delete-channel btn-action">
                                                    {{ 'Bannir'|trans }}
                                                </button>
                                            </form>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="4" class="empty-state">
                                        {{ 'Aucun utilisateur.'|trans }}
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    {% include 'admin/_pagination.html.twig' with {
                        routeName: 'app_admin_users',
                        currentPage: page,
                        totalPages: totalPages,
                        totalItems: total,
                    } %}
                </div>
            </section>
        </main>

        {% include 'partials/_footer.html.twig' %}
    </div>
{% endblock %}
