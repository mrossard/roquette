{% extends 'base.html.twig' %}

{% block title %}{{ 'Roquette - Membres du groupe %group_name%'|trans({ '%group_name%': group.name }) }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
    <div class="app-container admin-layout" hx-boost="true">
        <header class="app-header">
            <div class="logo-area">
                <button id="mobile-sidebar-toggle" class="btn-mobile-toggle" aria-label="{{ 'Afficher le menu'|trans }}">
                    <span class="hamburger-bar"></span>
                    <span class="hamburger-bar"></span>
                    <span class="hamburger-bar"></span>
                </button>
                <span class="logo-rocket">🚀</span>
                <div class="logo-text">
                    <h1>Roquette</h1>
                    <p class="subtitle">Administration</p>
                </div>
            </div>

            {% include 'dashboard/_header_controls.html.twig' with {'show_back_button': true} %}
        </header>

        <main class="dashboard-grid" id="main-content">
            <section class="card glass-panel settings-panel">
                <div class="card-header" style="border-bottom: 1px solid var(--border-glass); padding-bottom: 1rem;">
                    <div>
                        <div class="back-link-row">
                            <a href="{{ path('app_admin_groups') }}" hx-boost="false">⬅️</a>
                            <h2>{{ 'Membres de %group_name%'|trans({ '%group_name%': group.name }) }}</h2>
                        </div>
                        <p class="card-description">{{ 'Ajouter ou retirer manuellement des membres de ce groupe.'|trans }}</p>
                    </div>
                    {% include 'admin/_nav.html.twig' %}
                </div>

                <div class="card-body card-body--column">
                    {% for label, messages in app.flashes %}
                        {% for msg in messages %}
                            <div class="alert-{{ label == 'error' ? 'error' : 'success' }} fade-in">
                                {{ msg }}
                            </div>
                        {% endfor %}
                    {% endfor %}

                    {% if isExternal %}
                        <div class="external-sync-notice">
                            <h3>🌐 {{ 'Groupe synchronisé (Annuaire externe)'|trans }}</h3>
                            <p>{{ "Ce groupe est géré dans l'annuaire externe (LDAP). La liste des membres est synchronisée automatiquement et ne peut pas être modifiée manuellement."|trans }}</p>
                        </div>
                    {% else %}
                        <div class="add-member-panel">
                            <h3>➕ {{ 'Ajouter un membre'|trans }}</h3>
                            <form action="{{ path('app_admin_group_member_add', {id: group.id}) }}" method="POST">
                                <div class="field-wrapper">
                                    <label for="member-search-input-field" class="form-label">{{ 'Rechercher un utilisateur'|trans }}</label>
                                    <input type="text" id="member-search-input-field" placeholder="{{ 'Saisir le nom ou l\'identifiant...'|trans }}" class="input-sidebar form-input-full" autocomplete="off"
                                           hx-get="{{ path('app_admin_group_member_autocomplete', {id: group.id}) }}"
                                           hx-trigger="keyup changed delay:300ms"
                                           hx-target="#member-autocomplete-suggestions"
                                           hx-swap="outerHTML"
                                           onkeydown="if(event.key === 'Enter') event.preventDefault();">
                                    <input type="hidden" name="userId" id="member-user-id" required>
                                    <div id="member-autocomplete-suggestions" class="emoji-autocomplete-dropdown autocomplete-dropdown--hidden"></div>
                                </div>
                                <button type="submit" class="btn-publish btn-panel">{{ 'Ajouter'|trans }}</button>
                            </form>
                        </div>
                    {% endif %}

                    <!-- Current Members List -->
                    <div>
                        {% if isExternal %}
                            <h3 class="section-title">{{ "Membres de l'annuaire"|trans }} ({{ externalMembers|length }})</h3>
                            {% if externalMembers|length > 0 %}
                                <div class="member-list">
                                    {% for item in externalMembers %}
                                        <div class="member-item {{ not item.isRegistered ? 'member-item--dimmed' }}">
                                            <div class="member-info">
                                                <div class="member-avatar" style="--avatar-bg: {% if item.isRegistered %}hsl({{ item.user.hue }}, 90%, var(--user-hue-lightness-border)){% else %}#4b5563{% endif %};">
                                                    {{ item.username|slice(0,1)|upper }}
                                                </div>
                                                <div>
                                                    <div class="member-name-row">
                                                        <span class="member-display-name">
                                                            {% if item.isRegistered %}
                                                                {{ item.user.displayName|default(item.user.username) }}
                                                            {% else %}
                                                                {{ item.username }}
                                                            {% endif %}
                                                        </span>
                                                        {% if item.isRegistered and group.isAdministrator(item.user) %}
                                                            <span class="admin-badge admin-badge--uppercase">{{ 'Admin'|trans }}</span>
                                                        {% endif %}
                                                        {% if not item.isRegistered %}
                                                            <span class="status-pill status-pill--not-registered">{{ 'Non inscrit'|trans }}</span>
                                                        {% endif %}
                                                    </div>
                                                    <div class="text-muted-small">
                                                        @{{ item.username }}
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="member-actions">
                                                    {% if item.isRegistered %}
                                                        {% if group.isAdministrator(item.user) %}
                                                            <form action="{{ path('app_admin_group_administrator_remove', {id: group.id, userId: item.user.id}) }}" method="POST" data-confirm="{{ 'Retirer les droits administrateur de cet utilisateur ?'|trans }}" style="margin: 0;">
                                                                <button type="submit" class="btn-member-action btn-member-action--neutral">{{ 'Retirer Admin'|trans }}</button>
                                                            </form>
                                                        {% else %}
                                                            <form action="{{ path('app_admin_group_administrator_add', {id: group.id}) }}" method="POST" style="margin: 0;">
                                                                <input type="hidden" name="userId" value="{{ item.user.id }}">
                                                                <button type="submit" class="btn-member-action btn-member-action--promote">{{ 'Nommer Admin'|trans }}</button>
                                                            </form>
                                                        {% endif %}
                                                    {% endif %}
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <div class="empty-state-block">{{ "Aucun membre dans l'annuaire pour ce groupe."|trans }}</div>
                            {% endif %}
                        {% else %}
                            <h3 class="section-title">{{ 'Membres actuels'|trans }} ({{ group.members|length }})</h3>
                            {% if group.members|length > 0 %}
                                <div class="member-list">
                                    {% for member in group.members|sort((a, b) => (a.displayName|default(a.username))|lower <=> (b.displayName|default(b.username))|lower) %}
                                        <div class="member-item">
                                            <div class="member-info">
                                                <div class="member-avatar member-avatar--glow" style="--avatar-bg: hsl({{ member.hue }}, 90%, var(--user-hue-lightness-border)); --hue: {{ member.hue }};">
                                                    {{ member.username|slice(0,1)|upper }}
                                                </div>
                                                <div>
                                                    <div class="member-name-row">
                                                        <span class="member-display-name">{{ member.displayName|default(member.username) }}</span>
                                                        {% if group.isAdministrator(member) %}
                                                            <span class="admin-badge admin-badge--uppercase">{{ 'Admin'|trans }}</span>
                                                        {% endif %}
                                                    </div>
                                                    <div class="text-muted-small">@{{ member.username }}</div>
                                                </div>
                                            </div>
                                            <div class="member-actions">
                                                {% if group.isAdministrator(member) %}
                                                    <form action="{{ path('app_admin_group_administrator_remove', {id: group.id, userId: member.id}) }}" method="POST" data-confirm="{{ 'Retirer les droits administrateur de cet utilisateur ?'|trans }}" style="margin: 0;">
                                                        <button type="submit" class="btn-member-action btn-member-action--neutral">{{ 'Retirer Admin'|trans }}</button>
                                                    </form>
                                                {% else %}
                                                    <form action="{{ path('app_admin_group_administrator_add', {id: group.id}) }}" method="POST" style="margin: 0;">
                                                        <input type="hidden" name="userId" value="{{ member.id }}">
                                                        <button type="submit" class="btn-member-action btn-member-action--promote">{{ 'Nommer Admin'|trans }}</button>
                                                    </form>
                                                {% endif %}
                                                <form action="{{ path('app_admin_group_member_remove', {id: group.id, userId: member.id}) }}" method="POST" data-confirm="{{ 'Retirer cet utilisateur du groupe ?'|trans }}" style="margin: 0;">
                                                    <button type="submit" class="btn-member-action btn-member-action--remove">{{ 'Retirer'|trans }}</button>
                                                </form>
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <div class="empty-state-block">{{ "Ce groupe n'a pas encore de membre local."|trans }}</div>
                            {% endif %}
                        {% endif %}
                    </div>
                </div>
            </section>
        </main>
    </div>
{% endblock %}
