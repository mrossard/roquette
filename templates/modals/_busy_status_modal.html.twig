{% embed 'partials/_modal_layout.html.twig' with {
    id: 'busy-status-modal',
    content_style: 'max-width: 440px !important;'
} %}
    {% block modal_title %}
        <span style="display: flex; align-items: center; gap: 0.5rem; font-size: 1.25rem; margin: 0;">⚠️ {{ 'Activer le statut Occupé ?'|trans }}</span>
    {% endblock %}

    {% block modal_body %}
        <div class="modal-body"
             style="color: var(--text-primary); font-size: 0.95rem; line-height: 1.5; margin: 1rem 0 1.5rem 0; display: flex; flex-direction: column; gap: 0.75rem;">
            <p>{{ "En passant votre statut en"|trans }} <strong>"Occupé"</strong> :</p>
            <ul style="margin: 0; padding-left: 1.25rem; display: flex; flex-direction: column; gap: 0.5rem;">
                <li>{{ 'Toutes les notifications de bureau seront désactivées.'|trans }}</li>
                <li>{{ 'Le rafraîchissement en direct de l\'interface (nouveaux messages) sera suspendu.'|trans }}</li>
            </ul>
            <p style="margin-top: 0.5rem; color: var(--text-warning, #ffca28);">
                💡 <em>{{ "Votre contenu et les messages reçus s'actualiseront automatiquement dès que vous changerez à nouveau de statut."|trans }}</em>
            </p>
        </div>
        <div class="modal-footer" style="display: flex; justify-content: flex-end; gap: 0.75rem;">
            <button type="button" class="btn-cancel" data-dialog-close
                    style="background: rgba(255, 255, 255, 0.05); border: 1px solid var(--border-glass); color: var(--text-primary); padding: 0.5rem 1rem; border-radius: 0.5rem; cursor: pointer; transition: background 0.2s;">
                {{ 'Annuler'|trans }}
            </button>
            <button type="button"
                    class="btn-publish"
                    hx-post="{{ path('app_user_update_status') }}"
                    hx-vals='{"status": "busy"}'
                    hx-swap="none"
                    data-dialog-close
                    style="margin-top: 0; padding: 0.5rem 1rem; border-radius: 0.5rem; cursor: pointer; background: #ffab00; border: none; color: #000; font-weight: bold; transition: opacity 0.2s;">
                {{ 'Confirmer'|trans }}
            </button>
        </div>
    {% endblock %}
{% endembed %}
