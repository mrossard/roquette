{% embed 'partials/_modal_layout.html.twig' with {
    id: 'edit-channel-modal',
    title: 'Modifier le canal'
} %}
    {% block modal_body %}
        <form action="{{ path('app_channel_edit', {slug: activeChannel.slug}) }}" method="POST" class="add-channel-form"
              hx-boost="false">
            <div class="input-group">
                <label for="edit-modal-name">Nom du canal</label>
                <input type="text" id="edit-modal-name" name="name" value="{{ activeChannel.name }}" required
                       placeholder="Nom du canal..." maxlength="20" class="input-sidebar">
            </div>
            <div class="input-group" style="margin-top: 0.5rem;">
                <label for="edit-modal-description">Description</label>
                <input type="text" id="edit-modal-description" name="description"
                       value="{{ activeChannel.description }}" placeholder="Description (optionnelle)..." maxlength="50"
                       class="input-sidebar">
            </div>
            <div class="input-group" style="margin-top: 0.5rem;">
                <label for="edit-modal-retention">Rétention des messages</label>
                <select id="edit-modal-retention" name="messageRetentionMonths" class="input-sidebar"
                        style="width: 100%; cursor: pointer;">
                    <option value="1" {% if activeChannel.messageRetentionMonths == 1 %}selected{% endif %}>1 mois
                    </option>
                    <option value="3" {% if activeChannel.messageRetentionMonths == 3 %}selected{% endif %}>3 mois
                    </option>
                    <option value="6" {% if activeChannel.messageRetentionMonths == 6 %}selected{% endif %}>6 mois
                    </option>
                    <option value="12" {% if activeChannel.messageRetentionMonths == 12 %}selected{% endif %}>12 mois
                </select>
            </div>

            {% if activeChannel.isPrivate() %}
                <div class="input-group" style="margin-top: 1rem; border-top: 1px solid var(--border-glass); padding-top: 1rem;">
                    <label>Groupes abonnés</label>
                    <div id="group-subscriptions-list" style="display: flex; flex-direction: column; gap: 0.5rem; margin-top: 0.5rem; margin-bottom: 0.5rem;">
                        {% for sub in resolvedSubscriptions %}
                            <div class="admin-chip" style="background: rgba(255, 255, 255, 0.05); border: 1px solid var(--border-glass); padding: 0.4rem 0.75rem; border-radius: 0.5rem; font-size: 0.85rem; display: flex; align-items: center; justify-content: space-between; color: var(--text-primary);">
                                <span>👥 {{ sub.name }} {% if sub.isGroupChannel %}<span style="font-size: 0.75rem; color: #6366f1; background: rgba(99, 102, 241, 0.1); padding: 0.1rem 0.4rem; border-radius: 0.25rem; margin-left: 0.25rem;">Officiel</span>{% endif %}</span>
                                <button type="button" 
                                        hx-post="{{ path('app_channel_unsubscribe_group', {slug: activeChannel.slug, subscriptionId: sub.id}) }}"
                                        hx-target="#edit-channel-modal"
                                        hx-swap="outerHTML"
                                        style="background: none; border: none; color: var(--text-muted); cursor: pointer; padding: 0; font-size: 1.1rem; line-height: 1; display: flex; align-items: center; margin-left: auto;">
                                    &times;
                                </button>
                            </div>
                        {% else %}
                            <div style="font-size: 0.85rem; color: var(--text-muted); font-style: italic;">Aucun groupe abonné.</div>
                        {% endfor %}
                    </div>

                    <div style="margin-top: 0.5rem; display: flex; gap: 0.5rem; align-items: flex-end;">
                        <div style="flex-grow: 1;">
                            <label for="edit-modal-add-group" style="font-size: 0.75rem;">Abonner un groupe</label>
                            <select id="edit-modal-add-group" name="newGroupIdentifier" class="input-sidebar" style="width: 100%; cursor: pointer;">
                                <option value="">-- Sélectionner un groupe --</option>
                                {% for group in groups %}
                                    <option value="{{ group.identifier }}">{{ group.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.25rem;">
                            <input type="checkbox" name="newGroupIsOfficial" id="edit-modal-group-official" class="input-checkbox" style="width: auto; cursor: pointer;">
                            <label for="edit-modal-group-official" style="font-size: 0.75rem; color: var(--text-muted); cursor: pointer; white-space: nowrap;">Officiel</label>
                        </div>
                        <button type="button" 
                                hx-post="{{ path('app_channel_subscribe_group', {slug: activeChannel.slug}) }}"
                                hx-include="#edit-modal-add-group, #edit-modal-group-official"
                                hx-target="#edit-channel-modal"
                                hx-swap="outerHTML"
                                class="btn-publish" 
                                style="padding: 0.5rem 1rem; margin-top: 0; font-size: 0.85rem; border-radius: 0.5rem; cursor: pointer;">
                            Ajouter
                        </button>
                    </div>
                </div>
            {% endif %}

            {% if activeChannel.isSubChannel() %}
                <div class="input-group-checkbox"
                     style="margin-top: 0.75rem; display: flex; align-items: center; gap: 0.5rem;">
                    <input type="checkbox" name="isTodoList" id="edit-modal-isTodoList" class="input-checkbox"
                           style="width: auto; cursor: pointer;" {% if activeChannel.isTodoList() %}checked{% endif %}>
                    <label for="edit-modal-isTodoList"
                           style="font-size: 0.85rem; color: var(--text-muted); cursor: pointer; text-transform: none; font-weight: normal; letter-spacing: normal;">Transformer
                        en todo list</label>
                </div>
            {% endif %}
            <div class="input-group" style="margin-top: 0.75rem;">
                <label>Administrateurs du canal</label>
                <div id="admin-chips-container"
                     style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.5rem; margin-top: 0.25rem;">
                    <!-- Creator chip -->
                    <div class="admin-chip creator"
                         style="background: rgba(255, 255, 255, 0.1); border: 1px solid var(--border-glass); padding: 0.25rem 0.75rem; border-radius: 2rem; font-size: 0.85rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.25rem;">
                        👤 {{ activeChannel.creator.displayName ?: activeChannel.creator.username }} <span
                            style="font-size: 0.75rem; opacity: 0.75;">(Créateur)</span>
                    </div>
                    <!-- Other administrators -->
                    {% for member in activeChannel.members %}
                        {% if activeChannel.administrators.contains(member) and member != activeChannel.creator %}
                            <div class="admin-chip" id="admin-chip-{{ member.id }}"
                                 style="background: rgba(99, 102, 241, 0.2); border: 1px solid #6366f1; padding: 0.25rem 0.75rem; border-radius: 2rem; font-size: 0.85rem; display: flex; align-items: center; gap: 0.5rem; color: var(--text-primary);">
                                <span>{{ member.displayName ?: member.username }}</span>
                                <button type="button" class="btn-remove-chip"
                                        style="background: none; border: none; color: var(--text-muted); cursor: pointer; padding: 0; font-size: 1rem; line-height: 1; display: flex; align-items: center;">
                                    &times;
                                </button>
                                <input type="hidden" name="administrators[]" value="{{ member.id }}">
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
            <div class="input-group" style="margin-top: 0.5rem;">
                <label for="admin-autocomplete-input">Ajouter un administrateur</label>
                <div class="autocomplete-wrapper" style="position: relative; width: 100%;">
                    <input type="text" id="admin-autocomplete-input" name="search"
                           placeholder="Saisir le nom d'un membre..."
                           class="input-sidebar" autocomplete="off"
                           hx-get="{{ path('app_channel_admin_autocomplete', {slug: activeChannel.slug}) }}"
                           hx-trigger="keyup changed delay:300ms"
                           hx-target="#admin-autocomplete-suggestions"
                           hx-swap="outerHTML"
                           onkeydown="if(event.key === 'Enter') event.preventDefault();">
                    <div id="admin-autocomplete-suggestions" class="emoji-autocomplete-dropdown"
                         style="display: none; top: 100%; bottom: auto; left: 0; right: 0; min-width: 100%; max-width: 100%; margin-top: 4px;"></div>
                </div>
            </div>
            <button type="submit" class="btn-publish" style="margin-top: 1.25rem;">Enregistrer les modifications
            </button>
        </form>

        {% if webhooks is defined %}
            {% include 'dashboard/_channel_webhooks.html.twig' with {webhooks: webhooks, activeChannel: activeChannel} %}
        {% endif %}
        {% if activeChannel.creator == app.user or is_granted('ROLE_ADMIN') %}
            <form action="{{ path('app_channel_delete', {slug: activeChannel.slug}) }}" method="POST"
                  data-confirm="Êtes-vous sûr de vouloir supprimer ce canal ? Tout l'historique des messages sera perdu définitivement."
                  hx-boost="false"
                  style="margin-top: 1rem; border-top: 1px solid var(--border-glass); padding-top: 1rem;">
                <button type="submit" class="btn-delete-channel"
                        style="width: 100%; justify-content: center; cursor: pointer;">🗑️ Supprimer le canal
                </button>
            </form>
        {% endif %}
    {% endblock %}
{% endembed %}
