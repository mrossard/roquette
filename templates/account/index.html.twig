{% extends 'base.html.twig' %}

{% block title %}Roquette - {{ 'Mon Compte'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
    {% set mercureTopics = [
        mercure_topic_prefix ~ '/users/' ~ app.user.username,
        mercure_topic_prefix ~ '/users/status'
    ] %}
    {% for ch in channels %}
        {% set mercureTopics = mercureTopics|merge([mercure_topic_prefix ~ '/channels/' ~ ch.slug]) %}
    {% endfor %}
    {% set hubUrl = mercure(mercureTopics, { subscribe: mercureTopics }) %}
    <div class="app-container" hx-boost="true" hx-ext="sse" sse-connect="{{ hubUrl }}">
    <header class="app-header">
        <div class="logo-area">
            <button id="mobile-sidebar-toggle" class="btn-mobile-toggle" aria-label="Afficher le menu">
                <span class="hamburger-bar"></span>
                <span class="hamburger-bar"></span>
                <span class="hamburger-bar"></span>
            </button>
            <span class="logo-rocket">🚀</span>
            <div class="logo-text">
                <h1>Roquette</h1>
                <p class="subtitle">Symfony + HTMX + Mercure + AssetMapper</p>
            </div>
        </div>

        {% include 'dashboard/_header_controls.html.twig' with {'show_back_button': true} %}
    </header>

    <main class="dashboard-grid">
        <!-- Channels Sidebar Panel -->
        {% include 'dashboard/_sidebar.html.twig' with {
            'channels': channels,
            'unreadCounts': {},
            'activeChannel': null,
            'pendingInvitations': []
        } %}

        <!-- Account Settings Panel -->
        <section class="card glass-panel settings-panel" style="flex-grow: 1;">
            {% include 'dashboard/_settings_skeleton.html.twig' %}
            <div class="card-header">
                <h2>{{ 'Gestion du Compte'|trans }}</h2>
                <p class="card-description">{{ 'Personnalisez votre profil et gérez vos informations de connexion.'|trans }}</p>
            </div>

            <div class="card-body" style="gap: 1rem;">
                {# Display Flash Messages #}
                {% for label, messages in app.flashes %}
                    {% for msg in messages %}
                        <div class="alert-{{ label == 'error' ? 'error' : 'success' }} fade-in">
                            {{ msg|trans }}
                        </div>
                    {% endfor %}
                {% endfor %}

                <div class="settings-grid">
                    <!-- Profile Settings Form -->
                    <form action="{{ path('app_account') }}" method="POST" class="form-section">
                        <input type="hidden" name="action" value="profile">
                        <h3>{{ 'Informations de profil'|trans }}</h3>

                        <div class="input-group">
                            <label for="username-static">{{ "Nom d'utilisateur (non modifiable)"|trans }}</label>
                            <input type="text" id="username-static" value="{{ user.username }}" disabled style="opacity: 0.6; cursor: not-allowed; background: rgba(0, 0, 0, 0.3);">
                        </div>

                        <div class="input-group">
                            <label for="displayName">{{ "Nom d'affichage"|trans }}</label>
                            <input type="text" name="displayName" id="displayName" value="{{ user.displayName }}"
                                   placeholder="{{ 'Ex: Jean Dupont'|trans }}" maxlength="30">
                        </div>

                        <div class="input-group">
                            <label>{{ 'Couleur du profil'|trans }}</label>
                            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem; background: rgba(0, 0, 0, 0.2); padding: 0.75rem 1rem; border-radius: 0.75rem; border: 1px solid var(--border-glass);">
                                <span class="feed-item-avatar" style="--user-hue: {{ user.hue }}; margin-bottom: 0; width: 36px; height: 36px; font-size: 1.1rem;">
                                    {{ user.username|slice(0, 1)|upper }}
                                </span>
                                <span class="feed-item-user" style="--user-hue: {{ user.hue }}; font-weight: 600; font-size: 1.05rem;">
                                    {{ user.displayName|default(user.username) }}
                                </span>
                            </div>
                            <input type="range" name="hue" min="0" max="360" value="{{ user.hue }}" class="hue-slider" style="width: 100%; cursor: pointer;"
                                   oninput="
                                       const avatar = this.previousElementSibling.firstElementChild;
                                       const name = this.previousElementSibling.lastElementChild;
                                       avatar.style.setProperty('--user-hue', this.value);
                                       name.style.setProperty('--user-hue', this.value);
                                       document.documentElement.style.setProperty('--user-hue-primary', this.value);
                                   ">
                        </div>

                        <div class="input-group">
                            <label for="statusOverride">{{ 'Statut de présence'|trans }}</label>
                            <select name="statusOverride" id="statusOverride" class="form-control"
                                    style="display: none;" data-prev-value="{{ user.statusOverride|default('auto') }}"
                                    onchange="
                                if (this.value === 'busy') {
                                    const self = this;
                                    if (window.openBusyStatusModal) {
                                        window.openBusyStatusModal(function() {
                                            self.setAttribute('data-prev-value', 'busy');
                                            updateCustomDropdownFromSelect('statusOverride');
                                        }, function() {
                                            self.value = self.getAttribute('data-prev-value') || 'auto';
                                            updateCustomDropdownFromSelect('statusOverride');
                                        });
                                    }
                                } else {
                                    this.setAttribute('data-prev-value', this.value);
                                    updateCustomDropdownFromSelect('statusOverride');
                                }
                            ">
                                <option value="auto"
                                        {% if user.statusOverride == 'auto' or user.statusOverride is null %}selected{% endif %}>{{ "Automatique (Basé sur l'activité)"|trans }}</option>
                                <option value="online"
                                        {% if user.statusOverride == 'online' %}selected{% endif %}>{{ 'En ligne'|trans }}</option>
                                <option value="away"
                                        {% if user.statusOverride == 'away' %}selected{% endif %}>{{ 'Absent'|trans }}</option>
                                <option value="busy"
                                        {% if user.statusOverride == 'busy' %}selected{% endif %}>{{ 'Occupé'|trans }}</option>
                                <option value="offline"
                                        {% if user.statusOverride == 'offline' %}selected{% endif %}>{{ 'Hors ligne (Invisible)'|trans }}</option>
                            </select>

                            <div class="custom-dropdown-container" id="custom-dropdown-statusOverride">
                                <button type="button" class="custom-dropdown-trigger"
                                        onclick="toggleCustomDropdown(event, 'statusOverride')">
                                    <span class="custom-dropdown-selected-label">
                                        {% if user.statusOverride == 'auto' or user.statusOverride is null %}{{ "Automatique (Basé sur l'activité)"|trans }}
                                        {% elseif user.statusOverride == 'online' %}{{ 'En ligne'|trans }}
                                        {% elseif user.statusOverride == 'away' %}{{ 'Absent'|trans }}
                                        {% elseif user.statusOverride == 'busy' %}{{ 'Occupé'|trans }}
                                        {% elseif user.statusOverride == 'offline' %}{{ 'Hors ligne (Invisible)'|trans }}
                                        {% endif %}
                                    </span>
                                    <span class="dropdown-chevron">▼</span>
                                </button>
                                <div class="custom-dropdown-menu">
                                    <button type="button"
                                            class="custom-dropdown-item {% if user.statusOverride == 'auto' or user.statusOverride is null %}active{% endif %}"
                                            data-value="auto"
                                            onclick="selectCustomDropdownOption(event, 'statusOverride')">
                                        {{ "Automatique (Basé sur l'activité)"|trans }}
                                    </button>
                                    <button type="button"
                                            class="custom-dropdown-item {% if user.statusOverride == 'online' %}active{% endif %}"
                                            data-value="online"
                                            onclick="selectCustomDropdownOption(event, 'statusOverride')">
                                        {{ 'En ligne'|trans }}
                                    </button>
                                    <button type="button"
                                            class="custom-dropdown-item {% if user.statusOverride == 'away' %}active{% endif %}"
                                            data-value="away"
                                            onclick="selectCustomDropdownOption(event, 'statusOverride')">
                                        {{ 'Absent'|trans }}
                                    </button>
                                    <button type="button"
                                            class="custom-dropdown-item {% if user.statusOverride == 'busy' %}active{% endif %}"
                                            data-value="busy"
                                            onclick="selectCustomDropdownOption(event, 'statusOverride')">
                                        {{ 'Occupé'|trans }}
                                    </button>
                                    <button type="button"
                                            class="custom-dropdown-item {% if user.statusOverride == 'offline' %}active{% endif %}"
                                            data-value="offline"
                                            onclick="selectCustomDropdownOption(event, 'statusOverride')">
                                        {{ 'Hors ligne (Invisible)'|trans }}
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="input-group">
                            <label for="locale">{{ 'Langue'|trans }}</label>
                            <select name="locale" id="locale" class="form-control" style="display: none;">
                                <option value="fr"
                                        {% if user.locale == 'fr' %}selected{% endif %}>{{ 'Français'|trans }}</option>
                                <option value="en"
                                        {% if user.locale == 'en' %}selected{% endif %}>{{ 'English'|trans }}</option>
                            </select>

                            <div class="custom-dropdown-container" id="custom-dropdown-locale">
                                <button type="button" class="custom-dropdown-trigger"
                                        onclick="toggleCustomDropdown(event, 'locale')">
                                    <span class="custom-dropdown-selected-label">
                                        {% if user.locale == 'en' %}{{ 'English'|trans }}{% else %}{{ 'Français'|trans }}{% endif %}
                                    </span>
                                    <span class="dropdown-chevron">▼</span>
                                </button>
                                <div class="custom-dropdown-menu">
                                    <button type="button"
                                            class="custom-dropdown-item {% if user.locale == 'fr' or user.locale is null %}active{% endif %}"
                                            data-value="fr" onclick="selectCustomDropdownOption(event, 'locale')">
                                        {{ 'Français'|trans }}
                                    </button>
                                    <button type="button"
                                            class="custom-dropdown-item {% if user.locale == 'en' %}active{% endif %}"
                                            data-value="en" onclick="selectCustomDropdownOption(event, 'locale')">
                                        {{ 'English'|trans }}
                                    </button>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn-submit">{{ 'Sauvegarder le profil'|trans }}</button>
                    </form>

                    <!-- Password Settings Form -->
                    <form action="{{ path('app_account') }}" method="POST" class="form-section">
                        <input type="hidden" name="action" value="password">
                        <h3>{{ 'Changer le mot de passe'|trans }}</h3>

                        <div class="input-group">
                            <label for="currentPassword">{{ 'Mot de passe actuel'|trans }}</label>
                            <input type="password" name="currentPassword" id="currentPassword" required placeholder="••••••••">
                        </div>

                        <div class="input-group">
                            <label for="newPassword">{{ 'Nouveau mot de passe'|trans }}</label>
                            <input type="password" name="newPassword" id="newPassword" required
                                   placeholder="{{ 'Min. 6 caractères'|trans }}">
                        </div>

                        <div class="input-group">
                            <label for="confirmPassword">{{ 'Confirmer le nouveau mot de passe'|trans }}</label>
                            <input type="password" name="confirmPassword" id="confirmPassword" required
                                   placeholder="{{ 'Confirmez'|trans }}">
                        </div>

                        <button type="submit" class="btn-submit">{{ 'Mettre à jour le mot de passe'|trans }}</button>
                    </form>

                    <!-- Desktop Notifications Settings -->
                    <form action="{{ path('app_account') }}" method="POST" class="form-section" id="desktop-notifications-section">
                        <input type="hidden" name="action" value="notifications">
                        <h3>{{ 'Notifications de bureau'|trans }}</h3>
                        <p class="card-description" style="margin-bottom: 1.25rem;">
                            {{ 'Recevez des notifications en direct pour les nouveaux messages et invitations lorsque l\'application est en arrière-plan.'|trans }}
                        </p>
                        <div id="notification-settings-content">
                            <!-- Populated dynamically via JS -->
                        </div>

                        <div class="input-group" style="display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-top: 1rem; margin-bottom: 1.25rem; background: rgba(0, 0, 0, 0.2); padding: 0.75rem 1rem; border-radius: 0.75rem; border: 1px solid var(--border-glass);">
                            <label for="mentionNotificationsEnabled"
                                   style="margin-bottom: 0; cursor: pointer; font-weight: 500;">{{ 'Notifications de bureau pour les mentions'|trans }}</label>
                            <label class="switch" style="position: relative; display: inline-block; width: 44px; height: 24px; flex-shrink: 0; margin-bottom: 0;">
                                <input type="checkbox" name="mentionNotificationsEnabled" id="mentionNotificationsEnabled" value="1" {% if user.mentionNotificationsEnabled %}checked{% endif %} style="opacity: 0; width: 0; height: 0;"
                                       onchange="this.nextElementSibling.style.backgroundColor = this.checked ? 'var(--accent-cyan)' : 'rgba(255, 255, 255, 0.1)';">
                                <span class="slider round" style="position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: {% if user.mentionNotificationsEnabled %}var(--accent-cyan){% else %}rgba(255, 255, 255, 0.1){% endif %}; transition: .3s; border-radius: 24px; border: 1px solid var(--border-glass);"></span>
                            </label>
                        </div>

                        <button type="submit" class="btn-submit">{{ 'Sauvegarder les notifications'|trans }}</button>
                    </form>
                </div>
            </div>
        </section>
    </main>

    {% include '_footer.html.twig' %}
</div>

    <script>
        function toggleCustomDropdown(event, selectId) {
            event.stopPropagation();
            const container = document.getElementById('custom-dropdown-' + selectId);
            const isOpen = container.classList.contains('open');

            // Close all other dropdowns
            document.querySelectorAll('.custom-dropdown-container').forEach(c => {
                c.classList.remove('open');
                const menu = c.querySelector('.custom-dropdown-menu');
                if (menu) menu.style.display = 'none';
            });

            if (!isOpen) {
                container.classList.add('open');
                container.querySelector('.custom-dropdown-menu').style.display = 'flex';
            }
        }

        function selectCustomDropdownOption(event, selectId) {
            event.stopPropagation();
            const item = event.currentTarget;
            const val = item.getAttribute('data-value');
            const select = document.getElementById(selectId);

            // Update hidden select
            select.value = val;

            // Trigger change event to run any onchange handlers
            const changeEvent = new Event('change', {bubbles: true});
            select.dispatchEvent(changeEvent);

            // Update labels and active states in custom dropdown UI
            updateCustomDropdownFromSelect(selectId);

            // Close menu
            const container = document.getElementById('custom-dropdown-' + selectId);
            container.classList.remove('open');
            container.querySelector('.custom-dropdown-menu').style.display = 'none';
        }

        function updateCustomDropdownFromSelect(selectId) {
            const select = document.getElementById(selectId);
            const container = document.getElementById('custom-dropdown-' + selectId);
            const selectedOption = select.options[select.selectedIndex];

            // Update label
            if (selectedOption && container) {
                const labelEl = container.querySelector('.custom-dropdown-selected-label');
                if (labelEl) {
                    labelEl.textContent = selectedOption.textContent;
                }
            }

            // Update active class
            if (container) {
                container.querySelectorAll('.custom-dropdown-item').forEach(item => {
                    if (item.getAttribute('data-value') === select.value) {
                        item.classList.add('active');
                    } else {
                        item.classList.remove('active');
                    }
                });
            }
        }

        // Close dropdowns on document click
        document.addEventListener('click', function () {
            document.querySelectorAll('.custom-dropdown-container').forEach(c => {
                c.classList.remove('open');
                const menu = c.querySelector('.custom-dropdown-menu');
                if (menu) menu.style.display = 'none';
            });
        });
    </script>
{% endblock %}
