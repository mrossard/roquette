# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=prod
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> proxy
SYMFONY_TRUSTED_HEADERS=x-forwarded-for,x-forwarded-proto,x-forwarded-port,x-forwarded-host
SYMFONY_TRUSTED_PROXIES='private_ranges'
###< proxy

###> symfony/mercure-bundle ###
# See https://symfony.com/doc/current/mercure.html#configuration
# The URL of the Mercure hub, used by the app to publish updates (can be a local URL)
MERCURE_URL=https://example.com/.well-known/mercure
# The public URL of the Mercure hub, used by the browser to connect
MERCURE_PUBLIC_URL=https://example.com/.well-known/mercure
# The secret used to sign the JWTs
MERCURE_JWT_SECRET="!ChangeThisMercureHubJWTSecretKey!"
###< symfony/mercure-bundle ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
POSTGRES_DB="roquette"
POSTGRES_USER="app"
POSTGRES_PASSWORD="!ChangeMe!"
DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> generic-oauth2 ###
OAUTH_CLIENT_ID="mock_client_id"
OAUTH_CLIENT_SECRET="mock_client_secret"
OAUTH_REDIRECT_URI="http://127.0.0.1:8000/oauth/check"
OAUTH_AUTH_URL="http://127.0.0.1:8000/oauth/mock/authorize"
OAUTH_TOKEN_URL="http://127.0.0.1:8000/oauth/mock/token"
OAUTH_USER_INFO_URL="http://127.0.0.1:8000/oauth/mock/user"
OAUTH_USERNAME_FIELD="username"
OAUTH_SCOPE="read"
###< generic-oauth2 ###

###> mercure-topics ###
MERCURE_TOPIC_PREFIX=roquette
###< mercure-topics ###


REDIS_URL=redis://redis:6379

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
MESSENGER_TRANSPORT_DSN=redis://redis:6379/messages
###< symfony/messenger ###

###> clamav ###
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
###< clamav ###

###> authentication-modes ###
AUTH_FORM_ENABLED=true
AUTH_OAUTH_ENABLED=true
###< authentication-modes ###

###> mesdiscussions-emojis ###
EMOJI_BASE_URL="http://127.0.0.1:8000/uploads/emojis"
###< mesdiscussions-emojis ###

###> aws-s3-minio ###
AWS_KEY=minioadmin
AWS_SECRET=minioadminpassword
AWS_BUCKET=roquette-uploads
AWS_ENDPOINT=http://minio:9000
###< aws-s3-minio ###

###> ldap ###
# LDAP connection settings (overrides for the LdapGroupProvider)
# LDAP_HOST=127.0.0.1
# LDAP_PORT=389
# LDAP_ENCRYPTION=none
# LDAP_BASE_DN=
# LDAP_BIND_DN=
# LDAP_BIND_PASSWORD=
# LDAP_GROUP_SEARCH_BASE=
# LDAP_GROUP_SEARCH_FILTER='(objectClass=groupOfNames)'
# LDAP_GROUP_MEMBERSHIP_ATTRIBUTE=member
# LDAP_GROUP_MEMBERSHIP_VALUE=dn
# LDAP_USER_SEARCH_BASE=
# LDAP_USER_SEARCH_FILTER='(uid={username})'
###< ldap ###

###> group-provider ###
# GROUP_PROVIDER_TYPE=in_memory
###< group-provider ###

###> symfony/ai-bundle ###
LLM_MODEL=qwen2.5:0.5b
LLM_ENDPOINT=http://ollama:11434
LLM_SYSTEM_PROMPT="Tu es l'Assistant Roquette, un assistant virtuel d'aide pour l'application Roquette."
LLM_MAX_SUMMARY_MESSAGES=50
###< symfony/ai-bundle ###

###> web-push ###
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@roquette.local
###< web-push ###

###> symfony/mailer ###
MAILER_DSN=smtp://localhost:1025
###< symfony/mailer ###
